/**
 * 场景 1：整批原样搬入 / 搬出（DIST_NORM）
 *
 * 最基础的搬运模式：数据原样搬入寄存器，逐元素计算后原样搬出。
 * dist 缺省即为 DIST_NORM。搬入不带 mask（尾部多读由后续 mask 屏蔽），
 * 搬出必须带 mask（否则尾轮 64 lane 全部写回，覆盖 buffer 有效数据）。
 *
 * 输入取 x[i]=i*0.5、y[i]=i*0.25，输出应为 z[i]=i*0.75。N=150 取非 VL(64)
 * 整数倍以覆盖尾块路径：z[149] 有值、z[150] 起保持初始化的预填校验值。
 *
 * 编译 & 运行：
 *   cmake -S . -B build -DNPU_ARCH=dav-3510   # 仓库根目录
 *   cmake --build build --target scene1_dist_norm
 *   ./build/Samples/1_Features/memory_optimization/reg_data_movement/scene1_dist_norm
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t N = 150;                          // 不整除 VL，留尾块
static constexpr uint32_t N_PAD = 192;                      // UB 侧按 VL 整数倍分配

// ============ VF 层：MicroAPI 必须放在 __simd_vf__ 函数中 ============
template <typename T>
__simd_vf__ inline void Scene1Vf(__ubuf__ T* xAddr, __ubuf__ T* yAddr,
                                 __ubuf__ T* zAddr, uint32_t n, uint16_t loopNum)
{
    uint32_t VL = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    AscendC::Reg::RegTensor<T> vregA, vregB, vregC;
    AscendC::Reg::MaskReg mask;
    uint32_t count = n;

    for (uint16_t i = 0; i < loopNum; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);   // 开前 count 个 lane，count 原地递减

        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_NORM>(
            vregA, xAddr + i * VL);                              // 搬入，无 mask
        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_NORM>(
            vregB, yAddr + i * VL);

        AscendC::Reg::Add(vregC, vregA, vregB, mask);

        AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_NORM>(
            zAddr + i * VL, vregC, mask);                        // 搬出，带 mask
    }
}

// ============ Kernel：GM → UB → VF → UB → GM，单核单 tile ============
__global__ __aicore__ __vector__ void Scene1Kernel(GM_ADDR x, GM_ADDR y, GM_ADDR z)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, yBuf, zBuf;
    pipe.InitBuffer(xBuf, N_PAD * sizeof(float));
    pipe.InitBuffer(yBuf, N_PAD * sizeof(float));
    pipe.InitBuffer(zBuf, N_PAD * sizeof(float));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<float> yUb = yBuf.Get<float>();
    AscendC::LocalTensor<float> zUb = zBuf.Get<float>();

    AscendC::GlobalTensor<float> xGm, yGm, zGm;
    xGm.SetGlobalBuffer((__gm__ float*)x, N_PAD);
    yGm.SetGlobalBuffer((__gm__ float*)y, N_PAD);
    zGm.SetGlobalBuffer((__gm__ float*)z, N_PAD);

    AscendC::DataCopy(xUb, xGm, N_PAD);
    AscendC::DataCopy(yUb, yGm, N_PAD);
    AscendC::DataCopy(zUb, zGm, N_PAD);   // 带入预填校验值，验证尾部不被覆盖
    AscendC::PipeBarrier<PIPE_ALL>();

    constexpr uint16_t loopNum = (N * sizeof(float) + AscendC::VECTOR_REG_WIDTH - 1) / AscendC::VECTOR_REG_WIDTH;
    Scene1Vf<float>((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ float*)yUb.GetPhyAddr(),
                    (__ubuf__ float*)zUb.GetPhyAddr(), N, loopNum);
    AscendC::PipeBarrier<PIPE_ALL>();

    // 关键数据：头部原样相加；148/149 是尾轮 mask 内，150/151 在 mask 外保持预填值
    AscendC::PRINTF("[scene1] in : x[0..3]=%f %f %f %f  y[0..3]=%f %f %f %f\n",
           xUb.GetValue(0), xUb.GetValue(1), xUb.GetValue(2), xUb.GetValue(3),
           yUb.GetValue(0), yUb.GetValue(1), yUb.GetValue(2), yUb.GetValue(3));
    AscendC::PRINTF("[scene1] out: z[0..3]=%f %f %f %f\n",
           zUb.GetValue(0), zUb.GetValue(1), zUb.GetValue(2), zUb.GetValue(3));
    AscendC::PRINTF("[scene1] tail: z[148]=%f z[149]=%f | z[150]=%f z[151]=%f (sentinel -1)\n",
           zUb.GetValue(148), zUb.GetValue(149), zUb.GetValue(150), zUb.GetValue(151));

    AscendC::DataCopy(zGm, zUb, N_PAD);
}

// ============ Host 侧 ============
int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t bytes = N_PAD * sizeof(float);
    std::vector<float> hX(N_PAD, 0.f), hY(N_PAD, 0.f), hZ(N_PAD, -1.f);
    for (uint32_t i = 0; i < N; i++) { hX[i] = i * 0.5f; hY[i] = i * 0.25f; }

    uint8_t *dX, *dY, *dZ;
    CHECK_ACL(aclrtMalloc((void**)&dX, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dZ, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, bytes, hX.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, bytes, hY.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dZ, bytes, hZ.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene1Kernel<<<1, nullptr, stream>>>(dX, dY, dZ);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hZ.data(), bytes, dZ, bytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t i = 0; i < N && ok; i++) ok = std::fabs(hZ[i] - i * 0.75f) <= 1e-4f;
    for (uint32_t i = N; i < N_PAD && ok; i++) ok = (hZ[i] == -1.f);   // mask 外不被写
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dY); aclrtFree(dZ);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
