/**
 * 场景 7：按索引取数（Arange 直接生成索引 + DataCopyGather）
 *
 * Gather（vgather2）按逐 lane 寻址：dstReg[lane] = baseAddr[index[lane]]，
 * 索引就是一个普通的 uint32 RegTensor，每个 lane 一个独立索引。索引不必从 UB
 * 读入再用 E2B 展开，可以直接用 Arange 在寄存器内生成。本例用 DECREASE_ORDER
 * 生成倒序索引 idx[i]=63-i，Gather 后 out[i]=data[63-i]，得到 data 的逆序拷贝，
 * 64 个 lane 各取各的、互不重复。
 *
 * 注意：Arange 不支持 uint32，需把 RegTensor<uint32_t> 的引用强转成
 * RegTensor<int32_t> 再调用（0..63 的非负值 int32/uint32 位型一致）。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_FP32 = 64;

__simd_vf__ inline void Scene7Vf(__ubuf__ float* dataAddr, __ubuf__ float* outAddr)
{
    AscendC::Reg::RegTensor<uint32_t> idxReg;
    AscendC::Reg::RegTensor<float> vregOut;
    AscendC::Reg::MaskReg preg;
    uint32_t count = VL_FP32;

    preg = AscendC::Reg::UpdateMask<uint32_t>(count);

    // 寄存器内直接生成倒序索引 idx[i]=63-i，逐 lane 一个，免去 UB 索引与 E2B 展开。
    // DECREASE_ORDER 的标量是序列最小值（落在最后一个 lane），故传 0：idx[i]=0+(VL-1-i)=63-i
    AscendC::Reg::Arange<int32_t, AscendC::Reg::IndexOrder::DECREASE_ORDER>(
        (AscendC::Reg::RegTensor<int32_t>&)idxReg, 0);

    AscendC::Reg::Gather<float, float, uint32_t>(vregOut, dataAddr, idxReg, preg);   // 逐 lane 离散收集

    AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(outAddr, vregOut, preg); // 连续写出
}

__global__ __aicore__ __vector__ void Scene7Kernel(GM_ADDR data, GM_ADDR out)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> dataBuf, outBuf;
    pipe.InitBuffer(dataBuf, VL_FP32 * sizeof(float));
    pipe.InitBuffer(outBuf, VL_FP32 * sizeof(float));
    AscendC::LocalTensor<float> dataUb = dataBuf.Get<float>();
    AscendC::LocalTensor<float> outUb = outBuf.Get<float>();

    AscendC::GlobalTensor<float> dataGm, outGm;
    dataGm.SetGlobalBuffer((__gm__ float*)data, VL_FP32);
    outGm.SetGlobalBuffer((__gm__ float*)out, VL_FP32);

    AscendC::DataCopy(dataUb, dataGm, VL_FP32);
    AscendC::DataCopy(outUb, outGm, VL_FP32);
    AscendC::PipeBarrier<PIPE_ALL>();

    Scene7Vf((__ubuf__ float*)dataUb.GetPhyAddr(), (__ubuf__ float*)outUb.GetPhyAddr());
    AscendC::PipeBarrier<PIPE_ALL>();

    // 倒序索引 idx[i]=63-i：out[i]=data[63-i]，out 为 data 的逆序拷贝
    AscendC::PRINTF("[scene7] data[0..3]=%f %f %f %f (data[i]=i)\n",
           dataUb.GetValue(0), dataUb.GetValue(1), dataUb.GetValue(2), dataUb.GetValue(3));
    AscendC::PRINTF("[scene7] out[0..3]=%f %f %f %f | out[62]=%f out[63]=%f (idx[i]=63-i)\n",
           outUb.GetValue(0), outUb.GetValue(1), outUb.GetValue(2), outUb.GetValue(3),
           outUb.GetValue(62), outUb.GetValue(63));

    AscendC::DataCopy(outGm, outUb, VL_FP32);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t dataB = VL_FP32 * sizeof(float);
    std::vector<float> hData(VL_FP32), hOut(VL_FP32, -1.f);
    for (uint32_t i = 0; i < VL_FP32; i++) hData[i] = float(i);

    uint8_t *dData, *dOut;
    CHECK_ACL(aclrtMalloc((void**)&dData, dataB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dOut, dataB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dData, dataB, hData.data(), dataB, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dOut, dataB, hOut.data(), dataB, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene7Kernel<<<1, nullptr, stream>>>(dData, dOut);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hOut.data(), dataB, dOut, dataB, ACL_MEMCPY_DEVICE_TO_HOST));

    std::cout << "out[0..15] = ";
    for (uint32_t i = 0; i < 16; i++) std::cout << hOut[i] << " ";
    std::cout << "\nout[48..63] = ";
    for (uint32_t i = 48; i < VL_FP32; i++) std::cout << hOut[i] << " ";
    std::cout << std::endl;

    bool ok = true;   // 逐 lane 倒序收集：out[i] = data[63-i] = 63-i
    for (uint32_t i = 0; i < VL_FP32 && ok; i++)
        ok = (hOut[i] == float(VL_FP32 - 1 - i));
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dData); aclrtFree(dOut);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
