/**
 * 场景 8：交织拆合（DIST_DINTLV_B32 / DIST_INTLV_B32）
 *
 * 复数 [r0,i0,r1,i1,…] 类数据：DINTLV 搬入时按奇偶拆成两个寄存器，
 * 各自独立计算后 INTLV 交错合并写回。双寄存器一次搬 2*VL 元素，
 * 步长按 VL*2 推进。双寄存器重载的 dist 模板参数没有缺省值，必须显式。
 *
 * 输入 x[2k]=k+0.25（实部）、x[2k+1]=-(k+0.5)（虚部），Abs 后合并写回，
 * 虚部应去掉负号、实部不变，交织次序保持。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_FP32 = 64;
static constexpr uint32_t PAIRS = VL_FP32;                 // 64 对 (r,i)
static constexpr uint32_t N = PAIRS * 2;                  // 128 元素

__simd_vf__ inline void Scene8Vf(__ubuf__ float* xAddr, __ubuf__ float* yAddr)
{
    AscendC::Reg::RegTensor<float> vregEven, vregOdd, vregAbsE, vregAbsO;
    AscendC::Reg::MaskReg preg;
    uint32_t count = PAIRS;

    preg = AscendC::Reg::UpdateMask<float>(count);

    AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_DINTLV_B32>(
        vregEven, vregOdd, xAddr);                         // 偶 lane → even，奇 lane → odd

    AscendC::Reg::Abs(vregAbsE, vregEven, preg);
    AscendC::Reg::Abs(vregAbsO, vregOdd, preg);

    AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_INTLV_B32>(
        yAddr, vregAbsE, vregAbsO, preg);                  // 交错合并写回
}

__global__ __aicore__ __vector__ void Scene8Kernel(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, yBuf;
    pipe.InitBuffer(xBuf, N * sizeof(float));
    pipe.InitBuffer(yBuf, N * sizeof(float));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<float> yUb = yBuf.Get<float>();

    AscendC::GlobalTensor<float> xGm, yGm;
    xGm.SetGlobalBuffer((__gm__ float*)x, N);
    yGm.SetGlobalBuffer((__gm__ float*)y, N);

    AscendC::DataCopy(xUb, xGm, N);
    AscendC::DataCopy(yUb, yGm, N);
    AscendC::PipeBarrier<PIPE_ALL>();

    Scene8Vf((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ float*)yUb.GetPhyAddr());
    AscendC::PipeBarrier<PIPE_ALL>();

    // 交织次序保持：y[2k]=|r_k| 不变、y[2k+1]=|i_k| 去负号
    AscendC::PRINTF("[scene8] in : x[0..5]=%f %f %f %f %f %f (r,i interleaved)\n",
           xUb.GetValue(0), xUb.GetValue(1), xUb.GetValue(2),
           xUb.GetValue(3), xUb.GetValue(4), xUb.GetValue(5));
    AscendC::PRINTF("[scene8] out: y[0..5]=%f %f %f %f %f %f\n",
           yUb.GetValue(0), yUb.GetValue(1), yUb.GetValue(2),
           yUb.GetValue(3), yUb.GetValue(4), yUb.GetValue(5));

    AscendC::DataCopy(yGm, yUb, N);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t bytes = N * sizeof(float);
    std::vector<float> hX(N), hY(N, -1.f);
    for (uint32_t k = 0; k < PAIRS; k++) { hX[2 * k] = k + 0.25f; hX[2 * k + 1] = -(k + 0.5f); }

    uint8_t *dX, *dY;
    CHECK_ACL(aclrtMalloc((void**)&dX, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, bytes, hX.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, bytes, hY.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene8Kernel<<<1, nullptr, stream>>>(dX, dY);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), bytes, dY, bytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t i = 0; i < N && ok; i++) ok = (hY[i] == std::fabs(hX[i]));
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dY);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
