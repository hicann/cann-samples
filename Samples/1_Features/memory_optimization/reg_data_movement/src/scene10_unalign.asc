/**
 * 场景 10：非对齐搬运（StoreUnAlign 三件套）
 *
 * 每轮写出元素数不定（本例每轮 50 个，不是 32 B 整数倍）时 StoreAlign 无法使用。
 * StoreUnAlign 用 UnalignReg 暂存器把不满一块的残余攒起来，够 32 B 才刷出；
 * 三件套缺一不可：① 声明 UnalignReg → ② 循环内 StoreUnAlign（POST_MODE_UPDATE
 * 自动推进地址）→ ③ 循环后 StoreUnAlignPost 刷尾。漏 ③ 输出末尾丢数、不报错。
 *
 * 读侧保持 VL 对齐、每轮 mask 取前 50 个 lane，写侧连续累积：
 * y[r*50+j] = x[r*64+j]，即 y[49]=49、y[50]=64、y[149]=177，输出无空洞。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_B32 = 256 / sizeof(float);
static constexpr uint32_t PER_ROUND = 50;                 // 每轮写出数，非块整数倍
static constexpr uint32_t ROUNDS = 3;
static constexpr uint32_t N = PER_ROUND * ROUNDS;         // 150
static constexpr uint32_t N_PAD = 192;

__simd_vf__ inline void Scene10Vf(__ubuf__ float* xAddr, __ubuf__ float* yAddr)
{
    AscendC::Reg::RegTensor<float> vreg;
    AscendC::Reg::MaskReg mask;
    AscendC::Reg::UnalignReg ureg;                        // ① 暂存器

    for (uint16_t i = 0; i < ROUNDS; i++) {
        uint32_t cnt = PER_ROUND;
        mask = AscendC::Reg::UpdateMask<float>(cnt);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(
            vreg, xAddr + i * VL_B32);                           // 读侧保持 32 B 对齐

        AscendC::Reg::StoreUnAlign<float, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(
            yAddr, vreg, ureg, PER_ROUND);                // ② 累积，yAddr 自动推进
    }
    AscendC::Reg::StoreUnAlignPost(yAddr, ureg, 0);       // ③ 刷尾，漏掉则尾部丢失
}

__global__ __aicore__ __vector__ void Scene10Kernel(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, yBuf;
    pipe.InitBuffer(xBuf, N_PAD * sizeof(float));
    pipe.InitBuffer(yBuf, N_PAD * sizeof(float));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<float> yUb = yBuf.Get<float>();

    AscendC::GlobalTensor<float> xGm, yGm;
    xGm.SetGlobalBuffer((__gm__ float*)x, N_PAD);
    yGm.SetGlobalBuffer((__gm__ float*)y, N_PAD);

    AscendC::DataCopy(xUb, xGm, N_PAD);
    AscendC::DataCopy(yUb, yGm, N_PAD);
    AscendC::PipeBarrier<PIPE_ALL>();

    Scene10Vf((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ float*)yUb.GetPhyAddr());
    AscendC::PipeBarrier<PIPE_ALL>();

    // 三轮 50 个拼接连续：跨轮边界 y[49]=49、y[50]=64；Post 刷出的尾段 y[149]=177
    AscendC::PRINTF("[scene10] out: y[0]=%f y[49]=%f y[50]=%f y[99]=%f y[100]=%f\n",
           yUb.GetValue(0), yUb.GetValue(49), yUb.GetValue(50),
           yUb.GetValue(99), yUb.GetValue(100));
    AscendC::PRINTF("[scene10] tail: y[144]=%f y[149]=%f | y[150]=%f (sentinel -1)\n",
           yUb.GetValue(144), yUb.GetValue(149), yUb.GetValue(150));

    AscendC::DataCopy(yGm, yUb, N_PAD);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t bytes = N_PAD * sizeof(float);
    std::vector<float> hX(N_PAD, 0.f), hY(N_PAD, -1.f);
    for (uint32_t i = 0; i < N_PAD; i++) hX[i] = float(i);

    uint8_t *dX, *dY;
    CHECK_ACL(aclrtMalloc((void**)&dX, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, bytes, hX.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, bytes, hY.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene10Kernel<<<1, nullptr, stream>>>(dX, dY);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), bytes, dY, bytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t r = 0; r < ROUNDS && ok; r++)
        for (uint32_t j = 0; j < PER_ROUND && ok; j++)
            ok = (hY[r * PER_ROUND + j] == float(r * VL_B32 + j));
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dY);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
