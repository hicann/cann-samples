/**
 * 场景 2：升降位往返（DIST_UNPACK_B16 ↔ DIST_PACK_B32）
 *
 * 混合精度路线：UB 中 half 紧排，UNPACK 搬入展开进 32 位槽，Cast 升 fp32，
 * Exp 在 fp32 精度下计算，Cast 回 half，PACK 取低 16 位紧排落盘。
 * mask 必须按计算类型（fp32，64 lane）生成，而不是存储类型（half，128 lane）。
 *
 * 输入 x[i] = i * 0.01，输出应为 exp(x[i])。N=150 留尾块验证宽类型 mask 收尾。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_B32 = 256 / sizeof(float);   // 计算 lane 数：64
static constexpr uint32_t N = 150;
static constexpr uint32_t N_PAD = 192;

// CastTrait 等 Reg 类型仅 device 侧可见，常量需置于 #ifdef __NPU_ARCH__ 或函数体内
#ifdef __NPU_ARCH__
static constexpr AscendC::Reg::CastTrait CAST_B16_TO_B32 = {
    AscendC::Reg::RegLayout::ZERO, AscendC::Reg::SatMode::UNKNOWN,
    AscendC::Reg::MaskMergeMode::ZEROING, AscendC::RoundMode::UNKNOWN};
static constexpr AscendC::Reg::CastTrait CAST_B32_TO_B16 = {
    AscendC::Reg::RegLayout::ZERO, AscendC::Reg::SatMode::NO_SAT,   // 降位必须显式饱和模式
    AscendC::Reg::MaskMergeMode::ZEROING, AscendC::RoundMode::CAST_RINT};
#endif

template <typename T>
__simd_vf__ inline void Scene2Vf(__ubuf__ T* xAddr, __ubuf__ T* yAddr,
                                 uint32_t n, uint16_t loopNum)
{
    AscendC::Reg::RegTensor<T> vreg16In, vreg16Out;       // 128 lane × 16b
    AscendC::Reg::RegTensor<float> vreg32In, vreg32Out;   // 64 lane × 32b
    AscendC::Reg::MaskReg mask;
    uint32_t count = n;

    for (uint16_t i = 0; i < loopNum; i++) {
        mask = AscendC::Reg::UpdateMask<float>(count);     // 按宽类型生成 mask

        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(
            vreg16In, xAddr + i * VL_B32);                 // 紧排 b16 → 32 位槽

        AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(vreg32In, vreg16In, mask);
        AscendC::Reg::Exp(vreg32Out, vreg32In, mask);
        AscendC::Reg::Cast<T, float, CAST_B32_TO_B16>(vreg16Out, vreg32Out, mask);

        AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_PACK_B32>(
            yAddr + i * VL_B32, vreg16Out, mask);          // 32 位槽低 16 位 → 紧排
    }
}

__global__ __aicore__ __vector__ void Scene2Kernel(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, yBuf;
    pipe.InitBuffer(xBuf, N_PAD * sizeof(half));
    pipe.InitBuffer(yBuf, N_PAD * sizeof(half));
    AscendC::LocalTensor<half> xUb = xBuf.Get<half>();
    AscendC::LocalTensor<half> yUb = yBuf.Get<half>();

    AscendC::GlobalTensor<half> xGm, yGm;
    xGm.SetGlobalBuffer((__gm__ half*)x, N_PAD);
    yGm.SetGlobalBuffer((__gm__ half*)y, N_PAD);

    AscendC::DataCopy(xUb, xGm, N_PAD);
    AscendC::DataCopy(yUb, yGm, N_PAD);
    AscendC::PipeBarrier<PIPE_ALL>();

    constexpr uint16_t loopNum = (N + VL_B32 - 1) / VL_B32;
    Scene2Vf<half>((__ubuf__ half*)xUb.GetPhyAddr(), (__ubuf__ half*)yUb.GetPhyAddr(),
                   N, loopNum);
    AscendC::PipeBarrier<PIPE_ALL>();

    // exp(0)=1, exp(0.01)≈1.010, exp(0.02)≈1.020；尾部 mask 外保持预填值 -1
    AscendC::PRINTF("[scene2] in : x[0..3]=%f %f %f %f\n",
           (float)xUb.GetValue(0), (float)xUb.GetValue(1),
           (float)xUb.GetValue(2), (float)xUb.GetValue(3));
    AscendC::PRINTF("[scene2] out: y[0..3]=%f %f %f %f\n",
           (float)yUb.GetValue(0), (float)yUb.GetValue(1),
           (float)yUb.GetValue(2), (float)yUb.GetValue(3));
    AscendC::PRINTF("[scene2] tail: y[149]=%f | y[150]=%f (sentinel -1)\n",
           (float)yUb.GetValue(149), (float)yUb.GetValue(150));

    AscendC::DataCopy(yGm, yUb, N_PAD);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t bytes = N_PAD * sizeof(aclFloat16);
    std::vector<aclFloat16> hX(N_PAD, aclFloatToFloat16(0.f)), hY(N_PAD, aclFloatToFloat16(-1.f));
    for (uint32_t i = 0; i < N; i++) hX[i] = aclFloatToFloat16(i * 0.01f);

    uint8_t *dX, *dY;
    CHECK_ACL(aclrtMalloc((void**)&dX, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, bytes, hX.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, bytes, hY.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene2Kernel<<<1, nullptr, stream>>>(dX, dY);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), bytes, dY, bytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t i = 0; i < N && ok; i++) {
        float got = aclFloat16ToFloat(hY[i]);
        float exp = std::exp(i * 0.01f);
        ok = std::fabs(got - exp) <= exp * 2e-3f;   // half 精度容差
    }
    for (uint32_t i = N; i < N_PAD && ok; i++) ok = (aclFloat16ToFloat(hY[i]) == -1.f);
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dY);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
