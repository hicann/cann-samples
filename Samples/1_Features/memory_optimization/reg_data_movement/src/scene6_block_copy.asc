/**
 * 场景 6：跳跃搬运（DATA_BLOCK_COPY）
 *
 * 以 DataBlock（32 B = 8 个 float）为单位跳写：寄存器 64 lane = 8 块，
 * blockStride=2 时第 k 块落在 y[k*16..k*16+7]，块间留 8 个预填值。
 * stride 数的是 32 B 块——按字节或元素填会写到错误位置。
 *
 * 第二轮用 count=20（2.5 块）做 mask 粒度实验：观察第 3 块是整块写、
 * 半块写还是不写，以实测确认 mask 在该模式下的粒度。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_FP32 = 64;
static constexpr uint32_t BLK_ELEM = 8;                     // 32 B / 4 B
static constexpr uint32_t STRIDE = 2;                       // 单位：32 B 块
static constexpr uint32_t OUT_LEN = VL_FP32 * STRIDE;        // 128
static constexpr uint32_t OUT2_LEN = VL_FP32;                // 第二轮连续区

__simd_vf__ inline void Scene6Vf(__ubuf__ float* xAddr, __ubuf__ float* yAddr,
                                 __ubuf__ float* y2Addr)
{
    uint32_t VL = AscendC::VECTOR_REG_WIDTH / sizeof(float);
    AscendC::Reg::RegTensor<float> vreg;
    AscendC::Reg::MaskReg maskAll, maskPart;
    uint32_t cntAll = VL, cntPart = 20;

    AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vreg, xAddr);              // 连续搬入 64 元素

    maskAll = AscendC::Reg::UpdateMask<float>(cntAll);
    AscendC::Reg::StoreAlign<float, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY>(
        yAddr, vreg, STRIDE, maskAll);                       // 8 块全写，块间跳 32 B

    maskPart = AscendC::Reg::UpdateMask<float>(cntPart);     // 20 lane = 2.5 块
    AscendC::Reg::StoreAlign<float, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY>(
        y2Addr, vreg, 1, maskPart);                          // stride=1：连续，验证 mask 粒度
}

__global__ __aicore__ __vector__ void Scene6Kernel(GM_ADDR x, GM_ADDR y, GM_ADDR y2)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, yBuf, y2Buf;
    pipe.InitBuffer(xBuf, VL_FP32 * sizeof(float));
    pipe.InitBuffer(yBuf, OUT_LEN * sizeof(float));
    pipe.InitBuffer(y2Buf, OUT2_LEN * sizeof(float));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<float> yUb = yBuf.Get<float>();
    AscendC::LocalTensor<float> y2Ub = y2Buf.Get<float>();

    AscendC::GlobalTensor<float> xGm, yGm, y2Gm;
    xGm.SetGlobalBuffer((__gm__ float*)x, VL_FP32);
    yGm.SetGlobalBuffer((__gm__ float*)y, OUT_LEN);
    y2Gm.SetGlobalBuffer((__gm__ float*)y2, OUT2_LEN);

    AscendC::DataCopy(xUb, xGm, VL_FP32);
    AscendC::DataCopy(yUb, yGm, OUT_LEN);
    AscendC::DataCopy(y2Ub, y2Gm, OUT2_LEN);
    AscendC::PipeBarrier<PIPE_ALL>();

    Scene6Vf((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ float*)yUb.GetPhyAddr(),
             (__ubuf__ float*)y2Ub.GetPhyAddr());
    AscendC::PipeBarrier<PIPE_ALL>();

    // 块 0 落 y[0..7]，块 1 落 y[16..23]，y[8..15] 保持预填值
    AscendC::PRINTF("[scene6] y[0]=%f y[7]=%f | y[8]=%f y[15]=%f (sentinel) | y[16]=%f y[23]=%f\n",
           yUb.GetValue(0), yUb.GetValue(7), yUb.GetValue(8), yUb.GetValue(15),
           yUb.GetValue(16), yUb.GetValue(23));
    // mask 粒度实验：block2 = y2[16..23]，20 lane 落在块中间
    AscendC::PRINTF("[scene6] mask20: y2[15]=%f | y2[16..19]=%f %f %f %f | y2[20..23]=%f %f %f %f\n",
           y2Ub.GetValue(15), y2Ub.GetValue(16), y2Ub.GetValue(17), y2Ub.GetValue(18),
           y2Ub.GetValue(19), y2Ub.GetValue(20), y2Ub.GetValue(21), y2Ub.GetValue(22),
           y2Ub.GetValue(23));

    AscendC::DataCopy(yGm, yUb, OUT_LEN);
    AscendC::DataCopy(y2Gm, y2Ub, OUT2_LEN);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t xB = VL_FP32 * sizeof(float), yB = OUT_LEN * sizeof(float), y2B = OUT2_LEN * sizeof(float);
    std::vector<float> hX(VL_FP32), hY(OUT_LEN, -1.f), hY2(OUT2_LEN, -1.f);
    for (uint32_t i = 0; i < VL_FP32; i++) hX[i] = float(i);

    uint8_t *dX, *dY, *dY2;
    CHECK_ACL(aclrtMalloc((void**)&dX, xB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, yB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY2, y2B, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, xB, hX.data(), xB, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, yB, hY.data(), yB, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY2, y2B, hY2.data(), y2B, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene6Kernel<<<1, nullptr, stream>>>(dX, dY, dY2);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), yB, dY, yB, ACL_MEMCPY_DEVICE_TO_HOST));
    CHECK_ACL(aclrtMemcpy(hY2.data(), y2B, dY2, y2B, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t k = 0; k < VL_FP32 / BLK_ELEM && ok; k++) {        // 块 k → y[k*16..+7]
        for (uint32_t j = 0; j < BLK_ELEM && ok; j++)
            ok = (hY[k * BLK_ELEM * STRIDE + j] == float(k * BLK_ELEM + j));
        for (uint32_t j = BLK_ELEM; j < BLK_ELEM * STRIDE && ok; j++)
            ok = (hY[k * BLK_ELEM * STRIDE + j] == -1.f);            // 跳过的块保持预填值
    }
    for (uint32_t i = 0; i < 16 && ok; i++) ok = (hY2[i] == float(i)); // 整块部分
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;
    std::cout << "mask20 block2: y2[16..23] = ";
    for (uint32_t i = 16; i < 24; i++) std::cout << hY2[i] << " ";
    std::cout << std::endl;

    aclrtFree(dX); aclrtFree(dY); aclrtFree(dY2);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
