/**
 * 场景 7：按索引取数（DIST_E2B_B32 + DataCopyGather）
 *
 * Gather 要求索引在寄存器中按 DataBlock 粒度排布，E2B 把紧排 uint32 索引
 * 展开成每索引一个 32 B 块。实测：单轮 E2B 仅覆盖前 8 个 b32 索引
 *（256 B / 32 B = 8 块），且块内 8 lane 重复同一索引值，Gather 后输出按块重复：
 * out[8k..8k+7] = data[idx[k]]。逐 lane 独立收集需以 8 索引为步长多轮处理。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_FP32 = 64;

__simd_vf__ inline void Scene7Vf(__ubuf__ uint32_t* idxAddr, __ubuf__ float* dataAddr,
                                 __ubuf__ float* outAddr)
{
    uint32_t VL = AscendC::VECTOR_REG_WIDTH / sizeof(uint32_t);
    AscendC::Reg::RegTensor<uint32_t> idxReg;
    AscendC::Reg::RegTensor<float> vregOut;
    AscendC::Reg::MaskReg preg;
    uint32_t count = VL;

    preg = AscendC::Reg::UpdateMask<uint32_t>(count);

    AscendC::Reg::LoadAlign<uint32_t, AscendC::Reg::LoadDist::DIST_E2B_B32>(
        idxReg, idxAddr);                                  // 紧排索引 → 每索引一块

    AscendC::Reg::Gather<float, float, uint32_t>(vregOut, dataAddr, idxReg, preg);   // 离散收集

    AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(outAddr, vregOut, preg); // 连续写出
}

__global__ __aicore__ __vector__ void Scene7Kernel(GM_ADDR idx, GM_ADDR data, GM_ADDR out)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> idxBuf, dataBuf, outBuf;
    pipe.InitBuffer(idxBuf, VL_FP32 * sizeof(uint32_t));
    pipe.InitBuffer(dataBuf, VL_FP32 * sizeof(float));
    pipe.InitBuffer(outBuf, VL_FP32 * sizeof(float));
    AscendC::LocalTensor<uint32_t> idxUb = idxBuf.Get<uint32_t>();
    AscendC::LocalTensor<float> dataUb = dataBuf.Get<float>();
    AscendC::LocalTensor<float> outUb = outBuf.Get<float>();

    AscendC::GlobalTensor<uint32_t> idxGm;
    AscendC::GlobalTensor<float> dataGm, outGm;
    idxGm.SetGlobalBuffer((__gm__ uint32_t*)idx, VL_FP32);
    dataGm.SetGlobalBuffer((__gm__ float*)data, VL_FP32);
    outGm.SetGlobalBuffer((__gm__ float*)out, VL_FP32);

    AscendC::DataCopy(idxUb, idxGm, VL_FP32);
    AscendC::DataCopy(dataUb, dataGm, VL_FP32);
    AscendC::DataCopy(outUb, outGm, VL_FP32);
    AscendC::PipeBarrier<PIPE_ALL>();

    Scene7Vf((__ubuf__ uint32_t*)idxUb.GetPhyAddr(), (__ubuf__ float*)dataUb.GetPhyAddr(),
             (__ubuf__ float*)outUb.GetPhyAddr());
    AscendC::PipeBarrier<PIPE_ALL>();

    // 单轮覆盖 idx[0..7]=63..56，块内复制：out[0..7]=63、out[8..15]=62 …
    AscendC::PRINTF("[scene7] idx[0..3]=%u %u %u %u  data[0..3]=%f %f %f %f\n",
           idxUb.GetValue(0), idxUb.GetValue(1), idxUb.GetValue(2), idxUb.GetValue(3),
           dataUb.GetValue(0), dataUb.GetValue(1), dataUb.GetValue(2), dataUb.GetValue(3));
    AscendC::PRINTF("[scene7] out[0..3]=%f %f %f %f | out[7]=%f out[8]=%f | out[63]=%f\n",
           outUb.GetValue(0), outUb.GetValue(1), outUb.GetValue(2), outUb.GetValue(3),
           outUb.GetValue(7), outUb.GetValue(8), outUb.GetValue(63));

    AscendC::DataCopy(outGm, outUb, VL_FP32);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t idxB = VL_FP32 * sizeof(uint32_t), dataB = VL_FP32 * sizeof(float);
    std::vector<uint32_t> hIdx(VL_FP32);
    std::vector<float> hData(VL_FP32), hOut(VL_FP32, -1.f);
    for (uint32_t i = 0; i < VL_FP32; i++) { hIdx[i] = VL_FP32 - 1 - i; hData[i] = float(i); }

    uint8_t *dIdx, *dData, *dOut;
    CHECK_ACL(aclrtMalloc((void**)&dIdx, idxB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dData, dataB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dOut, dataB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dIdx, idxB, hIdx.data(), idxB, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dData, dataB, hData.data(), dataB, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dOut, dataB, hOut.data(), dataB, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene7Kernel<<<1, nullptr, stream>>>(dIdx, dData, dOut);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hOut.data(), dataB, dOut, dataB, ACL_MEMCPY_DEVICE_TO_HOST));

    std::cout << "out[0..15] = ";
    for (uint32_t i = 0; i < 16; i++) std::cout << hOut[i] << " ";
    std::cout << "\nout[56..63] = ";
    for (uint32_t i = 56; i < VL_FP32; i++) std::cout << hOut[i] << " ";
    std::cout << std::endl;

    bool ok = true;   // 单轮 8 索引、块内复制：out[8k+j] = data[idx[k]]
    for (uint32_t k = 0; k < 8 && ok; k++)
        for (uint32_t j = 0; j < 8 && ok; j++)
            ok = (hOut[k * 8 + j] == float(VL_FP32 - 1 - k));
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dIdx); aclrtFree(dData); aclrtFree(dOut);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
