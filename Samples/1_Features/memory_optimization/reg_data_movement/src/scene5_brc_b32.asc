/**
 * 场景 5：标量广播（DIST_BRC_B32）
 *
 * 从 UB 读 1 个标量复制铺满 64 lane，整批一条向量指令完成运算。
 * biasAddr 循环内不变，每轮广播同一标量，不随 Repeat 推进。
 *
 * 输入 x[i] = i * 0.5，bias = 100，输出应为 y[i] = i * 0.5 + 100。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t N = 150;
static constexpr uint32_t N_PAD = 192;

__simd_vf__ inline void Scene5Vf(__ubuf__ float* xAddr, __ubuf__ float* biasAddr,
                                 __ubuf__ float* yAddr, uint32_t n, uint16_t loopNum)
{
    uint32_t VL = AscendC::VECTOR_REG_WIDTH / sizeof(float);
    AscendC::Reg::RegTensor<float> vregData, vregBias, vregOut;
    AscendC::Reg::MaskReg mask;
    uint32_t count = n;

    for (uint16_t i = 0; i < loopNum; i++) {
        mask = AscendC::Reg::UpdateMask<float>(count);

        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(
            vregData, xAddr + i * VL);

        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_BRC_B32>(
            vregBias, biasAddr);                          // 1 个标量 → 64 lane

        AscendC::Reg::Add(vregOut, vregData, vregBias, mask);

        AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(
            yAddr + i * VL, vregOut, mask);
    }
}

__global__ __aicore__ __vector__ void Scene5Kernel(GM_ADDR x, GM_ADDR bias, GM_ADDR y)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, bBuf, yBuf;
    pipe.InitBuffer(xBuf, N_PAD * sizeof(float));
    pipe.InitBuffer(bBuf, AscendC::VECTOR_REG_WIDTH);
    pipe.InitBuffer(yBuf, N_PAD * sizeof(float));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<float> bUb = bBuf.Get<float>();
    AscendC::LocalTensor<float> yUb = yBuf.Get<float>();

    AscendC::GlobalTensor<float> xGm, bGm, yGm;
    xGm.SetGlobalBuffer((__gm__ float*)x, N_PAD);
    bGm.SetGlobalBuffer((__gm__ float*)bias, AscendC::VECTOR_REG_WIDTH / sizeof(float));
    yGm.SetGlobalBuffer((__gm__ float*)y, N_PAD);

    AscendC::DataCopy(xUb, xGm, N_PAD);
    AscendC::DataCopy(bUb, bGm, AscendC::VECTOR_REG_WIDTH / sizeof(float));
    AscendC::DataCopy(yUb, yGm, N_PAD);
    AscendC::PipeBarrier<PIPE_ALL>();

    constexpr uint16_t loopNum = (N * sizeof(float) + AscendC::VECTOR_REG_WIDTH - 1) / AscendC::VECTOR_REG_WIDTH;
    Scene5Vf((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ float*)bUb.GetPhyAddr(),
             (__ubuf__ float*)yUb.GetPhyAddr(), N, loopNum);
    AscendC::PipeBarrier<PIPE_ALL>();

    // UB 中只有 bias[0]=100 有效，广播后整批加同一标量
    AscendC::PRINTF("[scene5] in : x[0..3]=%f %f %f %f  bias[0]=%f\n",
           xUb.GetValue(0), xUb.GetValue(1), xUb.GetValue(2), xUb.GetValue(3),
           bUb.GetValue(0));
    AscendC::PRINTF("[scene5] out: y[0..3]=%f %f %f %f\n",
           yUb.GetValue(0), yUb.GetValue(1), yUb.GetValue(2), yUb.GetValue(3));
    AscendC::PRINTF("[scene5] tail: y[149]=%f | y[150]=%f (sentinel -1)\n",
           yUb.GetValue(149), yUb.GetValue(150));

    AscendC::DataCopy(yGm, yUb, N_PAD);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    constexpr uint32_t VL_FP32 = 64;
    size_t bytes = N_PAD * sizeof(float), bBytes = VL_FP32 * sizeof(float);
    std::vector<float> hX(N_PAD, 0.f), hB(VL_FP32, 0.f), hY(N_PAD, -1.f);
    for (uint32_t i = 0; i < N; i++) hX[i] = i * 0.5f;
    hB[0] = 100.f;

    uint8_t *dX, *dB, *dY;
    CHECK_ACL(aclrtMalloc((void**)&dX, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dB, bBytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, bytes, hX.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dB, bBytes, hB.data(), bBytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, bytes, hY.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene5Kernel<<<1, nullptr, stream>>>(dX, dB, dY);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), bytes, dY, bytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t i = 0; i < N && ok; i++) ok = std::fabs(hY[i] - (i * 0.5f + 100.f)) <= 1e-3f;
    for (uint32_t i = N; i < N_PAD && ok; i++) ok = (hY[i] == -1.f);
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dB); aclrtFree(dY);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
