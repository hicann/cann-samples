/**
 * 场景 4：归约写出（DIST_FIRST_ELEMENT_B32）
 *
 * ReduceSum 把 64 lane 归约成一个标量放在第 0 lane，其余 lane 是无意义中间值；
 * FIRST_ELEMENT 只取首 lane 写到 output[i]。关键在输出偏移 yAddr+i 逐元素推进，
 * 写成 +i*VL 输出会变稀疏（每 64 个位置才一个有效值）。
 *
 * 输入按 VL 分组取常数：组 0 全 1、组 1 全 2、组 2 全 3，组和应为 64/128/192。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t GROUPS = 3;
static constexpr uint32_t VL_FP32 = 64;
static constexpr uint32_t N = GROUPS * VL_FP32;
static constexpr uint32_t OUT_PAD = VL_FP32;

__simd_vf__ inline void Scene4Vf(__ubuf__ float* xAddr, __ubuf__ float* yAddr,
                                 uint32_t n, uint16_t loopNum)
{
    uint32_t VL = AscendC::VECTOR_REG_WIDTH / sizeof(float);
    AscendC::Reg::RegTensor<float> vregIn, vregSum;
    AscendC::Reg::MaskReg maskVL, maskVL1;
    uint32_t count = n;
    maskVL1 = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::VL1>();

    for (uint16_t i = 0; i < loopNum; i++) {
        maskVL = AscendC::Reg::UpdateMask<float>(count);

        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vregIn, xAddr + i * VL_FP32);

        AscendC::Reg::ReduceSum(vregSum, vregIn, maskVL);         // 归约 → 首 lane

        AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_FIRST_ELEMENT_B32>(
            yAddr + i, vregSum, maskVL1);                          // 偏移 +i，逐元素推进
    }
}

__global__ __aicore__ __vector__ void Scene4Kernel(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, yBuf;
    pipe.InitBuffer(xBuf, N * sizeof(float));
    pipe.InitBuffer(yBuf, OUT_PAD * sizeof(float));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<float> yUb = yBuf.Get<float>();

    AscendC::GlobalTensor<float> xGm, yGm;
    xGm.SetGlobalBuffer((__gm__ float*)x, N);
    yGm.SetGlobalBuffer((__gm__ float*)y, OUT_PAD);

    AscendC::DataCopy(xUb, xGm, N);
    AscendC::DataCopy(yUb, yGm, OUT_PAD);
    AscendC::PipeBarrier<PIPE_ALL>();

    Scene4Vf((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ float*)yUb.GetPhyAddr(),
             N, GROUPS);
    AscendC::PipeBarrier<PIPE_ALL>();

    // 三个组和紧排在 y[0..2]，y[3] 起保持预填值——验证逐元素偏移没有稀疏化
    AscendC::PRINTF("[scene4] in : group0=%f group1=%f group2=%f (per-lane const)\n",
           xUb.GetValue(0), xUb.GetValue(VL_FP32), xUb.GetValue(2 * VL_FP32));
    AscendC::PRINTF("[scene4] out: y[0]=%f y[1]=%f y[2]=%f | y[3]=%f (sentinel -1)\n",
           yUb.GetValue(0), yUb.GetValue(1), yUb.GetValue(2), yUb.GetValue(3));

    AscendC::DataCopy(yGm, yUb, OUT_PAD);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t xBytes = N * sizeof(float), yBytes = OUT_PAD * sizeof(float);
    std::vector<float> hX(N), hY(OUT_PAD, -1.f);
    for (uint32_t i = 0; i < N; i++) hX[i] = float(i / VL_FP32 + 1);

    uint8_t *dX, *dY;
    CHECK_ACL(aclrtMalloc((void**)&dX, xBytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, yBytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, xBytes, hX.data(), xBytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, yBytes, hY.data(), yBytes, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene4Kernel<<<1, nullptr, stream>>>(dX, dY);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), yBytes, dY, yBytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t g = 0; g < GROUPS && ok; g++)
        ok = std::fabs(hY[g] - (g + 1) * float(VL_FP32)) <= 1e-3f;
    for (uint32_t i = GROUPS; i < OUT_PAD && ok; i++) ok = (hY[i] == -1.f);
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dY);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
