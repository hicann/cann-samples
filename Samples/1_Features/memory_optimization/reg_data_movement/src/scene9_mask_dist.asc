/**
 * 场景 9：掩码存取（MaskDist）
 *
 * 搬运 MaskReg 本身：比较得到逐 lane 布尔结果，StoreAlign 存入 UB（位流），
 * LoadAlign 读回 MaskReg，MaskAnd 组合后接 Select。mask 在 UB 中是紧凑位流，
 * 类型参数按整型（惯用 int32_t）访问，按 float 解释无意义。
 * 存读参数顺序相反，记法：目标在前、源在后。
 *
 * 实测位流布局：MaskReg 固定 256 bit（每个 b8 lane 1 bit），b32 数据有效位
 * 每 4 bit 取 1。x[i]=i，cmpMask = (x>=32)，evenMask 由 host 按位流写好，
 * 两者 MaskAnd 后选择：i>=32 且 i 为偶数的 lane 输出 x[i]，其余置 0。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_FP32 = 64;
static constexpr uint32_t MASK_WORDS = 8;                 // mask 区按 8×int32 分配

__simd_vf__ inline void Scene9Vf(__ubuf__ float* xAddr, __ubuf__ int32_t* maskAddr,
                                 __ubuf__ int32_t* evenMaskAddr, __ubuf__ float* yAddr)
{
    AscendC::Reg::RegTensor<float> vregData, vregZeros;
    AscendC::Reg::MaskReg pregAll, cmpMask, evenMask;
    uint32_t count = VL_FP32;
    pregAll = AscendC::Reg::UpdateMask<float>(count);

    AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vregData, xAddr);
    AscendC::Reg::Duplicate(vregZeros, 0.f, pregAll);

    AscendC::Reg::Compares<float, AscendC::CMPMODE::GE>(cmpMask, vregData, 32.f, pregAll);

    // MaskReg → UB：UB 地址在前（位流存储）
    AscendC::Reg::StoreAlign<int32_t, AscendC::Reg::MaskDist::DIST_NORM>(maskAddr, cmpMask);
    // 同地址存→读必须显式插存读屏障，否则读回结果不定（实测概率性全 0）
    AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_STORE, AscendC::Reg::MemType::VEC_LOAD>();
    // UB → MaskReg：MaskReg 在前（读回暂存的 mask 与 host 预置的偶 lane mask）
    AscendC::Reg::LoadAlign<int32_t, AscendC::Reg::MaskDist::DIST_NORM>(cmpMask, maskAddr);
    AscendC::Reg::LoadAlign<int32_t, AscendC::Reg::MaskDist::DIST_NORM>(evenMask, evenMaskAddr);

    AscendC::Reg::MaskAnd(cmpMask, cmpMask, evenMask, pregAll);
    AscendC::Reg::Select(vregData, vregData, vregZeros, cmpMask);   // mask 内取 x，外取 0

    AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(yAddr, vregData, pregAll);
}

__global__ __aicore__ __vector__ void Scene9Kernel(GM_ADDR x, GM_ADDR evenMask,
                                                   GM_ADDR maskOut, GM_ADDR y)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, emBuf, mBuf, yBuf;
    pipe.InitBuffer(xBuf, VL_FP32 * sizeof(float));
    pipe.InitBuffer(emBuf, MASK_WORDS * sizeof(int32_t));
    pipe.InitBuffer(mBuf, MASK_WORDS * sizeof(int32_t));
    pipe.InitBuffer(yBuf, VL_FP32 * sizeof(float));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<int32_t> emUb = emBuf.Get<int32_t>();
    AscendC::LocalTensor<int32_t> mUb = mBuf.Get<int32_t>();
    AscendC::LocalTensor<float> yUb = yBuf.Get<float>();

    AscendC::GlobalTensor<float> xGm, yGm;
    AscendC::GlobalTensor<int32_t> emGm, mGm;
    xGm.SetGlobalBuffer((__gm__ float*)x, VL_FP32);
    emGm.SetGlobalBuffer((__gm__ int32_t*)evenMask, MASK_WORDS);
    mGm.SetGlobalBuffer((__gm__ int32_t*)maskOut, MASK_WORDS);
    yGm.SetGlobalBuffer((__gm__ float*)y, VL_FP32);

    AscendC::DataCopy(xUb, xGm, VL_FP32);
    AscendC::DataCopy(emUb, emGm, MASK_WORDS);
    AscendC::PipeBarrier<PIPE_ALL>();

    Scene9Vf((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ int32_t*)mUb.GetPhyAddr(),
             (__ubuf__ int32_t*)emUb.GetPhyAddr(), (__ubuf__ float*)yUb.GetPhyAddr());
    AscendC::PipeBarrier<PIPE_ALL>();

    // 位流：b32 lane 每 4 bit 占 1 位，lanes 32..63 → w4..w7=0x11111111
    AscendC::PRINTF("[scene9] mask in UB: w0=0x%x w1=0x%x w2=0x%x w3=0x%x w4=0x%x w5=0x%x w6=0x%x w7=0x%x\n",
           (uint32_t)mUb.GetValue(0), (uint32_t)mUb.GetValue(1),
           (uint32_t)mUb.GetValue(2), (uint32_t)mUb.GetValue(3),
           (uint32_t)mUb.GetValue(4), (uint32_t)mUb.GetValue(5),
           (uint32_t)mUb.GetValue(6), (uint32_t)mUb.GetValue(7));
    AscendC::PRINTF("[scene9] out: y[30..35]=%f %f %f %f %f %f\n",
           yUb.GetValue(30), yUb.GetValue(31), yUb.GetValue(32),
           yUb.GetValue(33), yUb.GetValue(34), yUb.GetValue(35));

    AscendC::DataCopy(yGm, yUb, VL_FP32);
    AscendC::DataCopy(mGm, mUb, MASK_WORDS);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t xB = VL_FP32 * sizeof(float), mB = MASK_WORDS * sizeof(int32_t);
    std::vector<float> hX(VL_FP32), hY(VL_FP32, -1.f);
    std::vector<int32_t> hEven(MASK_WORDS, 0), hMask(MASK_WORDS, 0);
    for (uint32_t i = 0; i < VL_FP32; i++) hX[i] = float(i);
    // MaskReg 落 UB 为 256 bit 位流（每个 b8 lane 1 bit），b32 数据每 4 bit 取 1：
    // 偶数 b32 lane 对应 bit 8k，即每个字 0x01010101
    for (auto& w : hEven) w = 0x01010101;

    uint8_t *dX, *dEven, *dMask, *dY;
    CHECK_ACL(aclrtMalloc((void**)&dX, xB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dEven, mB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dMask, mB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, xB, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, xB, hX.data(), xB, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dEven, mB, hEven.data(), mB, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, xB, hY.data(), xB, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene9Kernel<<<1, nullptr, stream>>>(dX, dEven, dMask, dY);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), xB, dY, xB, ACL_MEMCPY_DEVICE_TO_HOST));
    CHECK_ACL(aclrtMemcpy(hMask.data(), mB, dMask, mB, ACL_MEMCPY_DEVICE_TO_HOST));

    // x>=32 → b32 lanes 32..63 → 位流字 4..7 = 0x11111111
    bool ok = true;
    for (int w = 0; w < 4 && ok; w++) ok = ((uint32_t)hMask[w] == 0u);
    for (int w = 4; w < 8 && ok; w++) ok = ((uint32_t)hMask[w] == 0x11111111u);
    for (uint32_t i = 0; i < VL_FP32 && ok; i++) {
        float exp = (i >= 32 && i % 2 == 0) ? float(i) : 0.f;
        ok = (hY[i] == exp);
    }
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dEven); aclrtFree(dMask); aclrtFree(dY);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
