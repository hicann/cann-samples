/**
 * 场景 3：单向降位落盘（DIST_PACK_B32 单独使用）
 *
 * 量化类场景：全程 fp32 计算，仅在写出时降为 half，PACK 取每个 32 位槽
 * 低 16 位紧排落盘，输出 buffer 长度为输入一半字节数。无 UNPACK 往返。
 *
 * 输入 x[i] = i * 0.5（fp32），计算 ×0.5，输出 y[i] = i * 0.25（half）。
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#define CHECK_ACL(call)                                                        \
    do {                                                                       \
        aclError err = (call);                                                 \
        if (err != ACL_SUCCESS) {                                              \
            std::cerr << "ACL error " << err << " at " << __LINE__ << "\n";    \
            return 1;                                                          \
        }                                                                      \
    } while (0)

static constexpr uint32_t VL_B32 = 256 / sizeof(float);
static constexpr uint32_t N = 150;
static constexpr uint32_t N_PAD = 192;

#ifdef __NPU_ARCH__
static constexpr AscendC::Reg::CastTrait CAST_B32_TO_B16 = {
    AscendC::Reg::RegLayout::ZERO, AscendC::Reg::SatMode::NO_SAT,
    AscendC::Reg::MaskMergeMode::ZEROING, AscendC::RoundMode::CAST_RINT};
#endif

__simd_vf__ inline void Scene3Vf(__ubuf__ float* xAddr, __ubuf__ half* yAddr,
                                 uint32_t n, uint16_t loopNum)
{
    AscendC::Reg::RegTensor<float> vregIn, vregHalfScaled;
    AscendC::Reg::RegTensor<half> vreg16;
    AscendC::Reg::MaskReg mask;
    uint32_t count = n;

    for (uint16_t i = 0; i < loopNum; i++) {
        mask = AscendC::Reg::UpdateMask<float>(count);

        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(
            vregIn, xAddr + i * VL_B32);                              // fp32 原样搬入

        AscendC::Reg::Muls(vregHalfScaled, vregIn, 0.5f, mask);
        AscendC::Reg::Cast<half, float, CAST_B32_TO_B16>(vreg16, vregHalfScaled, mask);

        AscendC::Reg::StoreAlign<half, AscendC::Reg::StoreDist::DIST_PACK_B32>(
            yAddr + i * VL_B32, vreg16, mask);                            // 仅落盘时降位
    }
}

__global__ __aicore__ __vector__ void Scene3Kernel(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xBuf, yBuf;
    pipe.InitBuffer(xBuf, N_PAD * sizeof(float));
    pipe.InitBuffer(yBuf, N_PAD * sizeof(half));
    AscendC::LocalTensor<float> xUb = xBuf.Get<float>();
    AscendC::LocalTensor<half> yUb = yBuf.Get<half>();

    AscendC::GlobalTensor<float> xGm;
    AscendC::GlobalTensor<half> yGm;
    xGm.SetGlobalBuffer((__gm__ float*)x, N_PAD);
    yGm.SetGlobalBuffer((__gm__ half*)y, N_PAD);

    AscendC::DataCopy(xUb, xGm, N_PAD);
    AscendC::DataCopy(yUb, yGm, N_PAD);
    AscendC::PipeBarrier<PIPE_ALL>();

    constexpr uint16_t loopNum = (N + VL_B32 - 1) / VL_B32;
    Scene3Vf((__ubuf__ float*)xUb.GetPhyAddr(), (__ubuf__ half*)yUb.GetPhyAddr(),
             N, loopNum);
    AscendC::PipeBarrier<PIPE_ALL>();

    // 输入 fp32 4 字节/元素，输出 half 2 字节/元素紧排，y[i] = x[i] * 0.5
    AscendC::PRINTF("[scene3] in : x[0..3]=%f %f %f %f (fp32, 4B/elem)\n",
           xUb.GetValue(0), xUb.GetValue(1), xUb.GetValue(2), xUb.GetValue(3));
    AscendC::PRINTF("[scene3] out: y[0..3]=%f %f %f %f (half, 2B/elem)\n",
           (float)yUb.GetValue(0), (float)yUb.GetValue(1),
           (float)yUb.GetValue(2), (float)yUb.GetValue(3));
    AscendC::PRINTF("[scene3] tail: y[149]=%f | y[150]=%f (sentinel -1)\n",
           (float)yUb.GetValue(149), (float)yUb.GetValue(150));

    AscendC::DataCopy(yGm, yUb, N_PAD);
}

int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t xBytes = N_PAD * sizeof(float), yBytes = N_PAD * sizeof(aclFloat16);
    std::vector<float> hX(N_PAD, 0.f);
    std::vector<aclFloat16> hY(N_PAD, aclFloatToFloat16(-1.f));
    for (uint32_t i = 0; i < N; i++) hX[i] = i * 0.5f;

    uint8_t *dX, *dY;
    CHECK_ACL(aclrtMalloc((void**)&dX, xBytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, yBytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, xBytes, hX.data(), xBytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, yBytes, hY.data(), yBytes, ACL_MEMCPY_HOST_TO_DEVICE));

    Scene3Kernel<<<1, nullptr, stream>>>(dX, dY);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hY.data(), yBytes, dY, yBytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = true;
    for (uint32_t i = 0; i < N && ok; i++)
        ok = std::fabs(aclFloat16ToFloat(hY[i]) - i * 0.25f) <= i * 0.25f * 1e-3f + 1e-3f;
    for (uint32_t i = N; i < N_PAD && ok; i++) ok = (aclFloat16ToFloat(hY[i]) == -1.f);
    std::cout << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dY);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
