__simd_vf__ inline void ManyFloatArgs008VF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float p000, float p001, float p002, float p003,
    float p004, float p005, float p006, float p007,
    uint32_t elemNum, uint16_t vfLoopNum)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(float);
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; i++) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign<float>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<float>(xReg, xReg, p000, mask);
        AscendC::Reg::Adds<float>(xReg, xReg, p001, mask);
        AscendC::Reg::Adds<float>(xReg, xReg, p002, mask);
        AscendC::Reg::Adds<float>(xReg, xReg, p003, mask);
        AscendC::Reg::Adds<float>(xReg, xReg, p004, mask);
        AscendC::Reg::Adds<float>(xReg, xReg, p005, mask);
        AscendC::Reg::Adds<float>(xReg, xReg, p006, mask);
        AscendC::Reg::Adds<float>(xReg, xReg, p007, mask);
        AscendC::Reg::StoreAlign<float>(yUbAddr + i * VL_T, xReg, mask);
    }
}

