enum class ArgCase : uint32_t {
    FloatArgs008,
    FloatArgs032,
    FloatArgs064,
    FloatArgs128,
    FloatArgs256,
};

static float ExpectedSum(uint32_t argCount, float base)
{
    return static_cast<float>(argCount) * base + static_cast<float>(argCount * (argCount + 1) / 2);
}

void RunManyArgCase(ArgCase argCase, aclrtStream stream)
{
    constexpr int N = 123;
    constexpr size_t size = N * sizeof(float);
    assert(2 * CeilAlign<uint32_t>(size, UBBLOCKSIZE) <= AVAIL_UBSIZE);

    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, 0.0f);
    FillIndex(x);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);

    constexpr float base = 0.0f;
    const char* name = "";
    uint32_t argCount = 0;
    switch (argCase) {
        case ArgCase::FloatArgs008:
            name = "ManyFloatArgs008VF";
            argCount = 8;
            many_float_args_008_kernel<<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N, base);
            break;
        case ArgCase::FloatArgs032:
            name = "ManyFloatArgs032VF";
            argCount = 32;
            many_float_args_032_kernel<<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N, base);
            break;
        case ArgCase::FloatArgs064:
            name = "ManyFloatArgs064VF";
            argCount = 64;
            many_float_args_064_kernel<<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N, base);
            break;
        case ArgCase::FloatArgs128:
            name = "ManyFloatArgs128VF";
            argCount = 128;
            many_float_args_128_kernel<<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N, base);
            break;
        case ArgCase::FloatArgs256:
            name = "ManyFloatArgs256VF";
            argCount = 256;
            many_float_args_256_kernel<<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N, base);
            break;
    }
    aclrtSynchronizeStream(stream);

    yDev.CopyToHost(y);
    float expected = ExpectedSum(argCount, base);
    auto expectedFn = [&](int idx) -> float { return x[idx] + expected; };
    std::vector<int> samples = {0, 1, N - 1};
    int failed = CountSampleMismatches(y, samples, expectedFn);
    PrintCaseResult(name, failed == 0 ? "OK" : "MISMATCH", N, y, expectedFn, samples, failed);
    assert(failed == 0);
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();

    RunManyArgCase(ArgCase::FloatArgs008, stream);
    RunManyArgCase(ArgCase::FloatArgs032, stream);
    RunManyArgCase(ArgCase::FloatArgs064, stream);
    RunManyArgCase(ArgCase::FloatArgs128, stream);
    RunManyArgCase(ArgCase::FloatArgs256, stream);

    return 0;
}
