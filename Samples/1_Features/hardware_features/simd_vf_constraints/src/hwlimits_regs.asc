#include "acl/acl.h"
#include "host_test_utils.h"
#include "kernel_operator.h"
#include "kernel_utils.h"

#include <cassert>
#include <cmath>
#include <cstdio>
#include <vector>

enum class RegCase : uint32_t {
    UNALIGN_LOAD_4 = 0,
};

__simd_vf__ inline void UnalignLoad4VF(__ubuf__ float* src0, __ubuf__ float* src1, __ubuf__ float* src2,
    __ubuf__ float* src3, __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> r0, r1, r2, r3, out;
    AscendC::Reg::UnalignRegForLoad u0, u1, u2, u3;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        __ubuf__ float* p0 = src0 + i * VL_B32;
        __ubuf__ float* p1 = src1 + i * VL_B32;
        __ubuf__ float* p2 = src2 + i * VL_B32;
        __ubuf__ float* p3 = src3 + i * VL_B32;
        AscendC::Reg::LoadUnAlignPre(u0, p0);
        AscendC::Reg::LoadUnAlignPre(u1, p1);
        AscendC::Reg::LoadUnAlignPre(u2, p2);
        AscendC::Reg::LoadUnAlignPre(u3, p3);
        AscendC::Reg::LoadUnAlign<float>(r0, u0, p0);
        AscendC::Reg::LoadUnAlign<float>(r1, u1, p1);
        AscendC::Reg::LoadUnAlign<float>(r2, u2, p2);
        AscendC::Reg::LoadUnAlign<float>(r3, u3, p3);
        AscendC::Reg::Add(out, r0, r1, mask);
        AscendC::Reg::Add(out, out, r2, mask);
        AscendC::Reg::Add(out, out, r3, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, out, mask);
    }
}

//! 不允许：Load 侧同时使用 5 个 UnalignReg 会导致后端寄存器分配失败。
/*
__simd_vf__ inline void UnalignLoad5VF(__ubuf__ float* src0, __ubuf__ float* src1, __ubuf__ float* src2,
    __ubuf__ float* src3, __ubuf__ float* src4, __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> r0, r1, r2, r3, r4, out;
    AscendC::Reg::UnalignRegForLoad u0, u1, u2, u3, u4;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadUnAlignPre(u0, src0 + i * VL_B32);
        AscendC::Reg::LoadUnAlignPre(u1, src1 + i * VL_B32);
        AscendC::Reg::LoadUnAlignPre(u2, src2 + i * VL_B32);
        AscendC::Reg::LoadUnAlignPre(u3, src3 + i * VL_B32);
        AscendC::Reg::LoadUnAlignPre(u4, src4 + i * VL_B32);
        AscendC::Reg::LoadUnAlign<float>(r0, u0, src0 + i * VL_B32);
        AscendC::Reg::LoadUnAlign<float>(r1, u1, src1 + i * VL_B32);
        AscendC::Reg::LoadUnAlign<float>(r2, u2, src2 + i * VL_B32);
        AscendC::Reg::LoadUnAlign<float>(r3, u3, src3 + i * VL_B32);
        AscendC::Reg::LoadUnAlign<float>(r4, u4, src4 + i * VL_B32);
        AscendC::Reg::Add(out, r0, r1, mask);
        AscendC::Reg::Add(out, out, r2, mask);
        AscendC::Reg::Add(out, out, r3, mask);
        AscendC::Reg::Add(out, out, r4, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, out, mask);
    }
}
*/

//! 不允许：Store 侧同时使用 5 个 UnalignReg 会导致后端寄存器分配失败。
/*
__simd_vf__ inline void UnalignStore5VF(__ubuf__ float* xUbAddr, __ubuf__ float* dst0, __ubuf__ float* dst1,
    __ubuf__ float* dst2, __ubuf__ float* dst3, __ubuf__ float* dst4, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> r0, r1, r2, r3, r4;
    AscendC::Reg::UnalignRegForStore u0, u1, u2, u3, u4;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(r0, xUbAddr + i * VL_B32);
        AscendC::Reg::Adds(r1, r0, 1000.0f, mask);
        AscendC::Reg::Adds(r2, r0, 2000.0f, mask);
        AscendC::Reg::Adds(r3, r0, 3000.0f, mask);
        AscendC::Reg::Adds(r4, r0, 4000.0f, mask);
        AscendC::Reg::StoreUnAlign<float, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dst0 + i * VL_B32, r0, u0, VL_B32);
        AscendC::Reg::StoreUnAlign<float, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dst1 + i * VL_B32, r1, u1, VL_B32);
        AscendC::Reg::StoreUnAlign<float, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dst2 + i * VL_B32, r2, u2, VL_B32);
        AscendC::Reg::StoreUnAlign<float, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dst3 + i * VL_B32, r3, u3, VL_B32);
        AscendC::Reg::StoreUnAlign<float, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dst4 + i * VL_B32, r4, u4, VL_B32);
    }
}
*/


template <RegCase CaseId>
__global__ __vector__ void regs_kernel(__gm__ float* x, __gm__ float* y, int N)
{
    AscendC::GlobalTensor<float> xGlobal;
    AscendC::GlobalTensor<float> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;

    uint32_t ubBytes = CeilAlign<uint32_t>(N * sizeof(float), UBBLOCKSIZE);
    pipe.InitBuffer(xInQueue, 1, ubBytes);
    pipe.InitBuffer(yOutQueue, 1, ubBytes);

    AscendC::LocalTensor<float> xLocal = xInQueue.AllocTensor<float>();
    ElemwiseCopyIn<float>(xLocal, xGlobal, N);
    xInQueue.EnQue<float>(xLocal);
    xLocal = xInQueue.DeQue<float>();
    AscendC::LocalTensor<float> yLocal = yOutQueue.AllocTensor<float>();

    auto* xUbAddr = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());
    uint32_t elemNum = static_cast<uint32_t>(VL_B32);
    uint16_t vfLoopNum = 1;

    if constexpr (CaseId == RegCase::UNALIGN_LOAD_4) {
        asc_vf_call<UnalignLoad4VF>(xUbAddr + 1, xUbAddr + 65, xUbAddr + 129, xUbAddr + 193,
            yUbAddr, elemNum, vfLoopNum);
    }

    yOutQueue.EnQue<float>(yLocal);
    xInQueue.FreeTensor<float>(xLocal);
    yLocal = yOutQueue.DeQue<float>();
    ElemwiseCopyOut<float>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<float>(yLocal);
    pipe.Destroy();
}

template <RegCase CaseId>
void RunRegCase(const char* caseName, int N, aclrtStream stream)
{
    size_t size = static_cast<size_t>(N) * sizeof(float);
    assert(2 * CeilAlign<uint32_t>(size, UBBLOCKSIZE) <= AVAIL_UBSIZE);
    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, 0.0f);
    FillIndex(x);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);
    yDev.CopyFromHost(y);

    regs_kernel<CaseId><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N);
    aclrtSynchronizeStream(stream);
    yDev.CopyToHost(y);

    auto expected = [](int idx) -> float { return static_cast<float>((idx + 1) + (idx + 65) + (idx + 129) + (idx + 193)); };
    std::vector<int> samples = {0, 1, 5};
    int failed = CountSampleMismatches(y, samples, expected);
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();

    constexpr int N = static_cast<int>(VL_B32 * 9);
    RunRegCase<RegCase::UNALIGN_LOAD_4>("UNALIGN_LOAD_4", N, stream);

    return 0;
}
