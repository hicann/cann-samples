enum class HardwareLoopCase : uint32_t {
    GOOD_STANDARD = 0,
    GOOD_IF_CONSTEXPR = 2,
    GOOD_COMPARE_SELECT = 4,
    GOOD_NESTED4_IMMEDIATE = 5,
    TAIL_UPDATE_MASK = 8,
    TAIL_FOR_ONE = 9,
    BAD_U32_ITER = 10,
    BAD_NONZERO_START = 11,
    BAD_STEP_TWO = 12,
    BAD_RUNTIME_IF = 13,
    BAD_TERNARY = 14,
    BAD_CONTINUE = 15,
    BAD_LOOP_INDEX_DATA_IF = 16,
    TAIL_RUNTIME_IF = 17,
    EXTREME_IF_LOOP_INDEX = 20,
    EXTREME_BREAK = 21,
    EXTREME_WHILE = 22,
    EXTREME_MUTABLE_BOUND = 23,
    NESTED5_RUNTIME_IMMEDIATE = 26,
    EXTREME_MUTABLE_STEP = 28,
    BAD_RUNTIME_START = 29,
    BAD_RUNTIME_STRIDE = 30,
};

__host_aicore__ inline uint32_t GetLoopCount(uint32_t elemNum)
{
    return CeilDiv<uint32_t>(elemNum, VL_B32);
}

#define HWLOOP_FIVE_COMPUTE(dstReg, srcReg, scalarValue, maskValue) \
    do { \
        AscendC::Reg::Adds(dstReg, srcReg, scalarValue, maskValue); \
        AscendC::Reg::Muls(dstReg, dstReg, 2.0f, maskValue); \
        AscendC::Reg::Adds(dstReg, dstReg, 1.0f, maskValue); \
        AscendC::Reg::Mul(dstReg, dstReg, srcReg, maskValue); \
        AscendC::Reg::Adds(dstReg, dstReg, scalarValue, maskValue); \
    } while (0)

__simd_vf__ inline void GoodStandardVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}


template <uint16_t LoopA, uint16_t LoopB, uint16_t LoopC, uint16_t LoopD>
__simd_vf__ inline void GoodNested4ImmediateVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t a = 0; a < LoopA; ++a) {
        for (uint16_t b = 0; b < LoopB; ++b) {
            for (uint16_t c = 0; c < LoopC; ++c) {
                for (uint16_t d = 0; d < LoopD; ++d) {
                    uint16_t loopIdx = (((a * LoopB + b) * LoopC + c) * LoopD + d);
                    mask = AscendC::Reg::UpdateMask<float>(elemNum);
                    AscendC::Reg::LoadAlign(xReg, xUbAddr + loopIdx * VL_B32);
                    HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
                    AscendC::Reg::StoreAlign(yUbAddr + loopIdx * VL_B32, yReg, mask);
                }
            }
        }
    }
}






__simd_vf__ inline void Nested5RuntimeImmediateVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t loopA, uint16_t loopB, uint16_t loopC, uint16_t loopD, uint16_t loopE)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t a = 0; a < loopA; ++a) {
        for (uint16_t b = 0; b < loopB; ++b) {
            for (uint16_t c = 0; c < loopC; ++c) {
                for (uint16_t d = 0; d < loopD; ++d) {
                    for (uint16_t e = 0; e < loopE; ++e) {
                        uint16_t loopIdx = ((((a * loopB + b) * loopC + c) * loopD + d) * loopE + e);
                        mask = AscendC::Reg::UpdateMask<float>(elemNum);
                        AscendC::Reg::LoadAlign(xReg, xUbAddr + loopIdx * VL_B32);
                        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
                        AscendC::Reg::StoreAlign(yUbAddr + loopIdx * VL_B32, yReg, mask);
                    }
                }
            }
        }
    }
}

template <bool AddExtra>
__simd_vf__ inline void GoodIfConstexprVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        if constexpr (AddExtra) {
            AscendC::Reg::Adds(yReg, yReg, 1.0f, mask);
        }
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}


__simd_vf__ inline void GoodCompareSelectVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum, float threshold)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> normalReg;
    AscendC::Reg::RegTensor<float> defaultReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    AscendC::Reg::MaskReg selectMask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::Duplicate(defaultReg, -1.0f);
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(normalReg, xReg, scalar, mask);
        AscendC::Reg::Compares<float, AscendC::CMPMODE::NE>(selectMask, xReg, threshold, mask);
        AscendC::Reg::Select(yReg, normalReg, defaultReg, selectMask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void TailUpdateMaskVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void TailForOneVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t fullLoopNum, uint16_t hasTail, uint32_t tailCount)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < fullLoopNum; ++i) {
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }

    for (uint16_t i = 0; i < hasTail; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(tailCount);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + fullLoopNum * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + fullLoopNum * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void TailRuntimeIfVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t fullLoopNum, uint16_t hasTail, uint32_t tailCount)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < fullLoopNum; ++i) {
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }

    if (hasTail != 0) {
        mask = AscendC::Reg::UpdateMask<float>(tailCount);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + fullLoopNum * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + fullLoopNum * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadU32IterVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint32_t i = 0; i < static_cast<uint32_t>(vfLoopNum); ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadNonzeroStartVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 1; i <= vfLoopNum; ++i) {
        uint16_t loopIdx = i - 1;
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + loopIdx * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + loopIdx * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadStepTwoVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum * 2; i += 2) {
        uint16_t loopIdx = i >> 1;
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + loopIdx * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + loopIdx * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadRuntimeStartVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum, uint16_t start)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = start; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadRuntimeStrideVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum, uint16_t stride)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; i += stride) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadRuntimeIfVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        if (scalar >= 0.0f) {
            HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        } else {
            HWLOOP_FIVE_COMPUTE(yReg, xReg, -scalar, mask);
        }
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadTernaryVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        float delta = scalar >= 0.0f ? scalar : -scalar;
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, delta, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadContinueVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        if ((i & 1) == 1) {
            AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
            continue;
        }
        AscendC::Reg::Adds(yReg, yReg, 1.0f, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void BadLoopIndexDataIfVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum, uint16_t specialLoop)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        if (i == specialLoop) {
            AscendC::Reg::Duplicate(yReg, -1.0f);
        } else {
            HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        }
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

__simd_vf__ inline void ExtremeIfLoopIndexVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        if ((i & 1) == 0) {
            AscendC::Reg::Adds(yReg, yReg, 1.0f, mask);
        }
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

