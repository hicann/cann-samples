template <HardwareLoopCase CaseId>
__global__ __vector__ void hwloop_kernel(__gm__ float* x, __gm__ float* y, float scalar, int N)
{
    AscendC::GlobalTensor<float> xGlobal;
    AscendC::GlobalTensor<float> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;
    pipe.InitBuffer(xInQueue, 1, CeilAlign<uint32_t>(N * sizeof(float), UBBLOCKSIZE));
    pipe.InitBuffer(yOutQueue, 1, CeilAlign<uint32_t>(N * sizeof(float), UBBLOCKSIZE));

    AscendC::LocalTensor<float> xLocal = xInQueue.AllocTensor<float>();
    ElemwiseCopyIn<float>(xLocal, xGlobal, N);
    xInQueue.EnQue<float>(xLocal);

    xLocal = xInQueue.DeQue<float>();
    AscendC::LocalTensor<float> yLocal = yOutQueue.AllocTensor<float>();

    uint32_t elemNum = static_cast<uint32_t>(N);
    uint16_t vfLoopNum = static_cast<uint16_t>(GetLoopCount(elemNum));
    uint16_t fullLoopNum = static_cast<uint16_t>(elemNum / VL_B32);
    uint32_t tailCount = elemNum % VL_B32;
    uint16_t hasTail = static_cast<uint16_t>(tailCount != 0);
    auto* xUbAddr = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());

    if constexpr (CaseId == HardwareLoopCase::GOOD_STANDARD) {
        asc_vf_call<GoodStandardVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::GOOD_IF_CONSTEXPR) {
        asc_vf_call<GoodIfConstexprVF<true>>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::GOOD_COMPARE_SELECT) {
        asc_vf_call<GoodCompareSelectVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum, 5.0f);
    } else if constexpr (CaseId == HardwareLoopCase::GOOD_NESTED4_IMMEDIATE) {
        asc_vf_call<GoodNested4ImmediateVF<2, 2, 2, 2>>(xUbAddr, yUbAddr, scalar, elemNum);
    } else if constexpr (CaseId == HardwareLoopCase::TAIL_UPDATE_MASK) {
        asc_vf_call<TailUpdateMaskVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::TAIL_FOR_ONE) {
        asc_vf_call<TailForOneVF>(xUbAddr, yUbAddr, scalar, elemNum, fullLoopNum, hasTail, tailCount);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_U32_ITER) {
        asc_vf_call<BadU32IterVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_NONZERO_START) {
        asc_vf_call<BadNonzeroStartVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_STEP_TWO) {
        asc_vf_call<BadStepTwoVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_RUNTIME_START) {
        uint16_t runtimeStart = static_cast<uint16_t>(vfLoopNum - vfLoopNum);
        asc_vf_call<BadRuntimeStartVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum, runtimeStart);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_RUNTIME_STRIDE) {
        uint16_t runtimeStride = static_cast<uint16_t>(vfLoopNum / vfLoopNum);
        asc_vf_call<BadRuntimeStrideVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum, runtimeStride);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_RUNTIME_IF) {
        asc_vf_call<BadRuntimeIfVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_TERNARY) {
        asc_vf_call<BadTernaryVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_CONTINUE) {
        asc_vf_call<BadContinueVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_LOOP_INDEX_DATA_IF) {
        asc_vf_call<BadLoopIndexDataIfVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum, static_cast<uint16_t>(5));
    } else if constexpr (CaseId == HardwareLoopCase::TAIL_RUNTIME_IF) {
        asc_vf_call<TailRuntimeIfVF>(xUbAddr, yUbAddr, scalar, elemNum, fullLoopNum, hasTail, tailCount);
    } else if constexpr (CaseId == HardwareLoopCase::EXTREME_IF_LOOP_INDEX) {
        asc_vf_call<ExtremeIfLoopIndexVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    //! 不允许示例保留为注释，不参与正常执行
    // } else if constexpr (CaseId == HardwareLoopCase::EXTREME_BREAK) {
    //     asc_vf_call<ExtremeBreakVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == HardwareLoopCase::EXTREME_WHILE) {
        asc_vf_call<ExtremeWhileVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    //! 不允许示例保留为注释，不参与正常执行
    // } else if constexpr (CaseId == HardwareLoopCase::EXTREME_MUTABLE_BOUND) {
    //     asc_vf_call<ExtremeMutableBoundVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    // } else if constexpr (CaseId == HardwareLoopCase::EXTREME_MUTABLE_STEP) {
    //     asc_vf_call<ExtremeMutableStepVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum, static_cast<uint16_t>(1));
    } else if constexpr (CaseId == HardwareLoopCase::NESTED5_RUNTIME_IMMEDIATE) {
        asc_vf_call<Nested5RuntimeImmediateVF>(xUbAddr, yUbAddr, scalar, elemNum,
            static_cast<uint16_t>(2), static_cast<uint16_t>(2), static_cast<uint16_t>(2), static_cast<uint16_t>(2),
            static_cast<uint16_t>(2));
    }

    yOutQueue.EnQue<float>(yLocal);
    xInQueue.FreeTensor<float>(xLocal);

    yLocal = yOutQueue.DeQue<float>();
    ElemwiseCopyOut<float>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<float>(yLocal);

    pipe.Destroy();
}

template <HardwareLoopCase CaseId>
float ExpectedValue(float x, float scalar)
{
    float base = (((x + scalar) * 2.0f + 1.0f) * x) + scalar;
    if constexpr (CaseId == HardwareLoopCase::GOOD_IF_CONSTEXPR) {
        return base + 1.0f;
    } else if constexpr (CaseId == HardwareLoopCase::GOOD_COMPARE_SELECT) {
        return std::fabs(x - 5.0f) < 0.001f ? -1.0f : base;
    } else if constexpr (CaseId == HardwareLoopCase::BAD_RUNTIME_IF || CaseId == HardwareLoopCase::BAD_TERNARY) {
        float delta = std::fabs(scalar);
        return (((x + delta) * 2.0f + 1.0f) * x) + delta;
    } else if constexpr (CaseId == HardwareLoopCase::BAD_CONTINUE) {
        int loopIdx = static_cast<int>(x) / static_cast<int>(VL_B32);
        return base + ((loopIdx & 1) == 0 ? 1.0f : 0.0f);
    } else if constexpr (CaseId == HardwareLoopCase::BAD_LOOP_INDEX_DATA_IF) {
        int loopIdx = static_cast<int>(x) / static_cast<int>(VL_B32);
        return loopIdx == 5 ? -1.0f : base;
    } else if constexpr (CaseId == HardwareLoopCase::EXTREME_IF_LOOP_INDEX) {
        int loopIdx = static_cast<int>(x) / static_cast<int>(VL_B32);
        return base + ((loopIdx & 1) == 0 ? 1.0f : 0.0f);
    } else if constexpr (CaseId == HardwareLoopCase::EXTREME_MUTABLE_STEP) {
        int loopIdx = static_cast<int>(x) / static_cast<int>(VL_B32);
        return (loopIdx & 1) == 0 ? base : 0.0f;
    } else {
        return base;
    }
}

template <HardwareLoopCase CaseId>
void RunHardwareLoopCase(const char* caseName, int N, float scalar, aclrtStream stream)
{
    size_t size = static_cast<size_t>(N) * sizeof(float);
    assert(2 * CeilAlign<uint32_t>(size, UBBLOCKSIZE) <= AVAIL_UBSIZE);
    assert(GetLoopCount(static_cast<uint32_t>(N)) >= 4);

    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, 0.0f);
    FillIndex(x);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);

    hwloop_kernel<CaseId><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), scalar, N);
    aclrtSynchronizeStream(stream);

    yDev.CopyToHost(y);
    auto expected = [&](int idx) -> float { return ExpectedValue<CaseId>(x[idx], scalar); };
    int failed = CountMismatches(caseName, y, expected);
    std::vector<int> samples = {0, 5, N - 1};
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();

    constexpr int N = static_cast<int>(VL_B32 * 20); // twenty full VF iterations.
    constexpr int N_NESTED4 = static_cast<int>(VL_B32 * 16); // 2*2*2*2 nested-loop iterations.
    constexpr int N_NESTED5 = static_cast<int>(VL_B32 * 32); // 2*2*2*2*2 nested-loop iterations.
    constexpr int N_TAIL = static_cast<int>(VL_B32 * 19 + 17); // nineteen full iterations plus one tail.
    constexpr float scalar = 3.0f;
    RunHardwareLoopCase<HardwareLoopCase::GOOD_STANDARD>("GOOD_STANDARD", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::GOOD_IF_CONSTEXPR>("GOOD_IF_CONSTEXPR", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::GOOD_COMPARE_SELECT>("GOOD_COMPARE_SELECT", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::GOOD_NESTED4_IMMEDIATE>("GOOD_NESTED4_IMMEDIATE", N_NESTED4, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::TAIL_UPDATE_MASK>("TAIL_UPDATE_MASK", N_TAIL, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::TAIL_FOR_ONE>("TAIL_FOR_ONE", N_TAIL, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::TAIL_RUNTIME_IF>("TAIL_RUNTIME_IF", N_TAIL, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_U32_ITER>("BAD_U32_ITER", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_NONZERO_START>("BAD_NONZERO_START", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_STEP_TWO>("BAD_STEP_TWO", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_RUNTIME_START>("BAD_RUNTIME_START", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_RUNTIME_STRIDE>("BAD_RUNTIME_STRIDE", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_RUNTIME_IF>("BAD_RUNTIME_IF", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_TERNARY>("BAD_TERNARY", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_CONTINUE>("BAD_CONTINUE", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::BAD_LOOP_INDEX_DATA_IF>("BAD_LOOP_INDEX_DATA_IF", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::EXTREME_IF_LOOP_INDEX>("EXTREME_IF_LOOP_INDEX", N, scalar, stream);
    //! 不允许示例保留为注释，不参与正常执行
    // RunHardwareLoopCase<HardwareLoopCase::EXTREME_BREAK>("EXTREME_BREAK", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::EXTREME_WHILE>("EXTREME_WHILE", N, scalar, stream);
    //! 不允许示例保留为注释，不参与正常执行
    // RunHardwareLoopCase<HardwareLoopCase::EXTREME_MUTABLE_BOUND>("EXTREME_MUTABLE_BOUND", N, scalar, stream);
    // RunHardwareLoopCase<HardwareLoopCase::EXTREME_MUTABLE_STEP>("EXTREME_MUTABLE_STEP", N, scalar, stream);
    RunHardwareLoopCase<HardwareLoopCase::NESTED5_RUNTIME_IMMEDIATE>("NESTED5_RUNTIME_IMMEDIATE", N_NESTED5, scalar, stream);

    return 0;
}
