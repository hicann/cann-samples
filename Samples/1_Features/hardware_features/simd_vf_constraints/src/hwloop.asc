__simd_vf__ inline void ExtremeWhileVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    uint16_t i = 0;

    while (i < vfLoopNum) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        HWLOOP_FIVE_COMPUTE(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
        ++i;
    }
}

