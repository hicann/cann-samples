#include "acl/acl.h"
#include "host_test_utils.h"
#include "kernel_operator.h"
#include "kernel_utils.h"

#include <cassert>
#include <cmath>
#include <cstdio>
#include <cstdint>
#include <vector>

template <typename T>
__simd_callee__ inline T CalcIntegerScalar(uint16_t i, T a, T b, T divisor)
{
    T lhs = static_cast<T>(static_cast<uint32_t>(i) + static_cast<uint32_t>(a));
    T addValue = static_cast<T>(lhs + b);
    T subValue = static_cast<T>(lhs - b);
    T mulValue = static_cast<T>(lhs * b);
    T div2Value = static_cast<T>(lhs / static_cast<T>(2));
    T div3Value = static_cast<T>(lhs / static_cast<T>(3));
    T divVarValue = static_cast<T>(lhs / divisor);
    T mod2Value = static_cast<T>(lhs % static_cast<T>(2));
    T mod3Value = static_cast<T>(lhs % static_cast<T>(3));
    T modVarValue = static_cast<T>(lhs % divisor);
    return static_cast<T>(
        addValue + subValue + mulValue + div2Value + div3Value + divVarValue + mod2Value + mod3Value + modVarValue);
}

template <typename T>
__simd_vf__ inline void PrecomputedScalarVF(
    __ubuf__ T* xUbAddr, __ubuf__ T* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum, T scalar)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(remainElemNum);
        AscendC::Reg::LoadAlign<T>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<T>(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign<T>(yUbAddr + i * VL_T, yReg, mask);
    }
}

template <typename T>
__simd_vf__ inline void HoistableScalarVF(
    __ubuf__ T* xUbAddr, __ubuf__ T* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum, T divisor)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(remainElemNum);
        T scalar = static_cast<T>(elemNum) / divisor;
        AscendC::Reg::LoadAlign<T>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<T>(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign<T>(yUbAddr + i * VL_T, yReg, mask);
    }
}

template <typename T>
__simd_vf__ inline void IntegerLoopScalarVF(__ubuf__ T* xUbAddr, __ubuf__ T* yUbAddr,
    uint32_t elemNum, uint16_t vfLoopNum, T a, T b, T divisor)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(remainElemNum);
        T scalar = CalcIntegerScalar<T>(i, a, b, divisor);
        AscendC::Reg::LoadAlign<T>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<T>(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign<T>(yUbAddr + i * VL_T, yReg, mask);
    }
}

