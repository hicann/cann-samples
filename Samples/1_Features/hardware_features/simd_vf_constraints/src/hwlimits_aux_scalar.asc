}
*/

//! 不允许：VF Loop 内不支持依赖循环状态的浮点标量计算。
/*
template <typename T>
__simd_vf__ inline void InvalidLoopFloatExprVF(__ubuf__ T* xUbAddr, __ubuf__ T* yUbAddr,
    uint32_t elemNum, uint16_t vfLoopNum, T a, T b, T divisor)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(remainElemNum);
        T scalar = (static_cast<T>(i) + a - b) * b / divisor;
        AscendC::Reg::LoadAlign<T>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<T>(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign<T>(yUbAddr + i * VL_T, yReg, mask);
    }
}
*/

template <typename T>
__global__ __vector__ void precomputed_scalar_kernel(__gm__ T* x, __gm__ T* y, int N)
{
    AscendC::GlobalTensor<T> xGlobal;
    AscendC::GlobalTensor<T> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;
    uint32_t ubBytes = CeilAlign<uint32_t>(N * sizeof(T), UBBLOCKSIZE);
    pipe.InitBuffer(xInQueue, 1, ubBytes);
    pipe.InitBuffer(yOutQueue, 1, ubBytes);

    AscendC::LocalTensor<T> xLocal = xInQueue.AllocTensor<T>();
    ElemwiseCopyIn<T>(xLocal, xGlobal, N);
    xInQueue.EnQue<T>(xLocal);
    xLocal = xInQueue.DeQue<T>();
    AscendC::LocalTensor<T> yLocal = yOutQueue.AllocTensor<T>();

    auto* xUbAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    uint32_t elemNum = static_cast<uint32_t>(N);
    uint16_t vfLoopNum = static_cast<uint16_t>(CeilDiv<uint32_t>(elemNum, VL_T));
    T a = static_cast<T>((static_cast<uint32_t>(N) & 3U) + 5U);
    T b = static_cast<T>(3U);
    T scalar = static_cast<T>(((a + b) * static_cast<T>(2)) / static_cast<T>(4));
    asc_vf_call<PrecomputedScalarVF<T>>(xUbAddr, yUbAddr, elemNum, vfLoopNum, scalar);

    yOutQueue.EnQue<T>(yLocal);
    xInQueue.FreeTensor<T>(xLocal);
    yLocal = yOutQueue.DeQue<T>();
    ElemwiseCopyOut<T>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<T>(yLocal);
    pipe.Destroy();
}

template <typename T>
__global__ __vector__ void hoistable_scalar_kernel(__gm__ T* x, __gm__ T* y, int N)
{
    AscendC::GlobalTensor<T> xGlobal;
    AscendC::GlobalTensor<T> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;
    uint32_t ubBytes = CeilAlign<uint32_t>(N * sizeof(T), UBBLOCKSIZE);
    pipe.InitBuffer(xInQueue, 1, ubBytes);
    pipe.InitBuffer(yOutQueue, 1, ubBytes);

    AscendC::LocalTensor<T> xLocal = xInQueue.AllocTensor<T>();
    ElemwiseCopyIn<T>(xLocal, xGlobal, N);
    xInQueue.EnQue<T>(xLocal);
    xLocal = xInQueue.DeQue<T>();
    AscendC::LocalTensor<T> yLocal = yOutQueue.AllocTensor<T>();

    auto* xUbAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    uint32_t elemNum = static_cast<uint32_t>(N);
    uint16_t vfLoopNum = static_cast<uint16_t>(CeilDiv<uint32_t>(elemNum, VL_T));
    T runtimeDivisor = static_cast<T>((static_cast<uint32_t>(N) & 1U) + 3U);
    asc_vf_call<HoistableScalarVF<T>>(xUbAddr, yUbAddr, elemNum, vfLoopNum, runtimeDivisor);

    yOutQueue.EnQue<T>(yLocal);
    xInQueue.FreeTensor<T>(xLocal);
    yLocal = yOutQueue.DeQue<T>();
    ElemwiseCopyOut<T>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<T>(yLocal);
    pipe.Destroy();
}

template <typename T>
__global__ __vector__ void integer_loop_scalar_kernel(__gm__ T* x, __gm__ T* y, int N)
{
    AscendC::GlobalTensor<T> xGlobal;
    AscendC::GlobalTensor<T> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;
    uint32_t ubBytes = CeilAlign<uint32_t>(N * sizeof(T), UBBLOCKSIZE);
    pipe.InitBuffer(xInQueue, 1, ubBytes);
    pipe.InitBuffer(yOutQueue, 1, ubBytes);

    AscendC::LocalTensor<T> xLocal = xInQueue.AllocTensor<T>();
    ElemwiseCopyIn<T>(xLocal, xGlobal, N);
    xInQueue.EnQue<T>(xLocal);
    xLocal = xInQueue.DeQue<T>();
    AscendC::LocalTensor<T> yLocal = yOutQueue.AllocTensor<T>();

    auto* xUbAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    uint32_t elemNum = static_cast<uint32_t>(N);
    uint16_t vfLoopNum = static_cast<uint16_t>(CeilDiv<uint32_t>(elemNum, VL_T));
    T runtimeDivisor = static_cast<T>((static_cast<uint32_t>(N) & 1U) + 3U);
    asc_vf_call<IntegerLoopScalarVF<T>>(
        xUbAddr, yUbAddr, elemNum, vfLoopNum, static_cast<T>(5), static_cast<T>(2), runtimeDivisor);

    yOutQueue.EnQue<T>(yLocal);
    xInQueue.FreeTensor<T>(xLocal);
    yLocal = yOutQueue.DeQue<T>();
    ElemwiseCopyOut<T>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<T>(yLocal);
    pipe.Destroy();
}

template <typename T>
T HostCalcIntegerScalar(uint16_t i, T a, T b, T divisor)
{
    T lhs = static_cast<T>(static_cast<uint32_t>(i) + static_cast<uint32_t>(a));
    T addValue = static_cast<T>(lhs + b);
    T subValue = static_cast<T>(lhs - b);
    T mulValue = static_cast<T>(lhs * b);
    T div2Value = static_cast<T>(lhs / static_cast<T>(2));
    T div3Value = static_cast<T>(lhs / static_cast<T>(3));
    T divVarValue = static_cast<T>(lhs / divisor);
    T mod2Value = static_cast<T>(lhs % static_cast<T>(2));
    T mod3Value = static_cast<T>(lhs % static_cast<T>(3));
    T modVarValue = static_cast<T>(lhs % divisor);
    return static_cast<T>(
        addValue + subValue + mulValue + div2Value + div3Value + divVarValue + mod2Value + mod3Value + modVarValue);
}

template <typename T>
constexpr int GetCaseElemNum()
{
    constexpr int vectorRegBytes = 256;
    return static_cast<int>(vectorRegBytes / sizeof(T));
}

void RunPrecomputedScalarCase(const char* caseName, int N, aclrtStream stream)
{
    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, 0.0f);
    FillModulo(x, 8);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);
    yDev.CopyFromHost(y);

    precomputed_scalar_kernel<float><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N);
    aclrtSynchronizeStream(stream);
    yDev.CopyToHost(y);

    float a = static_cast<float>((static_cast<uint32_t>(N) & 3U) + 5U);
    float b = 3.0f;
    float scalar = ((a + b) * 2.0f) / 4.0f;
    auto expected = [&](int idx) -> float { return x[idx] + scalar; };
    std::vector<int> samples = {0, N - 1};
    int failed = CountSampleMismatches(y, samples, expected);
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

void RunHoistableScalarCase(const char* caseName, int N, aclrtStream stream)
{
    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, 0.0f);
    FillModulo(x, 8);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);
    yDev.CopyFromHost(y);

    hoistable_scalar_kernel<float><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N);
    aclrtSynchronizeStream(stream);
    yDev.CopyToHost(y);

    float divisor = static_cast<float>((static_cast<uint32_t>(N) & 1U) + 3U);
    float scalar = static_cast<float>(N) / divisor;
    auto expected = [&](int idx) -> float { return x[idx] + scalar; };
    std::vector<int> samples = {0, N - 1};
    int failed = CountSampleMismatches(y, samples, expected);
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

template <typename T>
void RunIntegerScalarCase(const char* caseName, int N, aclrtStream stream)
{
    std::vector<T> x(N, static_cast<T>(0));
    std::vector<T> y(N, static_cast<T>(0));
    FillModulo(x, 8);

    DeviceBuffer<T> xDev(N);
    DeviceBuffer<T> yDev(N);
    xDev.CopyFromHost(x);
    yDev.CopyFromHost(y);

    integer_loop_scalar_kernel<T><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N);
    aclrtSynchronizeStream(stream);
    yDev.CopyToHost(y);

    constexpr int VL_T = GetCaseElemNum<T>();
    T divisor = static_cast<T>((static_cast<uint32_t>(N) & 1U) + 3U);
    auto expected = [&](int idx) -> T {
        return static_cast<T>(x[idx] +
            HostCalcIntegerScalar<T>(static_cast<uint16_t>(idx / VL_T), static_cast<T>(5), static_cast<T>(2), divisor));
    };
    std::vector<int> samples = {0, VL_T, 2 * VL_T, N - 1};
    int failed = CountSampleMismatches(y, samples, expected);
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();

    RunPrecomputedScalarCase("AUX_SCALAR_PRECOMPUTED_FLOAT", 4 * GetCaseElemNum<float>() + 1, stream);
    RunHoistableScalarCase("AUX_SCALAR_HOISTABLE_FLOAT", 4 * GetCaseElemNum<float>() + 1, stream);
    RunIntegerScalarCase<int16_t>("AUX_SCALAR_INT16_OPS", 4 * GetCaseElemNum<int16_t>() + 1, stream);
    RunIntegerScalarCase<uint16_t>("AUX_SCALAR_UINT16_OPS", 4 * GetCaseElemNum<uint16_t>() + 1, stream);
    RunIntegerScalarCase<int32_t>("AUX_SCALAR_INT32_OPS", 4 * GetCaseElemNum<int32_t>() + 1, stream);
    RunIntegerScalarCase<uint32_t>("AUX_SCALAR_UINT32_OPS", 4 * GetCaseElemNum<uint32_t>() + 1, stream);

    return 0;
}
