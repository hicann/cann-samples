#include "acl/acl.h"
#include "host_test_utils.h"
#include "kernel_operator.h"
#include "kernel_utils.h"

#include <cassert>
#include <cmath>
#include <cstdio>
#include <vector>

__simd_vf__ inline void DataAccessVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        AscendC::Reg::Adds(yReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, yReg, mask);
    }
}

