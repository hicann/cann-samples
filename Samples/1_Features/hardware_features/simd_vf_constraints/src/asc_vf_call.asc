#include "acl/acl.h"
#include "host_test_utils.h"
#include "kernel_operator.h"
#include "kernel_utils.h"

#include <cassert>
#include <cstdio>
#include <vector>

__simd_vf__ inline void PlainVF(__ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr,
    float scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(float);
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < vfLoopNum; i++) {
        mask = AscendC::Reg::UpdateMask<float>(elemNum);
        AscendC::Reg::LoadAlign<float>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<float>(xReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign<float>(yUbAddr + i * VL_T, xReg, mask);
    }
}

template <typename T, uint32_t Scale>
__simd_vf__ inline void TemplateVF(__ubuf__ T* xUbAddr, __ubuf__ T* yUbAddr,
    T scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    T delta = static_cast<T>(static_cast<float>(Scale) * static_cast<float>(scalar));

    for (uint16_t i = 0; i < vfLoopNum; i++) {
        mask = AscendC::Reg::UpdateMask<T>(elemNum);
        AscendC::Reg::LoadAlign<T>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<T>(xReg, xReg, delta, mask);
        AscendC::Reg::StoreAlign<T>(yUbAddr + i * VL_T, xReg, mask);
    }
}


