template <uint32_t CaseId>
__global__ __vector__ void asc_vf_call_kernel(__gm__ float* x, __gm__ float* y, float scalar, int N)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(float);

    AscendC::GlobalTensor<float> xGlobal;
    AscendC::GlobalTensor<float> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;
    pipe.InitBuffer(xInQueue, 1, CeilAlign<uint32_t>(N * sizeof(float), UBBLOCKSIZE));
    pipe.InitBuffer(yOutQueue, 1, CeilAlign<uint32_t>(N * sizeof(float), UBBLOCKSIZE));

    AscendC::LocalTensor<float> xLocal = xInQueue.AllocTensor<float>();
    ElemwiseCopyIn<float>(xLocal, xGlobal, N);
    xInQueue.EnQue<float>(xLocal);

    xLocal = xInQueue.DeQue<float>();
    AscendC::LocalTensor<float> yLocal = yOutQueue.AllocTensor<float>();

    uint32_t elemNum = static_cast<uint32_t>(N);
    uint16_t vfLoopNum = CeilDiv<uint16_t>(elemNum, VL_T);
    auto* xUbAddr = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());

    if constexpr (CaseId == 0) {
        asc_vf_call<PlainVF>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    } else if constexpr (CaseId == 1) {
        asc_vf_call<TemplateVF<float, 2>>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    }

    yOutQueue.EnQue<float>(yLocal);
    xInQueue.FreeTensor<float>(xLocal);

    yLocal = yOutQueue.DeQue<float>();
    ElemwiseCopyOut<float>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<float>(yLocal);

    pipe.Destroy();
}

template <uint32_t CaseId>
void RunAscVfCallCase(const char* caseName, int N, float scalar, float expectedDelta, aclrtStream stream)
{
    size_t size = static_cast<size_t>(N) * sizeof(float);
    assert(2 * CeilAlign<uint32_t>(size, UBBLOCKSIZE) <= AVAIL_UBSIZE);

    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, 0.0f);
    FillIndex(x);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);

    asc_vf_call_kernel<CaseId><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), scalar, N);
    aclrtSynchronizeStream(stream);

    yDev.CopyToHost(y);
    auto expected = [&](int idx) -> float { return x[idx] + expectedDelta; };
    std::vector<int> samples = {0, 1, N - 1};
    int failed = CountSampleMismatches(y, samples, expected);
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();

    RunAscVfCallCase<0>("PlainVF", 123, 5.0f, 5.0f, stream);
    RunAscVfCallCase<1>("TemplateVF<float, 2>", 123, 5.0f, 10.0f, stream);

    return 0;
}
