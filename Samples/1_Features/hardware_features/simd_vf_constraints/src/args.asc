#include "acl/acl.h"
#include "host_test_utils.h"
#include "kernel_operator.h"
#include "kernel_utils.h"

#include <vector>
#include <cstdio>
#include <cassert>

//! __simd_vf__入参定义的不允许示例。
/*
//! 引用参数不支持：simd_vf 函数的指针参数必须位于 __ubuf__ 地址空间。
__simd_vf__ inline void InvalidRefArg(__ubuf__ float* x, float& scale) {}

//! 普通指针和非 UB 地址空间不支持：SIMD VF 指针参数必须使用 __ubuf__ 修饰。
__simd_vf__ inline void InvalidPlainPtr(float* x) {}
__simd_vf__ inline void InvalidGmPtr(__gm__ float* x) {}

//! 数组参数会退化为指针，因此同样受非 __ubuf__ 指针限制。
__simd_vf__ inline void InvalidArrayArg(float coeff[4], __ubuf__ float* y) {}

//! 函数指针和函数对象不支持作为 SIMD VF 参数。
using ScaleFn = float (*)(float);
__simd_vf__ inline void InvalidFunctionPtr(ScaleFn fn, __ubuf__ float* y) {}

struct VfParams {
    float scale;
    uint32_t elemNum;
};

//! 结构体按值传递属于不支持写法，可能会造成未定义行为。
__simd_vf__ inline void InvalidStructValue(__ubuf__ float* x, VfParams params) {}
*/

template<typename T>
__simd_vf__ inline void SingleOpVF(__ubuf__ T* xUbAddr, __ubuf__ T* yUbAddr,
    T scalar, uint32_t elemNum, uint16_t vfLoopNum)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);

    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; i++) {
        mask = AscendC::Reg::UpdateMask<T>(remainElemNum);
        AscendC::Reg::LoadAlign<T>(xReg, xUbAddr + i * VL_T);
        AscendC::Reg::Adds<T>(xReg, xReg, scalar, mask);
        AscendC::Reg::StoreAlign<T>(yUbAddr + i * VL_T, xReg, mask);
    }
}


template<typename T>
__global__ __vector__ void single_op_kernel(__gm__ T* x, __gm__ T* y, T scalar, int N)
{
    constexpr uint32_t VL_T = AscendC::VECTOR_REG_WIDTH / sizeof(T);

    AscendC::GlobalTensor<T> xGlobal, yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;
    pipe.InitBuffer(xInQueue, 1, CeilAlign<uint32_t>(N * sizeof(T), UBBLOCKSIZE));
    pipe.InitBuffer(yOutQueue, 1, CeilAlign<uint32_t>(N * sizeof(T), UBBLOCKSIZE));

    AscendC::LocalTensor<T> xLocal = xInQueue.AllocTensor<T>();
    ElemwiseCopyIn<T>(xLocal, xGlobal, N);
    xInQueue.EnQue<T>(xLocal);

    xLocal = xInQueue.DeQue<T>();
    AscendC::LocalTensor<T> yLocal = yOutQueue.AllocTensor<T>();

    uint32_t elemNum = static_cast<uint32_t>(N);
    uint16_t vfLoopNum = CeilDiv<uint16_t>(elemNum, VL_T);
    auto* xUbAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());


    // TODO: 发送单目运算VF
    // if constexpr (AscendC::IsSameType<T, double>::value) {
    //     asc_vf_call<SingleOpVF_TestDoubleScalars>(
    //         xUbAddr, yUbAddr, static_cast<double>(scalar) + 4294967297LL, 4294967296LL, elemNum, vfLoopNum);
    // } else {
    //     asc_vf_call<SingleOpVF<T>>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);
    // }
    asc_vf_call<SingleOpVF<T>>(xUbAddr, yUbAddr, scalar, elemNum, vfLoopNum);


    yOutQueue.EnQue<T>(yLocal);
    xInQueue.FreeTensor<T>(xLocal);

    yLocal = yOutQueue.DeQue<T>();
    ElemwiseCopyOut<T>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<T>(yLocal);

    pipe.Destroy();
}

template<typename T>
void TestSingleOpKernel(const char* caseName, int N, T scalar, aclrtStream stream)
{
    size_t size = N * sizeof(T);
    assert(2 * CeilAlign<uint32_t>(size, UBBLOCKSIZE) <= AVAIL_UBSIZE);

    std::vector<T> x(N, 0);
    std::vector<T> y(N, 0);
    FillIndex(x);

    DeviceBuffer<T> xDev(N);
    DeviceBuffer<T> yDev(N);
    xDev.CopyFromHost(x);

    // TODO: 拉起单目运算Kernel
    single_op_kernel<T><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), scalar, N);
    aclrtSynchronizeStream(stream);

    yDev.CopyToHost(y);
    auto expected = [&](int idx) -> T { return static_cast<T>(x[idx] + scalar); };
    std::vector<int> samples = {0, 1, N - 1};
    int failed = CountSampleMismatches(y, samples, expected);
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();
    
    TestSingleOpKernel<float>("ARGS_FLOAT", 123, static_cast<float>(114), stream);
    TestSingleOpKernel<uint16_t>("ARGS_UINT16", 243, static_cast<uint16_t>(2), stream);
    TestSingleOpKernel<int8_t>("ARGS_INT8", 13, static_cast<int8_t>(3), stream);
    TestSingleOpKernel<int64_t>("ARGS_INT64", 333, static_cast<int64_t>(4294967296LL), stream);
    TestSingleOpKernel<uint64_t>("ARGS_UINT64", 334, static_cast<uint64_t>(4294967297LL), stream);

    return 0;
}
