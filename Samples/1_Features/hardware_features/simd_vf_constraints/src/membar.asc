    AscendC::Reg::RegTensor<float> loadReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        AscendC::Reg::Adds(storeReg, xReg, 1.0f, mask);
        AscendC::Reg::StoreAlign(tmpUbAddr + i * VL_B32, storeReg, mask);
        AscendC::Reg::LoadAlign(loadReg, tmpUbAddr + i * VL_B32);
        AscendC::Reg::Adds(loadReg, loadReg, 2.0f, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, loadReg, mask);
    }
}
*/

__simd_vf__ inline void InterIterWithMemBarVF(__ubuf__ float* xUbAddr, __ubuf__ float* tmpUbAddr,
    __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> prevReg;
    AscendC::Reg::RegTensor<float> tmpReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    AscendC::Reg::MaskReg allMask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::Duplicate(tmpReg, 0.0f, allMask);
    AscendC::Reg::StoreAlign(tmpUbAddr, tmpReg, allMask);

    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_STORE, AscendC::Reg::MemType::VEC_LOAD>();
        AscendC::Reg::LoadAlign(prevReg, tmpUbAddr);
        AscendC::Reg::Adds(prevReg, prevReg, 2.0f, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, prevReg, mask);

        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        AscendC::Reg::Adds(tmpReg, xReg, 1.0f, mask);
        AscendC::Reg::StoreAlign(tmpUbAddr, tmpReg, mask);
    }
}

//! 不允许：跨轮次 Store 后 Load 依赖缺少 LocalMemBar 保序。
/*
__simd_vf__ inline void InterIterNoMemBarVF(__ubuf__ float* xUbAddr, __ubuf__ float* tmpUbAddr,
    __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> prevReg;
    AscendC::Reg::RegTensor<float> tmpReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    AscendC::Reg::MaskReg allMask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::Duplicate(tmpReg, 0.0f, allMask);
    AscendC::Reg::StoreAlign(tmpUbAddr, tmpReg, allMask);

    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        AscendC::Reg::LoadAlign(prevReg, tmpUbAddr);
        AscendC::Reg::Adds(prevReg, prevReg, 2.0f, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, prevReg, mask);

        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        AscendC::Reg::Adds(tmpReg, xReg, 1.0f, mask);
        AscendC::Reg::StoreAlign(tmpUbAddr, tmpReg, mask);
    }
}
*/

template <LocalMemBarCase CaseId>
__global__ __vector__ void membar_kernel(__gm__ float* x, __gm__ float* y, int N)
{
    AscendC::GlobalTensor<float> xGlobal;
    AscendC::GlobalTensor<float> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf;
    AscendC::TPipe pipe;

    uint32_t ubBytes = CeilAlign<uint32_t>(N * sizeof(float), UBBLOCKSIZE);
    pipe.InitBuffer(xInQueue, 1, ubBytes);
    pipe.InitBuffer(yOutQueue, 1, ubBytes);
    pipe.InitBuffer(tmpBuf, ubBytes);

    AscendC::LocalTensor<float> xLocal = xInQueue.AllocTensor<float>();
    ElemwiseCopyIn<float>(xLocal, xGlobal, N);
    xInQueue.EnQue<float>(xLocal);

    xLocal = xInQueue.DeQue<float>();
    AscendC::LocalTensor<float> yLocal = yOutQueue.AllocTensor<float>();
    AscendC::LocalTensor<float> tmpLocal = tmpBuf.Get<float>();

    uint32_t elemNum = static_cast<uint32_t>(N);
    uint16_t vfLoopNum = static_cast<uint16_t>(GetMemBarLoopCount(elemNum));
    auto* xUbAddr = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    auto* tmpUbAddr = reinterpret_cast<__ubuf__ float*>(tmpLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());

    if constexpr (CaseId == LocalMemBarCase::SAME_REG_NO_MEMBAR) {
        asc_vf_call<SameRegNoMemBarVF>(xUbAddr, tmpUbAddr, yUbAddr, elemNum, vfLoopNum);
    } else if constexpr (CaseId == LocalMemBarCase::DIFF_REG_WITH_MEMBAR) {
        asc_vf_call<DiffRegWithMemBarVF>(xUbAddr, tmpUbAddr, yUbAddr, elemNum, vfLoopNum);
    } else if constexpr (CaseId == LocalMemBarCase::DIFF_REG_NO_MEMBAR) {
        //! 不允许示例保留为注释，不参与正常执行
        // asc_vf_call<DiffRegNoMemBarVF>(xUbAddr, tmpUbAddr, yUbAddr, elemNum, vfLoopNum);
    } else if constexpr (CaseId == LocalMemBarCase::INTER_ITER_WITH_MEMBAR) {
        asc_vf_call<InterIterWithMemBarVF>(xUbAddr, tmpUbAddr, yUbAddr, elemNum, vfLoopNum);
    } else if constexpr (CaseId == LocalMemBarCase::INTER_ITER_NO_MEMBAR) {
        //! 不允许示例保留为注释，不参与正常执行
        // asc_vf_call<InterIterNoMemBarVF>(xUbAddr, tmpUbAddr, yUbAddr, elemNum, vfLoopNum);
    }

    yOutQueue.EnQue<float>(yLocal);
    xInQueue.FreeTensor<float>(xLocal);

    yLocal = yOutQueue.DeQue<float>();
    ElemwiseCopyOut<float>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<float>(yLocal);

    pipe.Destroy();
}

template <LocalMemBarCase CaseId, bool RequireCorrect>
void RunLocalMemBarCase(const char* caseName, int N, aclrtStream stream)
{
    size_t size = static_cast<size_t>(N) * sizeof(float);
    assert(3 * CeilAlign<uint32_t>(size, UBBLOCKSIZE) <= AVAIL_UBSIZE);

    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, 0.0f);
    FillIndex(x);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);

    membar_kernel<CaseId><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N);
    aclrtSynchronizeStream(stream);

    yDev.CopyToHost(y);
    auto expected = [&](int i) -> float {
        float expected = x[i] + 3.0f;
        if constexpr (CaseId == LocalMemBarCase::INTER_ITER_WITH_MEMBAR ||
                      CaseId == LocalMemBarCase::INTER_ITER_NO_MEMBAR) {
            int loopIdx = i / static_cast<int>(VL_B32);
            int lane = i % static_cast<int>(VL_B32);
            expected = loopIdx == 0 ? 2.0f : x[(loopIdx - 1) * static_cast<int>(VL_B32) + lane] + 3.0f;
        }
        return expected;
    };

    int failed = CountMismatches(caseName, y, expected);
    const char* status = failed == 0 ? "OK" : "MISMATCH";
    if (!RequireCorrect && failed == 0) {
        status = "OBSERVED_OK_UNSAFE";
    }
    std::vector<int> samples = {0, 5, N - 1};
    PrintCaseResult(caseName, status, N, y, expected, samples, failed);

    if constexpr (RequireCorrect) {
        assert(failed == 0);
    }
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();

    constexpr int N = static_cast<int>(VL_B32 * 20 + 17);
    RunLocalMemBarCase<LocalMemBarCase::SAME_REG_NO_MEMBAR, true>("SAME_REG_NO_MEMBAR", N, stream);
    RunLocalMemBarCase<LocalMemBarCase::DIFF_REG_WITH_MEMBAR, true>("DIFF_REG_WITH_MEMBAR", N, stream);
    //! 不允许示例保留为注释，不参与正常执行
    // RunLocalMemBarCase<LocalMemBarCase::DIFF_REG_NO_MEMBAR, false>("DIFF_REG_NO_MEMBAR", N, stream);
    RunLocalMemBarCase<LocalMemBarCase::INTER_ITER_WITH_MEMBAR, true>("INTER_ITER_WITH_MEMBAR", N, stream);
    //! 不允许示例保留为注释，不参与正常执行
    // RunLocalMemBarCase<LocalMemBarCase::INTER_ITER_NO_MEMBAR, false>("INTER_ITER_NO_MEMBAR", N, stream);

    return 0;
}
