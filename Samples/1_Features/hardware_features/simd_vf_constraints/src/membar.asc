#include "acl/acl.h"
#include "host_test_utils.h"
#include "kernel_operator.h"
#include "kernel_utils.h"

#include <cassert>
#include <cmath>
#include <cstdio>
#include <vector>

enum class LocalMemBarCase : uint32_t {
    SAME_REG_NO_MEMBAR = 0,
    DIFF_REG_WITH_MEMBAR = 1,
    DIFF_REG_NO_MEMBAR = 2,
    INTER_ITER_WITH_MEMBAR = 3,
    INTER_ITER_NO_MEMBAR = 4,
};

__host_aicore__ inline uint32_t GetMemBarLoopCount(uint32_t elemNum)
{
    return CeilDiv<uint32_t>(elemNum, VL_B32);
}

__simd_vf__ inline void SameRegNoMemBarVF(__ubuf__ float* xUbAddr, __ubuf__ float* tmpUbAddr,
    __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> workReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        AscendC::Reg::LoadAlign(workReg, xUbAddr + i * VL_B32);
        AscendC::Reg::Adds(workReg, workReg, 1.0f, mask);
        AscendC::Reg::StoreAlign(tmpUbAddr + i * VL_B32, workReg, mask);
        AscendC::Reg::LoadAlign(workReg, tmpUbAddr + i * VL_B32);
        AscendC::Reg::Adds(workReg, workReg, 2.0f, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, workReg, mask);
    }
}

__simd_vf__ inline void DiffRegWithMemBarVF(__ubuf__ float* xUbAddr, __ubuf__ float* tmpUbAddr,
    __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> storeReg;
    AscendC::Reg::RegTensor<float> loadReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        AscendC::Reg::LoadAlign(xReg, xUbAddr + i * VL_B32);
        AscendC::Reg::Adds(storeReg, xReg, 1.0f, mask);
        AscendC::Reg::StoreAlign(tmpUbAddr + i * VL_B32, storeReg, mask);
        AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_STORE, AscendC::Reg::MemType::VEC_LOAD>();
        AscendC::Reg::LoadAlign(loadReg, tmpUbAddr + i * VL_B32);
        AscendC::Reg::Adds(loadReg, loadReg, 2.0f, mask);
        AscendC::Reg::StoreAlign(yUbAddr + i * VL_B32, loadReg, mask);
    }
}

//! 不允许：同地址 Store 后 Load 依赖缺少 LocalMemBar 保序。
/*
__simd_vf__ inline void DiffRegNoMemBarVF(__ubuf__ float* xUbAddr, __ubuf__ float* tmpUbAddr,
    __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
