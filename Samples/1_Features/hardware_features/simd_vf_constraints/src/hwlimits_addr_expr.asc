#include "acl/acl.h"
#include "host_test_utils.h"
#include "kernel_operator.h"
#include "kernel_utils.h"

#include <cassert>
#include <cmath>
#include <cstdio>
#include <vector>

enum class AddrCase : uint32_t {
    DIRECT_MUL = 0,
    COMPLEX = 1,
    MOD5 = 2,
    DIV5 = 3,
    ADDR_REG = 4,
};

template <AddrCase CaseId>
const char* AddrCaseName()
{
    if constexpr (CaseId == AddrCase::DIRECT_MUL) {
        return "DIRECT_MUL";
    } else if constexpr (CaseId == AddrCase::COMPLEX) {
        return "COMPLEX";
    } else if constexpr (CaseId == AddrCase::MOD5) {
        return "MOD5";
    } else if constexpr (CaseId == AddrCase::DIV5) {
        return "DIV5";
    } else {
        return "ADDR_REG";
    }
}

template <AddrCase CaseId>
__simd_callee__ inline uint32_t CalcAddrOffset(uint16_t i)
{
    uint32_t idx = static_cast<uint32_t>(i);
    if constexpr (CaseId == AddrCase::DIRECT_MUL) {
        return idx * VL_B32;
    } else if constexpr (CaseId == AddrCase::COMPLEX) {
        return (((idx + 1U) * VL_B32 * 2U) / 2U) - VL_B32;
    } else if constexpr (CaseId == AddrCase::DIV5) {
        return (idx / 5U) * VL_B32;
    } else {
        return (idx % 5U) * VL_B32;
    }
}

template <AddrCase CaseId>
__simd_vf__ inline void AddrExprVF(
    __ubuf__ float* xUbAddr, __ubuf__ float* yUbAddr, uint32_t elemNum, uint16_t vfLoopNum)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    uint32_t remainElemNum = elemNum;
    for (uint16_t i = 0; i < vfLoopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remainElemNum);
        if constexpr (CaseId == AddrCase::ADDR_REG) {
            AscendC::Reg::AddrReg aReg = AscendC::Reg::CreateAddrReg<float>(i, VL_B32);
            AscendC::Reg::LoadAlign(xReg, xUbAddr, aReg);
            AscendC::Reg::StoreAlign(yUbAddr, xReg, aReg, mask);
        } else {
            uint32_t offset = CalcAddrOffset<CaseId>(i);
            if constexpr (CaseId == AddrCase::DIV5) {
                AscendC::Reg::LoadAlign(xReg, xUbAddr + offset);
                AscendC::Reg::StoreAlign(yUbAddr + static_cast<uint32_t>(i) * VL_B32, xReg, mask);
            } else {
                AscendC::Reg::LoadAlign(xReg, xUbAddr + offset);
                AscendC::Reg::StoreAlign(yUbAddr + offset, xReg, mask);
            }
        }
    }
}

//! 不允许：VF Loop 内不支持浮点地址偏移计算。
