template <AddrCase CaseId>
__global__ __vector__ void addr_expr_kernel(__gm__ float* x, __gm__ float* y, int N)
{
    AscendC::GlobalTensor<float> xGlobal;
    AscendC::GlobalTensor<float> yGlobal;
    xGlobal.SetGlobalBuffer(x);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> xInQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> yOutQueue;
    AscendC::TPipe pipe;
    uint32_t ubBytes = CeilAlign<uint32_t>(N * sizeof(float), UBBLOCKSIZE);
    pipe.InitBuffer(xInQueue, 1, ubBytes);
    pipe.InitBuffer(yOutQueue, 1, ubBytes);

    AscendC::LocalTensor<float> xLocal = xInQueue.AllocTensor<float>();
    ElemwiseCopyIn<float>(xLocal, xGlobal, N);
    xInQueue.EnQue<float>(xLocal);
    xLocal = xInQueue.DeQue<float>();
    AscendC::LocalTensor<float> yLocal = yOutQueue.AllocTensor<float>();

    auto* xUbAddr = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    auto* yUbAddr = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());
    asc_vf_call<AddrExprVF<CaseId>>(
        xUbAddr, yUbAddr, static_cast<uint32_t>(N), static_cast<uint16_t>(CeilDiv<uint32_t>(N, VL_B32)));

    yOutQueue.EnQue<float>(yLocal);
    xInQueue.FreeTensor<float>(xLocal);
    yLocal = yOutQueue.DeQue<float>();
    ElemwiseCopyOut<float>(yGlobal, yLocal, N);
    yOutQueue.FreeTensor<float>(yLocal);
    pipe.Destroy();
}

template <AddrCase CaseId>
void RunAddrCase(const char* caseName, int N, aclrtStream stream)
{
    std::vector<float> x(N, 0.0f);
    std::vector<float> y(N, -1.0f);
    FillIndex(x);

    DeviceBuffer<float> xDev(N);
    DeviceBuffer<float> yDev(N);
    xDev.CopyFromHost(x);
    yDev.CopyFromHost(y);

    addr_expr_kernel<CaseId><<<1, nullptr, stream>>>(xDev.Get(), yDev.Get(), N);
    aclrtSynchronizeStream(stream);
    yDev.CopyToHost(y);

    auto expected = [&](int idx) -> float {
        if constexpr (CaseId == AddrCase::DIV5) {
            int blockIdx = idx / static_cast<int>(VL_B32);
            return x[(blockIdx / 5) * static_cast<int>(VL_B32)];
        } else if constexpr (CaseId == AddrCase::MOD5) {
            return idx <= static_cast<int>(4 * VL_B32) ? x[idx] : -1.0f;
        }
        return x[idx];
    };
    std::vector<int> samples = {0, 64, 128, 192, 256};
    if constexpr (CaseId == AddrCase::DIV5) {
        samples.push_back(320);
        samples.push_back(384);
        samples.push_back(448);
        samples.push_back(512);
        samples.push_back(576);
    }
    int failed = CountSampleMismatches(y, samples, expected);
    PrintCaseResult(caseName, failed == 0 ? "OK" : "MISMATCH", N, y, expected, samples, failed);
    assert(failed == 0);
}

int main()
{
    AclRuntimeGuard runtime;
    aclrtStream stream = runtime.Stream();

    constexpr int N = static_cast<int>(VL_B32 * 10);
    RunAddrCase<AddrCase::DIRECT_MUL>(AddrCaseName<AddrCase::DIRECT_MUL>(), N, stream);
    RunAddrCase<AddrCase::COMPLEX>(AddrCaseName<AddrCase::COMPLEX>(), N, stream);
    RunAddrCase<AddrCase::MOD5>(AddrCaseName<AddrCase::MOD5>(), N, stream);
    RunAddrCase<AddrCase::DIV5>(AddrCaseName<AddrCase::DIV5>(), N, stream);
    RunAddrCase<AddrCase::ADDR_REG>(AddrCaseName<AddrCase::ADDR_REG>(), N, stream);

    return 0;
}
