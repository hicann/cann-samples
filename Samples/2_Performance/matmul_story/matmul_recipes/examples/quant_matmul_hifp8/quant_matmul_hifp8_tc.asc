/*!
 * \file quant_matmul_hifp8_tc.asc
 * \brief HiFloat8 sample (per-channel x2 scale): disk scale.bin is FP32; host converts each channel to uint64_t (DEQ + bit46) for GM.
 */

#include <cstdint>
#include <cstdlib>
#include <exception>
#include <iostream>
#include <memory>
#include <string>

#include "acl/acl.h"
#include "kernel_operator.h"

#include "block/block_mmad.h"
#include "block/block_scheduler_policy.h"
#include "host_utils/acl_utils.h"
#include "host_utils/common_utils.h"
#include "host_utils/io_utils.h"
#include "kernel/quant_matmul_hifp8_kernel_swat.h"
#include "policy/dispatch_policy.h"
#include "tiling/quant_matmul_hifp8_tiling_data.h"
#include "tiling/quant_matmul_hifp8_tiling_swat.h"

#include <vector>

namespace tc_host {

// Clear low 13 bits and Set bit 46
constexpr uint32_t kDeqScaleMulU32 = 0xFFFFE000U;
constexpr uint64_t kTcScaleU64MetaBit46 = 1ULL << 46U;

inline void Fp32ScalesToTcUInt64Host(const float* src_fp32, uint64_t* dst_u64, uint64_t channel_num)
{
    CHECK_COND(src_fp32 != nullptr && dst_u64 != nullptr, "Tc scale uint64 conversion: null pointers.");
    for (uint64_t i = 0; i < channel_num; ++i) {
        const uint32_t bits = reinterpret_cast<const uint32_t&>(src_fp32[i]);
        dst_u64[i] = static_cast<uint64_t>(bits & kDeqScaleMulU32) | kTcScaleU64MetaBit46;
    }
}

} // namespace tc_host

template <class LAYOUT_A, class LAYOUT_B, class LAYOUT_C>
__global__ __aicore__ __cube__ void MatmulHiFp8SwatKernel(GM_ADDR dA, GM_ADDR dB, GM_ADDR dScaleA, GM_ADDR dScaleB,
    GM_ADDR dC, const QuantMatmulHifp8TilingData tilingData)
{
    using AType = hifloat8_t;
    using BType = hifloat8_t;
    using CType = bfloat16_t;
    using DispatchPolicy = MatmulWithScale<NO_FULL_LOAD_MODE>;
    using ProblemShape = MatmulShape;
    using BlockMmad = Block::BlockMmad<DispatchPolicy, AType, LAYOUT_A, BType, LAYOUT_B, CType, LAYOUT_C>;
    using BlockScheduler = QuantBatchMatmulV3Scheduler<NO_FULL_LOAD_MODE>;
    using BlockEpilogue = void;
    using QuantMatmulKernelImpl =
        Kernel::QuantMmBatchCube<ProblemShape, BlockMmad, BlockEpilogue, BlockScheduler>;
    using Params = typename QuantMatmulKernelImpl::Params;
    using BlockMmadParams = typename BlockMmad::Params;
    using BlockSchedulerParams = typename QuantMatmulKernelImpl::BlockSchedulerParams;
    using QBMMTiling = typename QuantMatmulKernelImpl::QBMMTiling;

    ProblemShape problemShape{tilingData.m, tilingData.n, tilingData.k, 1L};
    BlockMmadParams mmadParams{dA, dB, dC, dScaleA, dScaleB};
    BlockSchedulerParams schedulerParams{
        tilingData.baseM, tilingData.baseN, tilingData.mTailTile, tilingData.nTailTile,
        tilingData.mBaseTailSplitCnt, tilingData.nBaseTailSplitCnt, tilingData.mTailMain, tilingData.nTailMain};
    QBMMTiling qbmmParams{tilingData.x1QuantMode, tilingData.x2QuantMode, tilingData.kAL1, tilingData.kBL1,
        tilingData.nBufferNum, tilingData.baseM, tilingData.baseN, tilingData.baseK, tilingData.dbL0c};

    Params params{problemShape, mmadParams, schedulerParams, qbmmParams};
    QuantMatmulKernelImpl quantMatmulKernelImpl;
    quantMatmulKernelImpl(params);
}

namespace {

template <bool TransA, bool TransB>
void LaunchKernel(GM_ADDR dA, GM_ADDR dB, GM_ADDR dScaleA, GM_ADDR dScaleB, GM_ADDR dC,
    const QuantMatmulHifp8TilingData& tilingData, aclrtStream stream)
{
    using LAYOUT_A = std::conditional_t<TransA, AscendC::Te::FrameLayoutFormat<AscendC::Te::DNExtLayoutPtn>, AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>>;
    using LAYOUT_B = std::conditional_t<TransB, AscendC::Te::FrameLayoutFormat<AscendC::Te::DNExtLayoutPtn>, AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>>;
    using LAYOUT_C = AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>;
    MatmulHiFp8SwatKernel<LAYOUT_A, LAYOUT_B, LAYOUT_C>
        <<<tilingData.usedCoreNum, nullptr, stream>>>(dA, dB, dScaleA, dScaleB, dC, tilingData);
    }

} // namespace

static void FillSampleTiling(
    uint64_t m, uint64_t n, uint64_t k, bool transA, bool transB, QuantMatmulHifp8TilingData& tilingData)
{
    QuantMatmulHifp8Config cfg{};
    cfg.x1QuantMode = hifp8::KERNEL_QUANT_DEFAULT;
    cfg.x2QuantMode = hifp8::KERNEL_QUANT_PERCHANNEL;
    cfg.scaleDtypeSize = sizeof(uint64_t);

    QuantMatmulHifp8TilingSwat tilingEngine;
    tilingEngine.SetQuantConfig(cfg);
    tilingEngine.GetTilingData(m, n, k, transA, transB, tilingData);
}

int main(int argc, char* argv[])
{
    uint64_t m = 0;
    uint64_t k = 0;
    uint64_t n = 0;
    bool transA = false;
    bool transB = false;
    try {
        ParseArguments(argc, argv, m, k, n, transA, transB);
    } catch (const std::exception& e) {
        std::cerr << e.what() << std::endl;
        PrintUsage(argv[0]);
        return 1;
    }

    constexpr int32_t deviceId = 0;

    try {
        QuantMatmulHifp8TilingData tilingData{};
        FillSampleTiling(m, n, k, transA, transB, tilingData);
        AclRtSession aclSession(deviceId);
        aclSession.Init();
        aclrtStream stream = aclSession.GetStream();

        uint64_t sizeA = (m * k) * sizeof(uint8_t);
        uint64_t sizeB = (k * n) * sizeof(uint8_t);
        const uint64_t sizeScaleFp32Host = n * sizeof(float);
        const uint64_t sizeScaleU64Dev = n * sizeof(uint64_t);
        uint64_t sizeC = m * n * sizeof(uint16_t);

        ExampleIoPaths paths = GetExampleIoPaths();
        uint8_t* hA = nullptr;
        uint8_t* hB = nullptr;
        float* hScaleFp32 = nullptr;
        uint16_t* hC = nullptr;
        uint8_t *dA = nullptr;
        uint8_t *dB = nullptr;
        uint8_t *dScaleB = nullptr;
        uint8_t *dC = nullptr;

        CHECK_COND(aclrtMallocHost((void**)&hA, sizeA) == ACL_SUCCESS, "Failed to allocate host buffer for A.");
        std::unique_ptr<void, aclError (*)(void*)> hostA(hA, aclrtFreeHost);
        CHECK_COND(aclrtMallocHost((void**)&hB, sizeB) == ACL_SUCCESS, "Failed to allocate host buffer for B.");
        std::unique_ptr<void, aclError (*)(void*)> hostB(hB, aclrtFreeHost);
        CHECK_COND(
            aclrtMallocHost((void**)&hScaleFp32, sizeScaleFp32Host) == ACL_SUCCESS,
            "Failed to allocate host buffer for scale (FP32).");
        std::unique_ptr<void, aclError (*)(void*)> hostScaleFp32(hScaleFp32, aclrtFreeHost);
        CHECK_COND(aclrtMallocHost((void**)&hC, sizeC) == ACL_SUCCESS, "Failed to allocate host buffer for C.");
        std::unique_ptr<void, aclError (*)(void*)> hostC(hC, aclrtFreeHost);

        CHECK_COND(ReadExactFile(paths.inputDir + "/x1.bin", hA, sizeA), "Failed to read x1.bin.");
        CHECK_COND(ReadExactFile(paths.inputDir + "/x2.bin", hB, sizeB), "Failed to read x2.bin.");
        CHECK_COND(
            ReadExactFile(paths.inputDir + "/scale.bin", reinterpret_cast<void*>(hScaleFp32),
                static_cast<size_t>(sizeScaleFp32Host)),
            "Failed to read scale.bin.");

        std::vector<uint64_t> hScaleU64(n);
        tc_host::Fp32ScalesToTcUInt64Host(hScaleFp32, hScaleU64.data(), n);

        for (int32_t i = 0; i < EXAMPLE_KERNEL_RUN_COUNT; i++) {
            CHECK_COND(aclrtMalloc((void**)&dA, sizeA, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS, "Failed to alloc dA.");
            std::unique_ptr<void, aclError (*)(void*)> deviceA(dA, aclrtFree);
            CHECK_COND(aclrtMalloc((void**)&dB, sizeB, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS, "Failed to alloc dB.");
            std::unique_ptr<void, aclError (*)(void*)> deviceB(dB, aclrtFree);
            CHECK_COND(aclrtMalloc((void**)&dScaleB, sizeScaleU64Dev, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS, "Failed to alloc dScaleB.");
            std::unique_ptr<void, aclError (*)(void*)> deviceScaleB(dScaleB, aclrtFree);
            CHECK_COND(aclrtMalloc((void**)&dC, sizeC, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS, "Failed to alloc dC.");
            std::unique_ptr<void, aclError (*)(void*)> deviceC(dC, aclrtFree);

            CHECK_COND(aclrtMemcpyAsync(dA, sizeA, hA, sizeA, ACL_MEMCPY_HOST_TO_DEVICE, stream) == ACL_SUCCESS, "Failed H2D A.");
            CHECK_COND(aclrtMemcpyAsync(dB, sizeB, hB, sizeB, ACL_MEMCPY_HOST_TO_DEVICE, stream) == ACL_SUCCESS, "Failed H2D B.");
            CHECK_COND(aclrtMemcpyAsync(dScaleB, sizeScaleU64Dev, hScaleU64.data(), sizeScaleU64Dev, ACL_MEMCPY_HOST_TO_DEVICE, stream) == ACL_SUCCESS, "Failed H2D dScaleB (per-channel uint64).");

            if (transA && transB) {
                LaunchKernel<true, true>(dA, dB, nullptr, dScaleB, dC, tilingData, stream);
            } else if (transA && !transB) {
                LaunchKernel<true, false>(dA, dB, nullptr, dScaleB, dC, tilingData, stream);
            } else if (!transA && transB) {
                LaunchKernel<false, true>(dA, dB, nullptr, dScaleB, dC, tilingData, stream);
            } else {
                LaunchKernel<false, false>(dA, dB, nullptr, dScaleB, dC, tilingData, stream);
            }

            CHECK_COND(aclrtMemcpyAsync(hC, sizeC, dC, sizeC, ACL_MEMCPY_DEVICE_TO_HOST, stream) == ACL_SUCCESS, "Failed D2H C.");
        }
        CHECK_COND(aclrtSynchronizeStream(stream) == ACL_SUCCESS, "Failed to synchronize stream.");

        CHECK_COND(WriteFile(paths.outputDir + "/npu_out.bin", hC, sizeC), "Failed to write npu_out.bin.");
        std::string cmd =
            "cd \"" + paths.baseDir + "\" && python3 verify_result.py " + std::to_string(m) + " " + std::to_string(n);
        if (std::system(cmd.c_str()) != 0) {
            return 1;
        }
        return 0;
    } catch (const std::exception& e) {
        std::cerr << e.what() << std::endl;
        return 1;
    }
}
