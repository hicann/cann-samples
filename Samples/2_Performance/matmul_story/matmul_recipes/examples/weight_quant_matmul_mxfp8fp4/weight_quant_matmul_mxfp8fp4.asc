/*!
 * \file weight_quant_matmul_mxfp8fp4.cpp
 * \brief MXA8W4 matmul sample launcher using the 2-buffer pipeline.
 */

#include <cstdint>
#include <cstdlib>
#include <exception>
#include <iostream>
#include <memory>
#include <string>

#include "acl/acl.h"
#include "kernel_operator.h"

#include "block/block_mmad.h"
#include "block/weight_quant_matmul_mxfp8fp4_block_scheduler_swat.h"
#include "host_utils/acl_utils.h"
#include "host_utils/common_utils.h"
#include "host_utils/io_utils.h"
#include "kernel/kernel_universal.h"
#include "policy/dispatch_policy.h"
#include "tiling/weight_quant_matmul_mxfp8fp4_tiling_swat.h"
#include "tiling/weight_quant_matmul_mxfp8fp4_tiling_data.h"
#include "utils/constant.h"
#include "utils/layout_utils.h"

namespace {

// Buffer mode is selected by the executable target, not by runtime tiling data.
constexpr uint64_t TARGET_L1_BUFFER_NUM = DB_SIZE;

struct WeightQuantMatmulMxfp8Fp4ProblemShape {
    uint64_t m{0};
    uint64_t n{0};
    uint64_t k{0};
};

template <class DispatchPolicy>
__global__ __aicore__ __mix__(1, 2) void WeightQuantMatmulMxfp8Fp4KernelEntry(
    GM_ADDR dA, GM_ADDR dB, GM_ADDR dScaleA, GM_ADDR dScaleB, GM_ADDR dC,
    const WeightQuantMatmulMxfp8Fp4TilingData tilingData)
{
    using TypeA = fp8_e4m3fn_t;
    using TypeB = fp4x2_e2m1_t;
    using TypeC = bfloat16_t;
    using TypeScaleA = fp8_e8m0_t;
    using TypeScaleB = fp8_e8m0_t;
    using LayoutA = AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>;
    using LayoutB = MatmulRecipe::Weight4BitNzLayout<TypeA>;
    using LayoutC = AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>;
    using LayoutScaleA = AscendC::Te::FrameLayoutFormat<AscendC::Te::ScaleANDLayoutPtn, AscendC::Std::Int<2>>;
    using LayoutScaleB = AscendC::Te::FrameLayoutFormat<AscendC::Te::ScaleBDNLayoutPtn, AscendC::Std::Int<2>>;
    using ProblemShape = WeightQuantMatmulMxfp8Fp4ProblemShape;
    using BlockMmad = Block::BlockMmad<
        DispatchPolicy, AscendC::Std::tuple<TypeA, TypeScaleA>, AscendC::Std::tuple<LayoutA, LayoutScaleA>,
        AscendC::Std::tuple<TypeB, TypeScaleB>, AscendC::Std::tuple<LayoutB, LayoutScaleB>, TypeC, LayoutC>;
    using BlockEpilogue = void;
    using BlockScheduler = Block::WeightQuantMatmulMxfp8Fp4SwatScheduler;
    using KernelImpl = Kernel::GemmUniversal<ProblemShape, BlockMmad, BlockEpilogue, BlockScheduler>;

    typename KernelImpl::Params params{
        {tilingData.m, tilingData.n, tilingData.k},
        {dA, dB, dScaleA, dScaleB, dC,
         AscendC::Te::MakeShape(
             static_cast<int64_t>(tilingData.baseM), static_cast<int64_t>(tilingData.baseN),
             static_cast<int64_t>(tilingData.tileShapeKL1), static_cast<int64_t>(tilingData.tileShapeScaleKL1)),
         AscendC::Te::MakeShape(
             static_cast<int64_t>(tilingData.baseM), static_cast<int64_t>(tilingData.baseN),
             static_cast<int64_t>(tilingData.baseK)),
         tilingData.kBubSize, tilingData.nBubSize},
        {AscendC::Te::MakeShape(
             static_cast<int64_t>(tilingData.m), static_cast<int64_t>(tilingData.n),
             static_cast<int64_t>(tilingData.k)),
         AscendC::Te::MakeShape(
             static_cast<int64_t>(tilingData.baseM), static_cast<int64_t>(tilingData.baseN),
             static_cast<int64_t>(tilingData.k), static_cast<int64_t>(1)),
         tilingData.mTailTile, tilingData.nTailTile, tilingData.mBaseTailSplitCnt, tilingData.nBaseTailSplitCnt,
         tilingData.mTailMain, tilingData.nTailMain}};
    KernelImpl::Run(params);
}

void LaunchWeightQuantMatmulMxfp8Fp4Kernel(
    uint8_t* dA, uint8_t* dB, uint8_t* dScaleA, uint8_t* dScaleB, uint8_t* dC,
    const WeightQuantMatmulMxfp8Fp4TilingData& tilingData, aclrtStream stream)
{
    using DispatchPolicy = WeightQuantMatmulMxfp8Fp4DispatchPolicy<TARGET_L1_BUFFER_NUM>;
    WeightQuantMatmulMxfp8Fp4KernelEntry<DispatchPolicy>
        <<<tilingData.usedCoreNum, nullptr, stream>>>(dA, dB, dScaleA, dScaleB, dC, tilingData);
}

void PrintMxfp8Fp4Usage(const std::string& programName)
{
    std::cerr << "Usage: " << programName << " m k n" << std::endl;
    std::cerr << "Args: " << std::endl;
    std::cerr << "  m: row of matrix A" << std::endl;
    std::cerr << "  k: col of matrix A" << std::endl;
    std::cerr << "  n: col of matrix B" << std::endl;
    std::cerr << "Example: " << programName << " 256 1024 256" << std::endl;
}

void ParseMxfp8Fp4Arguments(int argc, char* argv[], uint64_t& m, uint64_t& k, uint64_t& n)
{
    if (argc >= 2 && (std::string(argv[1]) == "--help" || std::string(argv[1]) == "-h")) {
        PrintMxfp8Fp4Usage(argv[0]);
        std::exit(1);
    }
    if (argc != 4) {
        throw std::invalid_argument("ERROR: Invalid number of arguments, expected: m k n");
    }
    m = ParsePositiveUint64(argv[1], "m");
    k = ParsePositiveUint64(argv[2], "k");
    n = ParsePositiveUint64(argv[3], "n");
    CheckUint32Shape(m, "m");
    CheckUint32Shape(k, "k");
    CheckUint32Shape(n, "n");
}

} // namespace

int main(int argc, char* argv[])
{
    uint64_t m = 0;
    uint64_t k = 0;
    uint64_t n = 0;
    try {
        ParseMxfp8Fp4Arguments(argc, argv, m, k, n);
        CHECK_COND((k % 64U) == 0U, "k must be a multiple of 64.");
        CHECK_COND((n % 16U) == 0U, "n must be a multiple of 16 for fixed NZ weight layout.");
    } catch (const std::exception& e) {
        std::cerr << e.what() << std::endl;
        PrintMxfp8Fp4Usage(argv[0]);
        return 1;
    }

    constexpr int32_t deviceId = 0;

    try {
        WeightQuantMatmulMxfp8Fp4TilingData tilingData;
        WeightQuantMatmulMxfp8Fp4SwatTiling tilingEngine(TARGET_L1_BUFFER_NUM);
        tilingEngine.GetTilingData(m, n, k, tilingData);

        ExampleIoPaths paths = GetExampleIoPaths();
        AclRtSession aclSession(deviceId);
        aclSession.Init();
        aclrtStream stream = aclSession.GetStream();

        uint64_t k1 = CeilDiv<uint64_t>(k, 32UL);
        uint64_t n1 = CeilDiv<uint64_t>(n, 16UL);
        uint64_t scaleK = CeilDiv<uint64_t>(Align<uint64_t>(k, 64UL), 32UL);

        size_t sizeA = m * k * sizeof(uint8_t);
        size_t sizeB = k1 * n1 * 16UL * 16UL * sizeof(uint8_t);
        size_t sizeScaleA = m * scaleK * sizeof(uint8_t);
        size_t sizeScaleB = n * scaleK * sizeof(uint8_t);
        size_t sizeC = m * n * sizeof(uint16_t);

        uint8_t* hA = nullptr;
        uint8_t* hB = nullptr;
        uint8_t* hScaleA = nullptr;
        uint8_t* hScaleB = nullptr;
        uint16_t* hC = nullptr;

        CHECK_COND(
            aclrtMallocHost((void**)&hA, sizeA) == ACL_SUCCESS, "Failed to allocate the host buffer for input A.");
        std::unique_ptr<void, aclError (*)(void*)> hostA(hA, aclrtFreeHost);
        CHECK_COND(
            aclrtMallocHost((void**)&hB, sizeB) == ACL_SUCCESS, "Failed to allocate the host buffer for input B.");
        std::unique_ptr<void, aclError (*)(void*)> hostB(hB, aclrtFreeHost);
        CHECK_COND(
            aclrtMallocHost((void**)&hScaleA, sizeScaleA) == ACL_SUCCESS,
            "Failed to allocate the host buffer for scaleA.");
        std::unique_ptr<void, aclError (*)(void*)> hostScaleA(hScaleA, aclrtFreeHost);
        CHECK_COND(
            aclrtMallocHost((void**)&hScaleB, sizeScaleB) == ACL_SUCCESS,
            "Failed to allocate the host buffer for scaleB.");
        std::unique_ptr<void, aclError (*)(void*)> hostScaleB(hScaleB, aclrtFreeHost);
        CHECK_COND(
            aclrtMallocHost((void**)&hC, sizeC) == ACL_SUCCESS, "Failed to allocate the host buffer for output C.");
        std::unique_ptr<void, aclError (*)(void*)> hostC(hC, aclrtFreeHost);

        CHECK_COND(ReadExactFile(paths.inputDir + "/input_a.bin", hA, sizeA), "Failed to read input_a.bin.");
        CHECK_COND(ReadExactFile(paths.inputDir + "/input_b.bin", hB, sizeB), "Failed to read input_b.bin.");
        CHECK_COND(
            ReadExactFile(paths.inputDir + "/input_scaleA.bin", hScaleA, sizeScaleA),
            "Failed to read input_scaleA.bin.");
        CHECK_COND(
            ReadExactFile(paths.inputDir + "/input_scaleB.bin", hScaleB, sizeScaleB),
            "Failed to read input_scaleB.bin.");

        void* dAPtr = nullptr;
        void* dBPtr = nullptr;
        void* dScaleAPtr = nullptr;
        void* dScaleBPtr = nullptr;
        void* dCPtr = nullptr;

        CHECK_COND(aclrtMalloc(&dAPtr, sizeA, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS, "Failed to allocate device A.");
        std::unique_ptr<void, aclError (*)(void*)> deviceA(dAPtr, aclrtFree);
        CHECK_COND(aclrtMalloc(&dBPtr, sizeB, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS, "Failed to allocate device B.");
        std::unique_ptr<void, aclError (*)(void*)> deviceB(dBPtr, aclrtFree);
        CHECK_COND(
            aclrtMalloc(&dScaleAPtr, sizeScaleA, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
            "Failed to allocate device scaleA.");
        std::unique_ptr<void, aclError (*)(void*)> deviceScaleA(dScaleAPtr, aclrtFree);
        CHECK_COND(
            aclrtMalloc(&dScaleBPtr, sizeScaleB, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
            "Failed to allocate device scaleB.");
        std::unique_ptr<void, aclError (*)(void*)> deviceScaleB(dScaleBPtr, aclrtFree);
        CHECK_COND(aclrtMalloc(&dCPtr, sizeC, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS, "Failed to allocate device C.");
        std::unique_ptr<void, aclError (*)(void*)> deviceC(dCPtr, aclrtFree);

        uint8_t* dA = reinterpret_cast<uint8_t*>(dAPtr);
        uint8_t* dB = reinterpret_cast<uint8_t*>(dBPtr);
        uint8_t* dScaleA = reinterpret_cast<uint8_t*>(dScaleAPtr);
        uint8_t* dScaleB = reinterpret_cast<uint8_t*>(dScaleBPtr);
        uint8_t* dC = reinterpret_cast<uint8_t*>(dCPtr);

        CHECK_COND(
            aclrtMemcpyAsync(dA, sizeA, hA, sizeA, ACL_MEMCPY_HOST_TO_DEVICE, stream) == ACL_SUCCESS,
            "Failed to copy input A to device.");
        CHECK_COND(
            aclrtMemcpyAsync(dB, sizeB, hB, sizeB, ACL_MEMCPY_HOST_TO_DEVICE, stream) == ACL_SUCCESS,
            "Failed to copy input B to device.");
        CHECK_COND(
            aclrtMemcpyAsync(dScaleA, sizeScaleA, hScaleA, sizeScaleA, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                ACL_SUCCESS,
            "Failed to copy scaleA to device.");
        CHECK_COND(
            aclrtMemcpyAsync(dScaleB, sizeScaleB, hScaleB, sizeScaleB, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                ACL_SUCCESS,
            "Failed to copy scaleB to device.");
        CHECK_COND(aclrtMemset(dC, sizeC, 0, sizeC) == ACL_SUCCESS, "Failed to memset output C.");

        LaunchWeightQuantMatmulMxfp8Fp4Kernel(dA, dB, dScaleA, dScaleB, dC, tilingData, stream);

        CHECK_COND(aclrtSynchronizeStream(stream) == ACL_SUCCESS, "Failed to synchronize the ACL stream.");
        CHECK_COND(
            aclrtMemcpy(hC, sizeC, dC, sizeC, ACL_MEMCPY_DEVICE_TO_HOST) == ACL_SUCCESS,
            "Failed to copy output C to host.");
        CHECK_COND(WriteFile(paths.outputDir + "/npu_out.bin", hC, sizeC), "Failed to write npu_out.bin.");

        std::string cmd =
            "cd \"" + paths.baseDir + "\" && python3 verify_result.py " + std::to_string(m) + " " + std::to_string(n);
        if (std::system(cmd.c_str()) != 0) {
            return 1;
        }
        return 0;
    } catch (const std::exception& e) {
        std::cerr << e.what() << std::endl;
        return 1;
    }
}
