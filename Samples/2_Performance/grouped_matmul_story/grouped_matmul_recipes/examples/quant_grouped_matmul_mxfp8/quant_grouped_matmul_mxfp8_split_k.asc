/*!
 * \file quant_grouped_matmul_mxfp8_split_k.cpp
 * \brief Minimal launcher for the grouped MXFP8 split-K recipe.
 */

#include <cstdint>
#include <cstdlib>
#include <exception>
#include <iostream>
#include <limits>
#include <numeric>
#include <string>
#include <vector>

#include "acl/acl.h"
#include "kernel_operator.h"

#include "host_utils/acl_utils.h"
#include "host_utils/common_utils.h"
#include "host_utils/io_utils.h"
#include "block/block_mmad.h"
#include "kernel/quant_grouped_matmul_mx_kernel.h"
#include "tiling/quant_grouped_matmul_mx_tiling_data.h"
#include "tiling/quant_grouped_matmul_mx_tiling.h"
#include "utils/grouped_matmul_constant.h"

namespace {

GroupedMatmulMxfp8Args ParseSplitKArguments(int argc, char* argv[])
{
    if (argc != 5 && argc != 7) {
        throw std::invalid_argument(
            "ERROR: Invalid number of arguments, expected: group_num m k n [transA transB]");
    }

    GroupedMatmulMxfp8Args args{
        ParsePositiveUint64(argv[1], "group_num"),
        ParsePositiveUint64(argv[2], "m"),
        ParsePositiveUint64(argv[3], "k"),
        ParsePositiveUint64(argv[4], "n"),
        true,
        false,
        0U};

    if (argc == 7) {
        args.transA = ParseBoolArg(argv[5], "transA");
        args.transB = ParseBoolArg(argv[6], "transB");
    }

    constexpr uint64_t int32MaxU64 = static_cast<uint64_t>(std::numeric_limits<int32_t>::max());
    CHECK_COND(args.m <= int32MaxU64, "m must not exceed INT32_MAX.");
    CHECK_COND(args.k <= int32MaxU64, "k must not exceed INT32_MAX.");
    CHECK_COND(args.n <= int32MaxU64, "n must not exceed INT32_MAX.");
    CHECK_COND(args.transA && !args.transB, "MXFP8 K-axis grouping requires transA=true and transB=false.");
    CHECK_COND(
        args.groupNum <= static_cast<uint64_t>(std::numeric_limits<size_t>::max()),
        "group_num exceeds addressable size on this platform.");
    CHECK_COND(
        args.groupNum <= static_cast<uint64_t>(std::numeric_limits<size_t>::max()) / sizeof(int64_t),
        "group list byte size exceeds addressable size on this platform.");
    args.groupListBytes = static_cast<size_t>(args.groupNum * sizeof(int64_t));
    return args;
}

void PrintSplitKUsage(const char* program)
{
    std::cerr << "Usage: " << program << " group_num m k n [transA transB]" << std::endl;
    std::cerr << "Args:" << std::endl;
    std::cerr << "  group_num: number of K-axis groups" << std::endl;
    std::cerr << "  m: common M size for each group" << std::endl;
    std::cerr << "  k: total K size, must be >= sum(group_k_list)" << std::endl;
    std::cerr << "  n: common N size for each group" << std::endl;
    std::cerr << "  transA/transB: optional, must be true false for split-K" << std::endl;
    std::cerr << "Example: " << program << " 3 256 768 1024 true false" << std::endl;
}

} // namespace

__global__ __aicore__ __mix__(1, 2) void QuantGroupedMatmulMxfp8SplitKKernel(
    GM_ADDR dA, GM_ADDR dB, GM_ADDR dScaleA, GM_ADDR dScaleB, GM_ADDR groupList, GM_ADDR dC,
    const QuantGroupedMatmulMxfp8TilingData tilingData)
{
    constexpr int32_t SCALE_C0 = 2;
    using AType = fp8_e4m3fn_t;
    using BType = fp8_e4m3fn_t;
    using ScaleAType = fp8_e8m0_t;
    using ScaleBType = fp8_e8m0_t;
    using CType = bfloat16_t;
    using LayoutA = AscendC::Te::FrameLayoutFormat<AscendC::Te::DNExtLayoutPtn>;
    using LayoutB = AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>;
    using LayoutC = AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>;
    using LayoutScaleA = AscendC::Te::FrameLayoutFormat<AscendC::Te::ScaleADNLayoutPtn, AscendC::Std::Int<SCALE_C0>>;
    using LayoutScaleB = AscendC::Te::FrameLayoutFormat<AscendC::Te::ScaleBNDLayoutPtn, AscendC::Std::Int<SCALE_C0>>;

    using ProblemShape = MatmulShape;
    using DispatchPolicy = QuantMatmulMxMultiBlockMmad;
    using BlockMmad = Block::BlockMmad<
        DispatchPolicy, AscendC::Std::tuple<AType, ScaleAType>, AscendC::Std::tuple<LayoutA, LayoutScaleA>,
        AscendC::Std::tuple<BType, ScaleBType>, AscendC::Std::tuple<LayoutB, LayoutScaleB>, CType, LayoutC>;
    using BlockScheduler = Block::BlockSchedulerGmmAswtWithTailSplit;
    using GroupedKernel = Kernel::QuantGroupedMatmulMxfp8KernelSplitM<ProblemShape, BlockMmad, BlockScheduler>;
    using Params = typename GroupedKernel::Params;
    using SchedulerParams = typename BlockScheduler::Params;

    Params params = {
        {static_cast<int64_t>(tilingData.m), static_cast<int64_t>(tilingData.n), static_cast<int64_t>(tilingData.k), 1},
        {dA, dB, dScaleA, dScaleB, dC},
        SchedulerParams{
            static_cast<int32_t>(tilingData.baseM),
            static_cast<int32_t>(tilingData.baseN),
        },
        {
            tilingData.groupNum,
            tilingData.m,
            tilingData.n,
            tilingData.k,
            tilingData.baseM,
            tilingData.baseN,
            tilingData.baseK,
            tilingData.kAL1,
            tilingData.kBL1,
            tilingData.scaleKAL1,
            tilingData.dbL0C,
        },
        groupList,
    };
    GroupedKernel kernel;
    kernel(params);
}

int main(int argc, char* argv[])
{
    GroupedMatmulMxfp8Args args{};
    try {
        args = ParseSplitKArguments(argc, argv);
    } catch (const std::exception& ex) {
        std::cerr << ex.what() << std::endl;
        PrintSplitKUsage(argv[0]);
        return 1;
    }

    constexpr int32_t deviceId = 0;

    try {
        std::string baseDir = GetExecutableDir();
        CHECK_COND(chdir(baseDir.c_str()) == 0, "Failed to switch to the executable directory.");
        uint64_t groupNum = args.groupNum;
        uint64_t m = args.m;
        uint64_t k = args.k;
        uint64_t n = args.n;
        const size_t groupListBytes = args.groupListBytes;
        std::string inputDir = "./input";
        std::string outputDir = "./output";
        std::vector<int64_t> groupListHost(static_cast<size_t>(groupNum), 0);

        size_t groupListFileSize = groupListBytes;
        CHECK_COND(
            ReadFile(inputDir + "/input_groupList.bin", groupListFileSize, groupListHost.data(), groupListBytes),
            "Failed to read input_groupList.bin.");
        CHECK_COND(
            groupListFileSize == groupListBytes, "input_groupList.bin size does not match the expected tensor size.");

        std::vector<uint32_t> groupKList = ParseGroupList(groupListHost);
        uint64_t sumGroupK = std::accumulate(groupKList.begin(), groupKList.end(), 0ULL);
        CHECK_COND(sumGroupK <= k, "k must be greater than or equal to sum(group_k_list).");

        QuantGroupedMatmulMxfp8TilingData tilingData;
        QuantGroupedMatmulMxTiling<gmm::DataType::DT_FLOAT8_E4M3FN> tiler;
        tiler.GetTilingData(static_cast<uint32_t>(groupKList.size()), static_cast<uint32_t>(m),
                            static_cast<uint32_t>(n), static_cast<uint32_t>(k), true, false, tilingData);

        uint64_t scaleK =
            (k / GroupedMatmulRecipe::MX_DIVISOR_SIZE + groupNum) * GroupedMatmulRecipe::MX_MULTI_SIZE;
        size_t xByteSize = (m * k) * sizeof(uint8_t);
        size_t weightByteSize = (n * k) * sizeof(uint8_t);
        size_t xScaleByteSize = m * scaleK * sizeof(uint8_t);
        size_t weightScaleByteSize = n * scaleK * sizeof(uint8_t);
        size_t yByteSize = static_cast<uint64_t>(groupKList.size()) * m * n * sizeof(uint16_t);

        std::vector<uint8_t> hostX(xByteSize, 0);
        std::vector<uint8_t> hostWeight(weightByteSize, 0);
        std::vector<uint8_t> hostXScale(xScaleByteSize, 0);
        std::vector<uint8_t> hostWeightScale(weightScaleByteSize, 0);
        std::vector<uint8_t> hostY(yByteSize, 0);
        size_t xFileSize = xByteSize;
        size_t weightFileSize = weightByteSize;
        size_t xScaleFileSize = xScaleByteSize;
        size_t weightScaleFileSize = weightScaleByteSize;

        CHECK_COND(ReadFile(inputDir + "/input_a.bin", xFileSize, hostX.data(), xByteSize), "Failed to read input_a.bin.");
        CHECK_COND(xFileSize == xByteSize, "input_a.bin size does not match the expected tensor size.");
        CHECK_COND(
            ReadFile(inputDir + "/input_b.bin", weightFileSize, hostWeight.data(), weightByteSize),
            "Failed to read input_b.bin.");
        CHECK_COND(weightFileSize == weightByteSize, "input_b.bin size does not match the expected tensor size.");
        CHECK_COND(
            ReadFile(inputDir + "/input_scaleA.bin", xScaleFileSize, hostXScale.data(), xScaleByteSize),
            "Failed to read input_scaleA.bin.");
        CHECK_COND(xScaleFileSize == xScaleByteSize, "input_scaleA.bin size does not match the expected tensor size.");
        CHECK_COND(
            ReadFile(inputDir + "/input_scaleB.bin", weightScaleFileSize, hostWeightScale.data(), weightScaleByteSize),
            "Failed to read input_scaleB.bin.");
        CHECK_COND(
            weightScaleFileSize == weightScaleByteSize, "input_scaleB.bin size does not match the expected tensor size.");

        AclRtSession aclSession(deviceId);
        aclSession.Init();

        {
            AclDeviceBuffers dBuffers;
            GM_ADDR dA = nullptr;
            GM_ADDR dB = nullptr;
            GM_ADDR dScaleA = nullptr;
            GM_ADDR dScaleB = nullptr;
            GM_ADDR dGroupList = nullptr;
            GM_ADDR dC = nullptr;
            CHECK_COND(aclrtMalloc(reinterpret_cast<void**>(&dA), xByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                       "Failed to allocate device X.");
            dBuffers.Push(dA);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dB), weightByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                "Failed to allocate device weight.");
            dBuffers.Push(dB);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dScaleA), xScaleByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                "Failed to allocate device xScale.");
            dBuffers.Push(dScaleA);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dScaleB), weightScaleByteSize, ACL_MEM_MALLOC_HUGE_ONLY) ==
                    ACL_SUCCESS,
                "Failed to allocate device weightScale.");
            dBuffers.Push(dScaleB);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dGroupList), groupListBytes, ACL_MEM_MALLOC_HUGE_ONLY) ==
                    ACL_SUCCESS,
                "Failed to allocate device groupList.");
            dBuffers.Push(dGroupList);
            CHECK_COND(aclrtMalloc(reinterpret_cast<void**>(&dC), yByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                       "Failed to allocate device Y.");
            dBuffers.Push(dC);
            CHECK_COND(aclrtMemset(dC, yByteSize, 0, yByteSize) == ACL_SUCCESS, "Failed to memset Y.");

            aclrtStream stream = aclSession.GetStream();
            CHECK_COND(
                aclrtMemcpyAsync(dA, xByteSize, hostX.data(), xByteSize, ACL_MEMCPY_HOST_TO_DEVICE, stream) == ACL_SUCCESS,
                "Failed to copy X to device.");
            CHECK_COND(
                aclrtMemcpyAsync(dB, weightByteSize, hostWeight.data(), weightByteSize, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                    ACL_SUCCESS,
                "Failed to copy weight to device.");
            CHECK_COND(
                aclrtMemcpyAsync(dScaleA, xScaleByteSize, hostXScale.data(), xScaleByteSize, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                    ACL_SUCCESS,
                "Failed to copy xScale to device.");
            CHECK_COND(
                aclrtMemcpyAsync(
                    dScaleB, weightScaleByteSize, hostWeightScale.data(), weightScaleByteSize, ACL_MEMCPY_HOST_TO_DEVICE,
                    stream) == ACL_SUCCESS,
                "Failed to copy weightScale to device.");
            CHECK_COND(
                aclrtMemcpyAsync(
                    dGroupList, groupListBytes, groupListHost.data(), groupListBytes, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                    ACL_SUCCESS,
                "Failed to copy groupList to device.");

            QuantGroupedMatmulMxfp8SplitKKernel
                <<<tilingData.usedCoreNum, nullptr, stream>>>(dA, dB, dScaleA, dScaleB, dGroupList, dC, tilingData);
            CHECK_COND(aclrtSynchronizeStream(stream) == ACL_SUCCESS, "Failed to synchronize stream.");
            CHECK_COND(
                aclrtMemcpy(hostY.data(), yByteSize, dC, yByteSize, ACL_MEMCPY_DEVICE_TO_HOST) == ACL_SUCCESS,
                "Failed to copy Y back to host.");
            CHECK_COND(WriteFile(outputDir + "/npu_out.bin", hostY.data(), yByteSize), "Failed to write npu_out.bin.");
        }
        std::string cmd = "cd \"" + baseDir + "\" && python3 verify_result.py " + std::to_string(groupNum) + " " +
                          std::to_string(m) + " " + std::to_string(k) + " " + std::to_string(n) + " true false";
        if (std::system(cmd.c_str()) != 0) {
            return 1;
        }
        return 0;
    } catch (const std::exception& ex) {
        std::cerr << ex.what() << std::endl;
        return 1;
    }
}
