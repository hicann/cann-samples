/*!
 * \file quant_grouped_matmul_hif8_tt.asc
 * \brief Grouped HiFloat8 split-M sample with per-group twin scalar FP32 scales.
 */

#include <cstdint>
#include <cstdlib>
#include <exception>
#include <iostream>
#include <numeric>
#include <string>
#include <type_traits>
#include <vector>

#include "acl/acl.h"
#include "kernel_operator.h"

#include "block/block_mmad.h"
#include "host_utils/acl_utils.h"
#include "host_utils/common_utils.h"
#include "host_utils/io_utils.h"
#include "kernel/quant_grouped_matmul_hif8_kernel.h"
#include "policy/dispatch_policy.h"
#include "tiling/quant_grouped_matmul_hif8_tiling.h"
#include "tiling/quant_grouped_matmul_hif8_tiling_data.h"

template <bool TransB>
__global__ __aicore__ __cube__ void QuantGroupedMatmulHif8TtKernel(
    GM_ADDR dA, GM_ADDR dB, GM_ADDR dScaleA, GM_ADDR dScaleB, GM_ADDR groupList, GM_ADDR dC,
    const QuantGroupedMatmulHif8TilingData tilingData)
{
    using AType = hifloat8_t;
    using BType = hifloat8_t;
    using CType = bfloat16_t;
    using LayoutA = AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>;
    using LayoutB = typename AscendC::Std::conditional_t<
        TransB, AscendC::Te::FrameLayoutFormat<AscendC::Te::DNExtLayoutPtn>,
        AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>>;
    using LayoutC = AscendC::Te::FrameLayoutFormat<AscendC::Te::NDExtLayoutPtn>;
    using DispatchPolicy = QuantGroupedMatmulBlockMmad;
    using BlockMmad = Block::BlockMmad<DispatchPolicy, AType, LayoutA, BType, LayoutB, CType, LayoutC>;
    using BlockScheduler = Block::BlockSchedulerGmmAswtWithTailSplit;
    using GroupedKernel = Kernel::QuantGroupedMatmulHif8KernelSplitM<MatmulShape, BlockMmad, BlockScheduler>;
    using Params = typename GroupedKernel::Params;
    using SchedulerParams = typename BlockScheduler::Params;

    Params params = {
        {static_cast<int64_t>(tilingData.m), static_cast<int64_t>(tilingData.n), static_cast<int64_t>(tilingData.k), 1},
        {dA, dB, dScaleA, dScaleB, dC},
        SchedulerParams{static_cast<int32_t>(tilingData.baseM), static_cast<int32_t>(tilingData.baseN)},
        {
            tilingData.groupNum,
            tilingData.m,
            tilingData.n,
            tilingData.k,
            tilingData.baseM,
            tilingData.baseN,
            tilingData.baseK,
            tilingData.kAL1,
            tilingData.kBL1,
            tilingData.nBufferNum,
            tilingData.dbL0C,
            tilingData.x1QuantMode,
            tilingData.x2QuantMode,
        },
        groupList,
    };
    GroupedKernel kernel;
    kernel(params);
}

int main(int argc, char* argv[])
{
    GroupedMatmulHif8Args args{};
    try {
        args = ParseArguments(argc, argv);
    } catch (const std::exception& ex) {
        std::cerr << ex.what() << std::endl;
        PrintUsage(argv[0]);
        return 1;
    }

    constexpr int32_t deviceId = 0;
    try {
        std::string baseDir = GetExecutableDir();
        CHECK_COND(chdir(baseDir.c_str()) == 0, "Failed to switch to the executable directory.");
        const uint64_t groupNum = args.groupNum;
        const uint64_t m = args.m;
        const uint64_t k = args.k;
        const uint64_t n = args.n;
        const bool transB = args.transB;
        const size_t groupListBytes = args.groupListBytes;
        const std::string inputDir = "./input";
        const std::string outputDir = "./output";

        std::vector<int64_t> groupListHost(static_cast<size_t>(groupNum), 0);
        size_t groupListFileSize = groupListBytes;
        CHECK_COND(
            ReadFile(inputDir + "/input_groupList.bin", groupListFileSize, groupListHost.data(), groupListBytes),
            "Failed to read input_groupList.bin.");
        CHECK_COND(groupListFileSize == groupListBytes, "input_groupList.bin size mismatch.");
        std::vector<uint32_t> groupMList = ParseGroupList(groupListHost);
        uint64_t sumGroupM = std::accumulate(groupMList.begin(), groupMList.end(), 0ULL);
        CHECK_COND(sumGroupM <= m, "m must be greater than or equal to sum(group_m_list).");

        QuantGroupedMatmulHif8TilingData tilingData{};
        QuantGroupedMatmulHif8Config cfg{};
        cfg.x1QuantMode = hif8::KERNEL_QUANT_PERTENSOR;
        cfg.x2QuantMode = hif8::KERNEL_QUANT_PERTENSOR;
        cfg.scaleDtypeSize = sizeof(float);
        QuantGroupedMatmulHif8Tiling tiler;
        tiler.SetQuantConfig(cfg);
        tiler.GetTilingData(
            static_cast<uint32_t>(groupMList.size()), static_cast<uint32_t>(m), static_cast<uint32_t>(n),
            static_cast<uint32_t>(k), false, transB, tilingData);

        size_t xByteSize = m * k * sizeof(uint8_t);
        size_t weightByteSize = groupNum * n * k * sizeof(uint8_t);
        size_t scaleByteSize = groupNum * sizeof(float);
        size_t yByteSize = m * n * sizeof(uint16_t);

        std::vector<uint8_t> hostX(xByteSize, 0);
        std::vector<uint8_t> hostWeight(weightByteSize, 0);
        std::vector<uint8_t> hostScaleA(scaleByteSize, 0);
        std::vector<uint8_t> hostScaleB(scaleByteSize, 0);
        std::vector<uint8_t> hostY(yByteSize, 0);
        size_t fileSize = xByteSize;
        CHECK_COND(ReadFile(inputDir + "/x1.bin", fileSize, hostX.data(), xByteSize), "Failed to read x1.bin.");
        CHECK_COND(fileSize == xByteSize, "x1.bin size mismatch.");
        fileSize = weightByteSize;
        CHECK_COND(
            ReadFile(inputDir + "/x2.bin", fileSize, hostWeight.data(), weightByteSize), "Failed to read x2.bin.");
        CHECK_COND(fileSize == weightByteSize, "x2.bin size mismatch.");
        fileSize = scaleByteSize;
        CHECK_COND(
            ReadFile(inputDir + "/pertoken_scale.bin", fileSize, hostScaleA.data(), scaleByteSize),
            "Failed to read pertoken_scale.bin.");
        CHECK_COND(fileSize == scaleByteSize, "pertoken_scale.bin size mismatch.");
        fileSize = scaleByteSize;
        CHECK_COND(
            ReadFile(inputDir + "/scale.bin", fileSize, hostScaleB.data(), scaleByteSize), "Failed to read scale.bin.");
        CHECK_COND(fileSize == scaleByteSize, "scale.bin size mismatch.");

        AclRtSession aclSession(deviceId);
        aclSession.Init();
        aclrtStream stream = aclSession.GetStream();

        for (int32_t i = 0; i < GroupedMatmulRecipe::EXAMPLE_KERNEL_RUN_COUNT; i++) {
            AclDeviceBuffers dBuffers;
            GM_ADDR dA = nullptr;
            GM_ADDR dB = nullptr;
            GM_ADDR dScaleA = nullptr;
            GM_ADDR dScaleB = nullptr;
            GM_ADDR dGroupList = nullptr;
            GM_ADDR dC = nullptr;
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dA), xByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                "Failed to allocate device X.");
            dBuffers.Push(dA);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dB), weightByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                "Failed to allocate device weight.");
            dBuffers.Push(dB);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dScaleA), scaleByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                "Failed to allocate device x scale.");
            dBuffers.Push(dScaleA);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dScaleB), scaleByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                "Failed to allocate device weight scale.");
            dBuffers.Push(dScaleB);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dGroupList), groupListBytes, ACL_MEM_MALLOC_HUGE_ONLY) ==
                    ACL_SUCCESS,
                "Failed to allocate device groupList.");
            dBuffers.Push(dGroupList);
            CHECK_COND(
                aclrtMalloc(reinterpret_cast<void**>(&dC), yByteSize, ACL_MEM_MALLOC_HUGE_ONLY) == ACL_SUCCESS,
                "Failed to allocate device Y.");
            dBuffers.Push(dC);
            CHECK_COND(aclrtMemset(dC, yByteSize, 0, yByteSize) == ACL_SUCCESS, "Failed to memset Y.");

            CHECK_COND(
                aclrtMemcpyAsync(dA, xByteSize, hostX.data(), xByteSize, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                    ACL_SUCCESS,
                "Failed to copy X to device.");
            CHECK_COND(
                aclrtMemcpyAsync(
                    dB, weightByteSize, hostWeight.data(), weightByteSize, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                    ACL_SUCCESS,
                "Failed to copy weight to device.");
            CHECK_COND(
                aclrtMemcpyAsync(
                    dScaleA, scaleByteSize, hostScaleA.data(), scaleByteSize, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                    ACL_SUCCESS,
                "Failed to copy x scale to device.");
            CHECK_COND(
                aclrtMemcpyAsync(
                    dScaleB, scaleByteSize, hostScaleB.data(), scaleByteSize, ACL_MEMCPY_HOST_TO_DEVICE, stream) ==
                    ACL_SUCCESS,
                "Failed to copy weight scale to device.");
            CHECK_COND(
                aclrtMemcpyAsync(
                    dGroupList, groupListBytes, groupListHost.data(), groupListBytes, ACL_MEMCPY_HOST_TO_DEVICE,
                    stream) == ACL_SUCCESS,
                "Failed to copy groupList to device.");

            if (transB) {
                QuantGroupedMatmulHif8TtKernel<true>
                    <<<tilingData.usedCoreNum, nullptr, stream>>>(dA, dB, dScaleA, dScaleB, dGroupList, dC, tilingData);
            } else {
                QuantGroupedMatmulHif8TtKernel<false>
                    <<<tilingData.usedCoreNum, nullptr, stream>>>(dA, dB, dScaleA, dScaleB, dGroupList, dC, tilingData);
            }
            CHECK_COND(
                aclrtMemcpyAsync(hostY.data(), yByteSize, dC, yByteSize, ACL_MEMCPY_DEVICE_TO_HOST, stream) ==
                    ACL_SUCCESS,
                "Failed to copy Y back to host.");
        }
        CHECK_COND(aclrtSynchronizeStream(stream) == ACL_SUCCESS, "Failed to synchronize stream.");
        CHECK_COND(WriteFile(outputDir + "/npu_out.bin", hostY.data(), yByteSize), "Failed to write npu_out.bin.");

        std::string cmd = "cd \"" + baseDir + "\" && python3 verify_result.py " + std::to_string(groupNum) + " " +
                          std::to_string(m) + " " + std::to_string(k) + " " + std::to_string(n);
        return std::system(cmd.c_str()) == 0 ? 0 : 1;
    } catch (const std::exception& ex) {
        std::cerr << ex.what() << std::endl;
        return 1;
    }
}
