/*!
 * \file full_load.cpp
 * \brief RegBase full-load sample for BF16 KvRmsNormRopeCache on Ascend 950.
 */

#include "basic_api/reg_compute/kernel_reg_compute_utils.h"
#include "sample_common.h"

using namespace AscendC;
using namespace KvRmsNormRopeCacheSample;

namespace {

constexpr int32_t BUFFER_NUM = 2;
constexpr int64_t BLOCK_BYTES = 32;
constexpr int64_t NUM_TWO = 2;
constexpr uint32_t VL_FP32_SIZE = 256 / sizeof(float);

static constexpr AscendC::Reg::CastTrait CAST_B16_TO_B32 = {
    AscendC::Reg::RegLayout::ZERO,
    AscendC::Reg::SatMode::UNKNOWN,
    AscendC::Reg::MaskMergeMode::ZEROING,
    AscendC::RoundMode::UNKNOWN,
};

static constexpr AscendC::Reg::CastTrait CAST_B16_TO_B32_ODD = {
    AscendC::Reg::RegLayout::ONE,
    AscendC::Reg::SatMode::UNKNOWN,
    AscendC::Reg::MaskMergeMode::ZEROING,
    AscendC::RoundMode::UNKNOWN,
};

static constexpr AscendC::Reg::CastTrait CAST_B32_TO_B16 = {
    AscendC::Reg::RegLayout::ZERO,
    AscendC::Reg::SatMode::NO_SAT,
    AscendC::Reg::MaskMergeMode::ZEROING,
    AscendC::RoundMode::CAST_RINT,
};

__aicore__ inline int64_t AlignBytes(int64_t elementNum, int64_t bytes)
{
    return (elementNum * bytes + BLOCK_BYTES - 1) / BLOCK_BYTES * BLOCK_BYTES;
}

template <typename T>
class KvRmsNormRopeCacheRegBaseFullLoad {
public:
    __aicore__ inline void Init(
        __gm__ T *kv, __gm__ T *gamma, __gm__ T *cos, __gm__ T *sin, __gm__ int64_t *index, __gm__ T *kCache,
        __gm__ T *vCache, __gm__ T *kOut, __gm__ T *vOut, KvRmsNormRopeCacheSampleTilingData *tiling)
    {
        tiling_ = tiling;
        blockIdx_ = GetBlockIdx();
        totalRows_ = tiling_->batchSize * tiling_->numHead * tiling_->seqLength;
        currentBlockRows_ = tiling_->blockFactor;
        int64_t blockStart = blockIdx_ * tiling_->blockFactor;
        if (blockStart + currentBlockRows_ > totalRows_) {
            currentBlockRows_ = totalRows_ - blockStart;
        }

        kvGm_.SetGlobalBuffer(kv + blockStart * (tiling_->dv + tiling_->dk));
        gammaGm_.SetGlobalBuffer(gamma);
        cosGm_.SetGlobalBuffer(cos + blockStart * tiling_->dk);
        sinGm_.SetGlobalBuffer(sin + blockStart * tiling_->dk);
        indexGm_.SetGlobalBuffer(index + blockStart);
        kCacheGm_.SetGlobalBuffer(kCache);
        vCacheGm_.SetGlobalBuffer(vCache);
        kOutGm_.SetGlobalBuffer(kOut + blockStart * tiling_->dk);
        vOutGm_.SetGlobalBuffer(vOut + blockStart * tiling_->dv);

        ubFactor_ = tiling_->ubFactor;
        ubLoop_ = (currentBlockRows_ + ubFactor_ - 1) / ubFactor_;
        dvLoop_ = static_cast<uint16_t>((tiling_->dv + VL_FP32_SIZE - 1) / VL_FP32_SIZE);

        pipe_.InitBuffer(gammaQueue_, 1, AlignBytes(tiling_->dv, sizeof(T)));
        pipe_.InitBuffer(inQueue_, BUFFER_NUM, ubFactor_ * AlignBytes(tiling_->dv + tiling_->dk, sizeof(T)));
        pipe_.InitBuffer(cosSinQueue_, BUFFER_NUM, ubFactor_ * AlignBytes(tiling_->dk * NUM_TWO, sizeof(T)));
        pipe_.InitBuffer(outQueue_, BUFFER_NUM, ubFactor_ * AlignBytes(tiling_->dv, sizeof(T)));
    }

    __aicore__ inline void Process()
    {
        LocalTensor<T> gammaLocal = gammaQueue_.AllocTensor<T>();
        DataCopy(gammaLocal, gammaGm_, tiling_->dv);
        gammaQueue_.EnQue(gammaLocal);
        gammaLocal = gammaQueue_.DeQue<T>();

        for (int64_t loopIdx = 0; loopIdx < ubLoop_; ++loopIdx) {
            int64_t rows = ubFactor_;
            if (loopIdx == ubLoop_ - 1) {
                rows = currentBlockRows_ - loopIdx * ubFactor_;
            }
            int64_t globalRow = blockIdx_ * tiling_->blockFactor + loopIdx * ubFactor_;
            ProcessTile(loopIdx, rows, globalRow, gammaLocal);
        }
        gammaQueue_.FreeTensor(gammaLocal);
    }

private:
    __aicore__ inline void ProcessTile(int64_t loopIdx, int64_t rows, int64_t globalRow, const LocalTensor<T> &gammaLocal)
    {
        LocalTensor<T> inLocal = inQueue_.AllocTensor<T>();
        LocalTensor<T> ropeLocal = inLocal;
        LocalTensor<T> xLocal = inLocal[rows * tiling_->dk];
        CopyRopeAndX(loopIdx, rows, ropeLocal, xLocal);
        inQueue_.EnQue(inLocal);
        inLocal = inQueue_.DeQue<T>();
        ropeLocal = inLocal;
        xLocal = inLocal[rows * tiling_->dk];

        LocalTensor<T> cosSinLocal = cosSinQueue_.AllocTensor<T>();
        LocalTensor<T> cosLocal = cosSinLocal;
        LocalTensor<T> sinLocal = cosSinLocal[rows * tiling_->dk];
        DataCopy(cosLocal, cosGm_[loopIdx * ubFactor_ * tiling_->dk], rows * tiling_->dk);
        DataCopy(sinLocal, sinGm_[loopIdx * ubFactor_ * tiling_->dk], rows * tiling_->dk);
        cosSinQueue_.EnQue(cosSinLocal);
        cosSinLocal = cosSinQueue_.DeQue<T>();
        cosLocal = cosSinLocal;
        sinLocal = cosSinLocal[rows * tiling_->dk];

        LocalTensor<T> outLocal = outQueue_.AllocTensor<T>();
        Rope(outLocal, ropeLocal, cosLocal, sinLocal, rows);
        outQueue_.EnQue(outLocal);
        outLocal = outQueue_.DeQue<T>();
        CopyOutK(outLocal, rows, globalRow, loopIdx);
        outQueue_.FreeTensor(outLocal);
        cosSinQueue_.FreeTensor(cosSinLocal);

        outLocal = outQueue_.AllocTensor<T>();
        RmsNorm(outLocal, xLocal, gammaLocal, rows);
        outQueue_.EnQue(outLocal);
        outLocal = outQueue_.DeQue<T>();
        CopyOutV(outLocal, rows, globalRow, loopIdx);
        outQueue_.FreeTensor(outLocal);
        inQueue_.FreeTensor(inLocal);
    }

    __aicore__ inline void CopyRopeAndX(int64_t loopIdx, int64_t rows, const LocalTensor<T> &ropeLocal,
        const LocalTensor<T> &xLocal)
    {
        DataCopyExtParams copyRopeParams{
            static_cast<uint16_t>(rows), static_cast<uint32_t>(tiling_->dk * sizeof(T)),
            static_cast<uint32_t>(tiling_->dv * sizeof(T)), 0, 0};
        DataCopyExtParams copyXParams{
            static_cast<uint16_t>(rows), static_cast<uint32_t>(tiling_->dv * sizeof(T)),
            static_cast<uint32_t>(tiling_->dk * sizeof(T)), 0, 0};
        DataCopyPadExtParams<T> padParams{false, 0, 0, static_cast<T>(0)};
        int64_t offset = loopIdx * ubFactor_ * (tiling_->dv + tiling_->dk);
        DataCopyPad(xLocal, kvGm_[offset], copyXParams, padParams);
        DataCopyPad(ropeLocal, kvGm_[offset + tiling_->dv], copyRopeParams, padParams);
    }

    __simd_vf__ inline void RmsNormVF(
        __ubuf__ T *out, __ubuf__ T *x, __ubuf__ T *gamma, uint16_t rows, uint32_t dv, uint16_t dvLoop)
    {
        AscendC::Reg::RegTensor<T> xB16;
        AscendC::Reg::RegTensor<T> gammaB16;
        AscendC::Reg::RegTensor<T> outB16;
        AscendC::Reg::RegTensor<float> xFp32;
        AscendC::Reg::RegTensor<float> gammaFp32;
        AscendC::Reg::RegTensor<float> square;
        AscendC::Reg::RegTensor<float> reduceSum;
        AscendC::Reg::RegTensor<float> one;
        AscendC::Reg::RegTensor<float> rmsValue;
        AscendC::Reg::RegTensor<float> invRms;
        AscendC::Reg::RegTensor<float> invRmsBrc;
        AscendC::Reg::RegTensor<float> norm;
        AscendC::Reg::MaskReg mask;
        AscendC::Reg::MaskReg fullMask =
            AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
        AscendC::Reg::MaskReg firstMask =
            AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::VL1>();
        AscendC::Reg::Duplicate(one, 1.0f, firstMask);
        for (uint16_t row = 0; row < rows; ++row) {
            AscendC::Reg::Duplicate(reduceSum, 0.0f);
            uint32_t remaining = dv;
            for (uint16_t i = 0; i < dvLoop; ++i) {
                mask = AscendC::Reg::UpdateMask<float>(remaining);
                AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(
                    xB16, x + row * dv + i * VL_FP32_SIZE);
                AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(xFp32, xB16, mask);
                AscendC::Reg::Mul(square, xFp32, xFp32, mask);
                AscendC::Reg::Add(reduceSum, reduceSum, square, mask);
            }
            AscendC::Reg::ReduceSum(reduceSum, reduceSum, fullMask);
            AscendC::Reg::Muls(rmsValue, reduceSum, tiling_->reciprocal, firstMask);
            AscendC::Reg::Adds(rmsValue, rmsValue, tiling_->epsilon, firstMask);
            AscendC::Reg::Sqrt(rmsValue, rmsValue, firstMask);
            AscendC::Reg::Div(invRms, one, rmsValue, firstMask);
            AscendC::Reg::Duplicate<float, AscendC::Reg::HighLowPart::LOWEST,
                AscendC::Reg::MaskMergeMode::ZEROING>(invRmsBrc, invRms, fullMask);

            remaining = dv;
            for (uint16_t i = 0; i < dvLoop; ++i) {
                mask = AscendC::Reg::UpdateMask<float>(remaining);
                AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(
                    xB16, x + row * dv + i * VL_FP32_SIZE);
                AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(
                    gammaB16, gamma + i * VL_FP32_SIZE);
                AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(xFp32, xB16, mask);
                AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(gammaFp32, gammaB16, mask);
                AscendC::Reg::Mul(norm, xFp32, invRmsBrc, mask);
                AscendC::Reg::Mul(norm, norm, gammaFp32, mask);
                AscendC::Reg::Cast<T, float, CAST_B32_TO_B16>(outB16, norm, mask);
                AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_PACK_B32>(
                    out + row * dv + i * VL_FP32_SIZE, outB16, mask);
            }
        }
    }

    __aicore__ inline void RmsNorm(
        const LocalTensor<T> &outLocal, const LocalTensor<T> &xLocal, const LocalTensor<T> &gammaLocal, int64_t rows)
    {
        __ubuf__ T *out = (__ubuf__ T *)outLocal.GetPhyAddr();
        __ubuf__ T *x = (__ubuf__ T *)xLocal.GetPhyAddr();
        __ubuf__ T *gamma = (__ubuf__ T *)gammaLocal.GetPhyAddr();
        uint16_t rowCount = static_cast<uint16_t>(rows);
        uint32_t dv = static_cast<uint32_t>(tiling_->dv);

        RmsNormVF(out, x, gamma, rowCount, dv, dvLoop_);
    }

    __aicore__ inline void Rope(
        const LocalTensor<T> &outLocal, const LocalTensor<T> &ropeLocal, const LocalTensor<T> &cosLocal,
        const LocalTensor<T> &sinLocal, int64_t rows)
    {
        __ubuf__ T *out = (__ubuf__ T *)outLocal.GetPhyAddr();
        __ubuf__ T *rope = (__ubuf__ T *)ropeLocal.GetPhyAddr();
        __ubuf__ T *cos = (__ubuf__ T *)cosLocal.GetPhyAddr();
        __ubuf__ T *sin = (__ubuf__ T *)sinLocal.GetPhyAddr();
        uint16_t rowCount = static_cast<uint16_t>(rows);
        uint32_t dk = static_cast<uint32_t>(tiling_->dk);
        uint32_t pairCount = static_cast<uint32_t>(tiling_->dk >> 1);

        RopeVF(out, out + pairCount, rope, cos, sin, cos + pairCount, sin + pairCount, rowCount, dk, pairCount);
    }

    __simd_vf__ inline void RopeVF(__ubuf__ T *outFirst, __ubuf__ T *outSecond,
        __ubuf__ T *rope, __ubuf__ T *cosFirst, __ubuf__ T *sinFirst, __ubuf__ T *cosSecond, __ubuf__ T *sinSecond,
        uint16_t rows, uint32_t dk, uint32_t pairCount)
    {
        AscendC::Reg::RegTensor<T> xB16;
        AscendC::Reg::RegTensor<T> cosB16;
        AscendC::Reg::RegTensor<T> sinB16;
        AscendC::Reg::RegTensor<T> outB16;
        AscendC::Reg::RegTensor<float> realFp32;
        AscendC::Reg::RegTensor<float> imagFp32;
        AscendC::Reg::RegTensor<float> cosFp32;
        AscendC::Reg::RegTensor<float> sinFp32;
        AscendC::Reg::RegTensor<float> mul0;
        AscendC::Reg::RegTensor<float> mul1;
        AscendC::Reg::RegTensor<float> result;
        AscendC::Reg::MaskReg mask = AscendC::Reg::UpdateMask<float>(pairCount);
        AscendC::Reg::MaskReg fullB16Mask =
            AscendC::Reg::CreateMask<uint16_t, AscendC::Reg::MaskPattern::ALL>();

        for (uint16_t row = 0; row < rows; ++row) {
            uint32_t rowOffset = static_cast<uint32_t>(row) * dk;
            __ubuf__ T *ropeRow = rope + rowOffset;
            __ubuf__ T *cosFirstRow = cosFirst + rowOffset;
            __ubuf__ T *sinFirstRow = sinFirst + rowOffset;
            __ubuf__ T *cosSecondRow = cosSecond + rowOffset;
            __ubuf__ T *sinSecondRow = sinSecond + rowOffset;
            __ubuf__ T *outFirstRow = outFirst + rowOffset;
            __ubuf__ T *outSecondRow = outSecond + rowOffset;

            AscendC::Reg::LoadAlign<T>(xB16, ropeRow);
            AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(realFp32, xB16, fullB16Mask);
            AscendC::Reg::Cast<float, T, CAST_B16_TO_B32_ODD>(imagFp32, xB16, fullB16Mask);
            AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(cosB16, cosFirstRow);
            AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(sinB16, sinFirstRow);
            AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(cosFp32, cosB16, mask);
            AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(sinFp32, sinB16, mask);
            AscendC::Reg::Mul(mul0, realFp32, cosFp32, mask);
            AscendC::Reg::Mul(mul1, imagFp32, sinFp32, mask);
            AscendC::Reg::Sub(result, mul0, mul1, mask);
            AscendC::Reg::Cast<T, float, CAST_B32_TO_B16>(outB16, result, mask);
            AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_PACK_B32>(outFirstRow, outB16, mask);
            AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(cosB16, cosSecondRow);
            AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(sinB16, sinSecondRow);
            AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(cosFp32, cosB16, mask);
            AscendC::Reg::Cast<float, T, CAST_B16_TO_B32>(sinFp32, sinB16, mask);
            AscendC::Reg::Mul(mul0, imagFp32, cosFp32, mask);
            AscendC::Reg::Mul(mul1, realFp32, sinFp32, mask);
            AscendC::Reg::Add(result, mul0, mul1, mask);
            AscendC::Reg::Cast<T, float, CAST_B32_TO_B16>(outB16, result, mask);
            AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_PACK_B32>(outSecondRow, outB16, mask);
        }
    }

    __aicore__ inline void CopyOutK(const LocalTensor<T> &outLocal, int64_t rows, int64_t globalRow, int64_t loopIdx)
    {
        DataCopyExtParams copyParams{1, static_cast<uint32_t>(tiling_->dk * sizeof(T)), 0, 0, 0};
        for (int64_t i = 0; i < rows; ++i) {
            int64_t token = globalRow + i;
            int64_t cacheOffset = indexGm_(loopIdx * ubFactor_ + i);
            WaitScalarToMte3();
            if (cacheOffset >= 0) {
                int64_t batch = token / tiling_->seqLength;
                DataCopyPad(kCacheGm_[(batch * tiling_->cacheLength + cacheOffset) * tiling_->dk],
                    outLocal[i * tiling_->dk], copyParams);
            }
            DataCopyPad(kOutGm_[(loopIdx * ubFactor_ + i) * tiling_->dk], outLocal[i * tiling_->dk], copyParams);
        }
    }

    __aicore__ inline void CopyOutV(const LocalTensor<T> &outLocal, int64_t rows, int64_t globalRow, int64_t loopIdx)
    {
        DataCopyExtParams copyParams{1, static_cast<uint32_t>(tiling_->dv * sizeof(T)), 0, 0, 0};
        for (int64_t i = 0; i < rows; ++i) {
            int64_t token = globalRow + i;
            int64_t cacheOffset = indexGm_(loopIdx * ubFactor_ + i);
            WaitScalarToMte3();
            if (cacheOffset >= 0) {
                int64_t batch = token / tiling_->seqLength;
                DataCopyPad(vCacheGm_[(batch * tiling_->cacheLength + cacheOffset) * tiling_->dv],
                    outLocal[i * tiling_->dv], copyParams);
            }
            DataCopyPad(vOutGm_[(loopIdx * ubFactor_ + i) * tiling_->dv], outLocal[i * tiling_->dv], copyParams);
        }
    }

    __aicore__ inline void WaitScalarToMte3()
    {
        event_t eventId = static_cast<event_t>(GetTPipePtr()->FetchEventID(HardEvent::S_MTE3));
        SetFlag<HardEvent::S_MTE3>(eventId);
        WaitFlag<HardEvent::S_MTE3>(eventId);
    }

    TPipe pipe_;
    TQue<QuePosition::VECIN, 1> gammaQueue_;
    TQue<QuePosition::VECIN, 1> inQueue_;
    TQue<QuePosition::VECIN, 1> cosSinQueue_;
    TQue<QuePosition::VECOUT, 1> outQueue_;

    GlobalTensor<T> kvGm_;
    GlobalTensor<T> gammaGm_;
    GlobalTensor<T> cosGm_;
    GlobalTensor<T> sinGm_;
    GlobalTensor<int64_t> indexGm_;
    GlobalTensor<T> kCacheGm_;
    GlobalTensor<T> vCacheGm_;
    GlobalTensor<T> kOutGm_;
    GlobalTensor<T> vOutGm_;

    KvRmsNormRopeCacheSampleTilingData *tiling_ = nullptr;
    int64_t blockIdx_ = 0;
    int64_t totalRows_ = 0;
    int64_t currentBlockRows_ = 0;
    int64_t ubFactor_ = 0;
    int64_t ubLoop_ = 0;
    uint16_t dvLoop_ = 0;
};

} // namespace

__global__ __aicore__ __vector__ void kv_rms_norm_rope_cache_regbase_full_load(
    __gm__ KvRmsNormRopeCacheSample::DataType *kv, __gm__ KvRmsNormRopeCacheSample::DataType *gamma,
    __gm__ KvRmsNormRopeCacheSample::DataType *cos, __gm__ KvRmsNormRopeCacheSample::DataType *sin,
    __gm__ int64_t *index, __gm__ KvRmsNormRopeCacheSample::DataType *kCache,
    __gm__ KvRmsNormRopeCacheSample::DataType *vCache, __gm__ KvRmsNormRopeCacheSample::DataType *kOut,
    __gm__ KvRmsNormRopeCacheSample::DataType *vOut, KvRmsNormRopeCacheSampleTilingData tiling)
{
    KvRmsNormRopeCacheRegBaseFullLoad<KvRmsNormRopeCacheSample::DataType> op;
    op.Init(kv, gamma, cos, sin, index, kCache, vCache, kOut, vOut, &tiling);
    op.Process();
}

void LaunchRegBaseKernel(uint32_t blockNum, aclrtStream stream, KvRmsNormRopeCacheSample::DataType *kv,
    KvRmsNormRopeCacheSample::DataType *gamma, KvRmsNormRopeCacheSample::DataType *cos,
    KvRmsNormRopeCacheSample::DataType *sin, int64_t *index, KvRmsNormRopeCacheSample::DataType *kCache,
    KvRmsNormRopeCacheSample::DataType *vCache, KvRmsNormRopeCacheSample::DataType *kOut,
    KvRmsNormRopeCacheSample::DataType *vOut, KvRmsNormRopeCacheSampleTilingData tiling)
{
    kv_rms_norm_rope_cache_regbase_full_load<<<blockNum, nullptr, stream>>>(
        kv, gamma, cos, sin, index, kCache, vCache, kOut, vOut, tiling);
}

int main()
{
    return RunSample(LaunchRegBaseKernel, "regbase/full_load");
}
