/**
 * 单 VF 拆分版：二维 ReduceSum，axis=1（沿尾维归约，输出 [D0]），二分累加 VF
 *
 * 从 reduce_sum.asc 拆出 axis=1 二分累加一个 VF（ReduceSumArVfBinary），写法参考
 * Samples/2_Performance/rms_norm_quant_story/src/6_binary_sum.asc 的 binary-add：把一行的求和
 * 元素「成对折叠」到 2 的幂折叠点再 ReduceSum，配对相距 foldPoint 的元素，既把累加串行依赖从
 * 线性 O(块数) 缩到 O(log 块数)，又用成对求和（pairwise summation）降低浮点舍入误差。
 * 二分累加只对 sum 有意义（max 选元素、精确、无精度收益，故 reduce_max 不提供此写法）。
 * 同 axis 的基线 / 多累加器手写展开 / #pragma 自动展开版见
 * reduce_sum_ar_baseline.asc / reduce_sum_ar_unroll.asc / reduce_sum_ar_pragma.asc。
 *
 * 命名约定：ar/ra 拼出 [A,R] 布局、归约其中 R 轴 → ar=归约 axis=1（输出 [D0]）、ra=归约 axis=0（输出 [D1]）；本文件为 ar。
 * 统一 case 规格（[D0,D1]=[78,250]）：每行 250 列 = 4 个 VL(64) 块，foldPoint=128（2 块、2 的幂）。
 *   第 1 层把上半 [128,250) 折到下半 [0,122)（块对 c0+c2、c1+c3，末块 c3 尾部空洞用 mask 屏蔽）；
 *   第 2 层 c0+c1 → 每 lane 含 4 块之和；最后一次向量内 ReduceSum 压成行标量。
 * 本写法按「每行恰 4 个 VL 块」展开，host 侧 static_assert 守护（改规格需同步调整）。
 *
 * 编译 & 运行：
 *   cmake --build build --target reduce_sum_ar_binary
 *   cannsim record ./build/Samples/2_Performance/simd_vf_story/reduce_sum_ar_binary -s Ascend950
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "../../include/vf_common.h"

// ============ VF 层（二分累加）：axis=1，沿尾维归约，成对折叠后向量内 ReduceSum，输出 [d0] ============
// 统一 case 每行 4 个 VL 块，foldPoint=128（=2 块）。二分树：c0+c2、c1+c3（第 1 层）→ c0+c1（第 2 层）。
__simd_vf__ inline void ReduceSumArVfBinary(__ubuf__ float* xAddr, __ubuf__ float* zAddr,
                                            uint32_t d0, uint32_t d1, uint32_t d1Pad)
{
    AscendC::Reg::RegTensor<float> c0, c1, c2, c3, outReg;
    AscendC::Reg::UnalignRegForStore unalignAcc;                                  // 非对齐散出累积器
    AscendC::Reg::MaskReg fullMask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < static_cast<uint16_t>(d0); i++) {   // 行循环：每行二分折叠出一个标量
        const uint32_t base = i * d1Pad;
        uint32_t lastValid = d1 - 3u * VL_B32;                   // 末块有效列数（250-192=58）；UpdateMask 会原地递减
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(c0, xAddr + base + 0u * VL_B32);  // [0:64)
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(c1, xAddr + base + 1u * VL_B32);  // [64:128)
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(c2, xAddr + base + 2u * VL_B32);  // [128:192)
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(c3, xAddr + base + 3u * VL_B32);  // [192:256)
        AscendC::Reg::MaskReg lastMask = AscendC::Reg::UpdateMask<float>(lastValid);                       // 末块 58 个有效 lane
        // 第 1 层：配对距离 foldPoint=128（=2 块）。c2 整块有效；c3 尾部 [58,64) 是行外 padding，
        // 用 MERGING+lastMask 屏蔽（mask 外保留 c1 原值，不污染）。两条 Add 相互独立 → 串行步数减半。
        AscendC::Reg::Add(c0, c0, c2, fullMask);                                                           // [0:64)+[128:192)
        AscendC::Reg::Add<float, AscendC::Reg::MaskMergeMode::MERGING>(c1, c1, c3, lastMask);              // [64:128)+[192:250)
        // 第 2 层：c0+c1 → 每 lane 含 4 块之和；再向量内 ReduceSum 压成行标量
        AscendC::Reg::Add(c0, c0, c1, fullMask);
        AscendC::Reg::ReduceSum(outReg, c0, fullMask);            // 64 lane → 行和落 lane0
        AscendC::Reg::StoreUnAlign(zAddr, outReg, unalignAcc, 1); // 追加 1 个标量，zAddr 自动后移
    }
    AscendC::Reg::StoreUnAlignPost(zAddr, unalignAcc, 0);         // 冲刷尾部不足一个 block 的残留
}

// ============ Kernel：单核单 tile，标准 CopyIn → Compute → CopyOut 三段式 ============
class KernelReduceSum {
public:
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR z, uint32_t d0, uint32_t d1)
    {
        d0_ = d0;
        d1_ = d1;
        d1Pad_ = (d1_ + UB_ALIGN - 1) / UB_ALIGN * UB_ALIGN;
        outLen_ = d0_;                                         // axis=1 输出 [d0]
        xGm_.SetGlobalBuffer((__gm__ float*)x, d0_ * d1_);
        zGm_.SetGlobalBuffer((__gm__ float*)z, outLen_);
        uint32_t inBytes = (d0_ * d1Pad_ + VL_B32) * sizeof(float);
        uint32_t outBytes = (outLen_ * sizeof(float) + 31) / 32 * 32;
        pipe_.InitBuffer(inQueue_, 1, (inBytes + 31) / 32 * 32);
        pipe_.InitBuffer(outQueue_, 1, outBytes);
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<float> xUb = inQueue_.AllocTensor<float>();
        AscendC::DataCopyExtParams params{1, static_cast<uint32_t>(d1_ * sizeof(float)), 0, 0, 0};
        AscendC::DataCopyPadExtParams<float> padParams{false, 0, 0, 0.f};
        for (uint32_t i = 0; i < d0_; i++) {
            AscendC::DataCopyPad(xUb[i * d1Pad_], xGm_[i * d1_], params, padParams);
        }
        inQueue_.EnQue(xUb);
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<float> xUb = inQueue_.DeQue<float>();
        AscendC::LocalTensor<float> zUb = outQueue_.AllocTensor<float>();
        auto* xAddr = (__ubuf__ float*)xUb.GetPhyAddr();
        auto* zAddr = (__ubuf__ float*)zUb.GetPhyAddr();
        for (int r = 0; r < VF_REPEAT; r++) {
            asc_vf_call<ReduceSumArVfBinary>(xAddr, zAddr, d0_, d1_, d1Pad_);
        }
        outQueue_.EnQue(zUb);
        inQueue_.FreeTensor(xUb);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<float> zUb = outQueue_.DeQue<float>();
        AscendC::DataCopyExtParams params{1, static_cast<uint32_t>(outLen_ * sizeof(float)), 0, 0, 0};
        AscendC::DataCopyPad(zGm_, zUb, params);
        outQueue_.FreeTensor(zUb);
    }

    AscendC::TPipe pipe_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueue_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueue_;
    AscendC::GlobalTensor<float> xGm_, zGm_;
    uint32_t d0_, d1_, d1Pad_, outLen_;
};

__global__ __aicore__ __vector__ void ReduceSumKernel(GM_ADDR x, GM_ADDR z, uint32_t d0, uint32_t d1)
{
    KernelReduceSum op;
    op.Init(x, z, d0, d1);
    op.Process();
}

// ============ Host 侧：随机输入（头文件共用）+ 本地 golden 校验 ============
int main()
{
    // 本二分写法按「每行恰 4 个 VL 块、foldPoint=128」硬展开；改规格需同步调整 VF。
    static_assert((D1 + VL_B32 - 1) / VL_B32 == 4, "reduce_sum_ar_binary 假设每行 4 个 VL 块");

    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    const uint32_t outLen = D0;
    std::vector<float> hX = vf::GenInput(D0 * D1);            // 16 个 VF 共用同一份随机输入
    std::vector<float> ref(outLen, 0.f);
    {
        std::vector<double> acc(outLen, 0.0);
        for (uint32_t i = 0; i < D0; i++)
            for (uint32_t j = 0; j < D1; j++) acc[i] += (double)hX[i * D1 + j];  // 标杆：每行 double 求和
        for (uint32_t k = 0; k < outLen; k++) ref[k] = (float)acc[k];
    }
    std::vector<float> hZ(outLen, 0.f);

    uint8_t *dX, *dZ;
    CHECK_ACL(aclrtMalloc((void**)&dX, hX.size() * sizeof(float), ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dZ, outLen * sizeof(float), ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, hX.size() * sizeof(float), hX.data(), hX.size() * sizeof(float),
                          ACL_MEMCPY_HOST_TO_DEVICE));

    ReduceSumKernel<<<1, nullptr, stream>>>(dX, dZ, D0, D1);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hZ.data(), outLen * sizeof(float), dZ, outLen * sizeof(float),
                          ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = vf::VerifyRel(hZ, ref, 1e-3);
    std::cout << "[reduce_sum axis1 binary] [" << D0 << "x" << D1 << "] outLen=" << outLen << " z[0..2]=" << hZ[0]
              << " " << hZ[1] << " " << hZ[2] << " | z[" << (outLen - 1) << "]=" << hZ[outLen - 1]
              << " -> " << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dZ);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
