/**
 * 单 VF 拆分版：二维 ReduceSum，axis=0（沿首维归约，输出 [D1]），多累加器展开 VF
 *
 * 从 reduce_sum.asc 拆出 axis=0 多累加器展开一个 VF（ReduceSumRaVfUnroll）：用 4 个独立累加器
 * acc0..acc3 按行号分组累加（行 r 进 acc[r%4]），最后两两合并 → 4 条归约流并行，利于双发/延迟
 * 隐藏。尾部不足 4 的行用第二个 for 处理。注：4 个部分和改变了浮点求和顺序，结果与基线有低位
 * 舍入差异（host golden 用 double+相对容差，仍 PASS）。
 *
 * 命名约定：ar/ra 拼出 [A,R] 布局、归约其中 R 轴 → ar=归约 axis=1（输出 [D0]）、ra=归约 axis=0（输出 [D1]）；本文件为 ra。
 * 统一 case 规格（本目录 16 个 VF 文件共用）：[D0,D1]=[78,250]，D1>VL 且 %8≠0、D0%4=2（覆盖分块 / 尾块 / 展开尾行各路径）。
 *
 * 编译 & 运行：
 *   cmake --build build --target reduce_sum_ra_unroll
 *   cannsim record ./build/Samples/2_Performance/simd_vf_story/reduce_sum_ra_unroll -s Ascend950
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "../../include/vf_common.h"

// ============ VF 层（多累加器展开）：axis=0，4 个独立累加器并行跨行 Add ============
__simd_vf__ inline void ReduceSumRaVfUnroll(__ubuf__ float* xAddr, __ubuf__ float* zAddr,
                                            uint32_t d0, uint32_t d1, uint32_t d1Pad)
{
    AscendC::Reg::RegTensor<float> acc0, acc1, acc2, acc3, in0, in1, in2, in3;
    uint32_t remainCols = d1;
    const uint16_t colChunks = static_cast<uint16_t>((d1 + VL_B32 - 1) / VL_B32);

    for (uint16_t c = 0; c < colChunks; c++) {
        AscendC::Reg::MaskReg mask = AscendC::Reg::UpdateMask<float>(remainCols);
        AscendC::Reg::Duplicate(acc0, 0.0f); AscendC::Reg::Duplicate(acc1, 0.0f);
        AscendC::Reg::Duplicate(acc2, 0.0f); AscendC::Reg::Duplicate(acc3, 0.0f);
        const uint16_t groups = static_cast<uint16_t>(d0) / 4;
        for (uint16_t g = 0; g < groups; g++) {              // 主循环：每轮 4 行 → 4 个独立累加器
            const uint16_t r = static_cast<uint16_t>(g * 4);
            AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(in0, xAddr + (r + 0) * d1Pad + c * VL_B32);
            AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(in1, xAddr + (r + 1) * d1Pad + c * VL_B32);
            AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(in2, xAddr + (r + 2) * d1Pad + c * VL_B32);
            AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(in3, xAddr + (r + 3) * d1Pad + c * VL_B32);
            AscendC::Reg::Add(acc0, acc0, in0, mask);
            AscendC::Reg::Add(acc1, acc1, in1, mask);
            AscendC::Reg::Add(acc2, acc2, in2, mask);
            AscendC::Reg::Add(acc3, acc3, in3, mask);
        }
        for (uint16_t r = static_cast<uint16_t>(groups * 4); r < static_cast<uint16_t>(d0); r++) {  // 尾部 0~3 行
            AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(in0, xAddr + r * d1Pad + c * VL_B32);
            AscendC::Reg::Add(acc0, acc0, in0, mask);
        }
        AscendC::Reg::Add(acc0, acc0, acc1, mask);           // 合并 4 个累加器
        AscendC::Reg::Add(acc2, acc2, acc3, mask);
        AscendC::Reg::Add(acc0, acc0, acc2, mask);
        AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(zAddr + c * VL_B32, acc0, mask);
    }
}

// ============ Kernel：单核单 tile，标准 CopyIn → Compute → CopyOut 三段式 ============
class KernelReduceSum {
public:
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR z, uint32_t d0, uint32_t d1)
    {
        d0_ = d0;
        d1_ = d1;
        d1Pad_ = (d1_ + UB_ALIGN - 1) / UB_ALIGN * UB_ALIGN;
        outLen_ = d1_;                                        // axis=0 输出 [d1]
        xGm_.SetGlobalBuffer((__gm__ float*)x, d0_ * d1_);
        zGm_.SetGlobalBuffer((__gm__ float*)z, outLen_);
        uint32_t inBytes = (d0_ * d1Pad_ + VL_B32) * sizeof(float);
        uint32_t outBytes = (outLen_ * sizeof(float) + 31) / 32 * 32;
        pipe_.InitBuffer(inQueue_, 1, (inBytes + 31) / 32 * 32);
        pipe_.InitBuffer(outQueue_, 1, outBytes);
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<float> xUb = inQueue_.AllocTensor<float>();
        AscendC::DataCopyExtParams params{1, static_cast<uint32_t>(d1_ * sizeof(float)), 0, 0, 0};
        AscendC::DataCopyPadExtParams<float> padParams{false, 0, 0, 0.f};
        for (uint32_t i = 0; i < d0_; i++) {
            AscendC::DataCopyPad(xUb[i * d1Pad_], xGm_[i * d1_], params, padParams);
        }
        inQueue_.EnQue(xUb);
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<float> xUb = inQueue_.DeQue<float>();
        AscendC::LocalTensor<float> zUb = outQueue_.AllocTensor<float>();
        auto* xAddr = (__ubuf__ float*)xUb.GetPhyAddr();
        auto* zAddr = (__ubuf__ float*)zUb.GetPhyAddr();
        for (int r = 0; r < VF_REPEAT; r++) {
            asc_vf_call<ReduceSumRaVfUnroll>(xAddr, zAddr, d0_, d1_, d1Pad_);
        }
        outQueue_.EnQue(zUb);
        inQueue_.FreeTensor(xUb);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<float> zUb = outQueue_.DeQue<float>();
        AscendC::DataCopyExtParams params{1, static_cast<uint32_t>(outLen_ * sizeof(float)), 0, 0, 0};
        AscendC::DataCopyPad(zGm_, zUb, params);
        outQueue_.FreeTensor(zUb);
    }

    AscendC::TPipe pipe_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueue_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueue_;
    AscendC::GlobalTensor<float> xGm_, zGm_;
    uint32_t d0_, d1_, d1Pad_, outLen_;
};

__global__ __aicore__ __vector__ void ReduceSumKernel(GM_ADDR x, GM_ADDR z, uint32_t d0, uint32_t d1)
{
    KernelReduceSum op;
    op.Init(x, z, d0, d1);
    op.Process();
}

// ============ Host 侧：随机输入（头文件共用）+ 本地 golden 校验 ============
int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    const uint32_t outLen = D1;
    std::vector<float> hX = vf::GenInput(D0 * D1);            // 16 个 VF 共用同一份随机输入
    std::vector<float> ref(outLen, 0.f);
    {
        std::vector<double> acc(outLen, 0.0);
        for (uint32_t i = 0; i < D0; i++)
            for (uint32_t j = 0; j < D1; j++) acc[j] += (double)hX[i * D1 + j];  // 标杆：每列 double 求和
        for (uint32_t k = 0; k < outLen; k++) ref[k] = (float)acc[k];
    }
    std::vector<float> hZ(outLen, 0.f);

    uint8_t *dX, *dZ;
    CHECK_ACL(aclrtMalloc((void**)&dX, hX.size() * sizeof(float), ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dZ, outLen * sizeof(float), ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, hX.size() * sizeof(float), hX.data(), hX.size() * sizeof(float),
                          ACL_MEMCPY_HOST_TO_DEVICE));

    ReduceSumKernel<<<1, nullptr, stream>>>(dX, dZ, D0, D1);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hZ.data(), outLen * sizeof(float), dZ, outLen * sizeof(float),
                          ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = vf::VerifyRel(hZ, ref, 1e-3);
    std::cout << "[reduce_sum axis0 unroll] [" << D0 << "x" << D1 << "] outLen=" << outLen << " z[0..2]=" << hZ[0]
              << " " << hZ[1] << " " << hZ[2] << " | z[" << (outLen - 1) << "]=" << hZ[outLen - 1]
              << " -> " << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dZ);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
