/*!
 * \file tail_axis_1_naive_getvalue.asc
 * \brief
 */

#include "tail_axis_common.h"

// VF外循环行，用GetValue获取a的值给VF内循环列
__simd_vf__ inline void ComputeVF(
    __ubuf__ float* xAddr, __ubuf__ float* yAddr, uint32_t n, uint16_t vfLoopN, float aVal)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();
    
    uint32_t remain = n;
    for (uint16_t i = 0; i < vfLoopN; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remain);
        AscendC::Reg::LoadAlign<float>(xReg, xAddr + i * VL_B32);
        AscendC::Reg::Adds<float>(yReg, xReg, aVal, mask);
        AscendC::Reg::StoreAlign<float>(yAddr + i * VL_B32, yReg, mask);
    }
}

__global__ __vector__ void brc_tail_axis_1_naive_getvalue_k(
    __gm__ float* x, __gm__ float* a, __gm__ float* y, BroadcastTailAxisTilingData tiling)
{
    BrcGlobal xGlobal;
    BrcGlobal aGlobal;
    BrcGlobal yGlobal;
    xGlobal.SetGlobalBuffer(x);
    aGlobal.SetGlobalBuffer(a);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TPipe pipe;
    BrcInQueue xQueue;
    BrcInQueue aQueue;
    BrcOutQueue yQueue;
    pipe.InitBuffer(xQueue, 1, tiling.xBytesAligned);
    pipe.InitBuffer(aQueue, 1, tiling.aBytesAligned);
    pipe.InitBuffer(yQueue, 1, tiling.xBytesAligned);

    BrcLocal xLocal = xQueue.AllocTensor<float>();
    BrcLocal aLocal = aQueue.AllocTensor<float>();
    BrcLocal yLocal = yQueue.AllocTensor<float>();
    RowiseCopyIn(xLocal, xGlobal, tiling.m, tiling.n, tiling.nElemsAligned);
    RowiseCopyIn(aLocal, aGlobal, 1, tiling.m, tiling.aElemsAligned);
    xQueue.EnQue<float>(xLocal);
    aQueue.EnQue<float>(aLocal);
    xLocal = xQueue.DeQue<float>();
    aLocal = aQueue.DeQue<float>();

    auto* xUb = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    auto* yUb = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());
    for (uint32_t j = 0; j < tiling.m; ++j) {
        asc_vf_call<ComputeVF>(
            xUb + j * tiling.nElemsAligned, yUb + j * tiling.nElemsAligned, tiling.n, VFLoopNumForB32(tiling.n),
            aLocal.GetValue(j));
    }

    xQueue.FreeTensor<float>(xLocal);
    aQueue.FreeTensor<float>(aLocal);
    yQueue.EnQue<float>(yLocal);
    yLocal = yQueue.DeQue<float>();
    RowiseCopyOut(yGlobal, yLocal, tiling.m, tiling.n, tiling.nElemsAligned);
    yQueue.FreeTensor<float>(yLocal);
    pipe.Destroy();
}

int main()
{
    return RunTailAxisBroadcastCase(
        "BRC_TAIL_AXIS", [](aclrtStream stream, float* x, float* a, float* y, BroadcastTailAxisTilingData tiling) {
            brc_tail_axis_1_naive_getvalue_k<<<1, nullptr, stream>>>(x, a, y, tiling);
        });
}
