/*!
 * \file head_axis_2_vfloop_nm.asc
 * \brief
 */

#include "head_axis_common.h"

// 先循环列再循环行
__simd_vf__ inline void ComputeVF(
    __ubuf__ float* xAddr, __ubuf__ float* aAddr, __ubuf__ float* yAddr, uint32_t n, uint32_t nElemsAligned,
    uint16_t vfLoopM, uint16_t vfLoopN)
{
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> aReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<float, AscendC::Reg::MaskPattern::ALL>();

    uint32_t remain = n;
    for (uint16_t i = 0; i < vfLoopN; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(remain);
        AscendC::Reg::LoadAlign<float>(aReg, aAddr + i * VL_B32);
        for (uint16_t j = 0; j < vfLoopM; ++j) {
            AscendC::Reg::LoadAlign<float>(xReg, xAddr + i * VL_B32 + j * nElemsAligned);
            AscendC::Reg::Add<float>(yReg, xReg, aReg, mask);
            AscendC::Reg::StoreAlign<float>(yAddr + i * VL_B32 + j * nElemsAligned, yReg, mask);
        }
    }
}

__global__ __vector__ void brc_head_axis_2_vfloop_nm_k(
    __gm__ float* x, __gm__ float* a, __gm__ float* y, BroadcastHeadAxisTilingData tiling)
{
    BrcGlobal xGlobal;
    BrcGlobal aGlobal;
    BrcGlobal yGlobal;
    xGlobal.SetGlobalBuffer(x);
    aGlobal.SetGlobalBuffer(a);
    yGlobal.SetGlobalBuffer(y);

    AscendC::TPipe pipe;
    BrcInQueue xQueue;
    BrcInQueue aQueue;
    BrcOutQueue yQueue;
    pipe.InitBuffer(xQueue, 1, tiling.xBytesAligned);
    pipe.InitBuffer(aQueue, 1, tiling.aBytesAligned);
    pipe.InitBuffer(yQueue, 1, tiling.xBytesAligned);

    BrcLocal xLocal = xQueue.AllocTensor<float>();
    BrcLocal aLocal = aQueue.AllocTensor<float>();
    BrcLocal yLocal = yQueue.AllocTensor<float>();
    RowiseCopyIn(xLocal, xGlobal, tiling.m, tiling.n, tiling.nElemsAligned);
    RowiseCopyIn(aLocal, aGlobal, 1, tiling.n, tiling.nElemsAligned);
    xQueue.EnQue<float>(xLocal);
    aQueue.EnQue<float>(aLocal);
    xLocal = xQueue.DeQue<float>();
    aLocal = aQueue.DeQue<float>();

    auto* xUb = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    auto* aUb = reinterpret_cast<__ubuf__ float*>(aLocal.GetPhyAddr());
    auto* yUb = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());
    asc_vf_call<ComputeVF>(
        xUb, aUb, yUb, tiling.n, tiling.nElemsAligned, static_cast<uint16_t>(tiling.m), VFLoopNumForB32(tiling.n));

    xQueue.FreeTensor<float>(xLocal);
    aQueue.FreeTensor<float>(aLocal);
    yQueue.EnQue<float>(yLocal);
    yLocal = yQueue.DeQue<float>();
    RowiseCopyOut(yGlobal, yLocal, tiling.m, tiling.n, tiling.nElemsAligned);
    yQueue.FreeTensor<float>(yLocal);
    pipe.Destroy();
}

int main()
{
    return RunHeadAxisBroadcastCase(
        "BRC_HEAD_AXIS", [](aclrtStream stream, float* x, float* a, float* y, BroadcastHeadAxisTilingData tiling) {
            brc_head_axis_2_vfloop_nm_k<<<1, nullptr, stream>>>(x, a, y, tiling);
        });
}
