/**
 * 单 VF 拆分版：Elementwise AXPY: z = a * x + y（手写展开 VF）
 *
 * 从 elemwise_axpy.asc 拆出「手写展开」一个 VF（ElemwiseAxpyVfUnroll）：一轮用 UNROLL=4 组独立
 * 命名寄存器算 UNROLL 个 VL 块，显式暴露多条独立指令流（双发 + 延迟隐藏）。基线 / #pragma 版见
 * 同目录 elemwise_axpy_baseline.asc / elemwise_axpy_pragma.asc。
 *
 * 统一 case 规格（本目录 16 个 VF 文件全部一致）：[D0,D1]=[78,250]，N=D0*D1=19500。
 *
 * 编译 & 运行：
 *   cmake --build build --target elemwise_axpy_unroll
 *   cannsim record ./build/Samples/2_Performance/simd_vf_story/elemwise_axpy_unroll -s Ascend950
 */

#include <iostream>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "../../include/vf_common.h"

static constexpr uint16_t UNROLL = 4;                     // 手动展开因子：一轮算 4 个 VL 块
static constexpr float A = 2.0f;

// ============ VF 层（手写展开）：一轮循环算 UNROLL 个 VL 块 ============
// 用 UNROLL 组互相独立的命名寄存器（VF 不支持 RegTensor 数组下标）。尾部凑不满 UNROLL 的块：
// count 扣到 0 后 UpdateMask 返回空 mask，Load 多读落在已分配 UB、Store 不写，无副作用。
__simd_vf__ inline void ElemwiseAxpyVfUnroll(__ubuf__ float* xAddr, __ubuf__ float* yAddr,
                                             __ubuf__ float* zAddr, float a, uint32_t n, uint16_t loopNum)
{
    static_assert(UNROLL == 4, "下面是 4 组命名寄存器手动展开，改 UNROLL 需同步增减寄存器组");
    AscendC::Reg::RegTensor<float> vx0, vx1, vx2, vx3, vy0, vy1, vy2, vy3, vt0, vt1, vt2, vt3;
    AscendC::Reg::MaskReg m0, m1, m2, m3;
    uint32_t count = n;
    const uint16_t outer = (loopNum + UNROLL - 1) / UNROLL;       // 外层轮数 = 块数 / 展开因子（向上取整）

    for (uint16_t i = 0; i < outer; i++) {
        const uint16_t base = i * UNROLL;
        m0 = AscendC::Reg::UpdateMask<float>(count);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vx0, xAddr + (base + 0) * VL_B32);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vy0, yAddr + (base + 0) * VL_B32);
        m1 = AscendC::Reg::UpdateMask<float>(count);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vx1, xAddr + (base + 1) * VL_B32);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vy1, yAddr + (base + 1) * VL_B32);
        m2 = AscendC::Reg::UpdateMask<float>(count);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vx2, xAddr + (base + 2) * VL_B32);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vy2, yAddr + (base + 2) * VL_B32);
        m3 = AscendC::Reg::UpdateMask<float>(count);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vx3, xAddr + (base + 3) * VL_B32);
        AscendC::Reg::LoadAlign<float, AscendC::Reg::LoadDist::DIST_NORM>(vy3, yAddr + (base + 3) * VL_B32);
        AscendC::Reg::Muls(vt0, vx0, a, m0); AscendC::Reg::Add(vt0, vt0, vy0, m0);
        AscendC::Reg::Muls(vt1, vx1, a, m1); AscendC::Reg::Add(vt1, vt1, vy1, m1);
        AscendC::Reg::Muls(vt2, vx2, a, m2); AscendC::Reg::Add(vt2, vt2, vy2, m2);
        AscendC::Reg::Muls(vt3, vx3, a, m3); AscendC::Reg::Add(vt3, vt3, vy3, m3);
        AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(zAddr + (base + 0) * VL_B32, vt0, m0);
        AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(zAddr + (base + 1) * VL_B32, vt1, m1);
        AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(zAddr + (base + 2) * VL_B32, vt2, m2);
        AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_NORM>(zAddr + (base + 3) * VL_B32, vt3, m3);
    }
}

// ============ Kernel：单核单 tile，标准 CopyIn → Compute → CopyOut 三段式 ============
class KernelElemwiseAxpy {
public:
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR z, uint32_t n)
    {
        n_ = n;
        loopNum_ = (n_ + VL_B32 - 1) / VL_B32;
        uint32_t chunksPad = (loopNum_ + UNROLL - 1) / UNROLL * UNROLL;  // 凑齐 UNROLL，覆盖手写展开的多读
        uint32_t bufBytes = chunksPad * VL_B32 * sizeof(float);
        xGm_.SetGlobalBuffer((__gm__ float*)x, n_);
        yGm_.SetGlobalBuffer((__gm__ float*)y, n_);
        zGm_.SetGlobalBuffer((__gm__ float*)z, n_);
        pipe_.InitBuffer(inQueueX_, 1, bufBytes);
        pipe_.InitBuffer(inQueueY_, 1, bufBytes);
        pipe_.InitBuffer(outQueueZ_, 1, bufBytes);
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<float> xUb = inQueueX_.AllocTensor<float>();
        AscendC::LocalTensor<float> yUb = inQueueY_.AllocTensor<float>();
        AscendC::DataCopyExtParams params{1, static_cast<uint32_t>(n_ * sizeof(float)), 0, 0, 0};
        AscendC::DataCopyPadExtParams<float> padParams{false, 0, 0, 0.f};
        AscendC::DataCopyPad(xUb, xGm_, params, padParams);
        AscendC::DataCopyPad(yUb, yGm_, params, padParams);
        inQueueX_.EnQue(xUb);
        inQueueY_.EnQue(yUb);
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<float> xUb = inQueueX_.DeQue<float>();
        AscendC::LocalTensor<float> yUb = inQueueY_.DeQue<float>();
        AscendC::LocalTensor<float> zUb = outQueueZ_.AllocTensor<float>();

        auto* x = (__ubuf__ float*)xUb.GetPhyAddr();
        auto* y = (__ubuf__ float*)yUb.GetPhyAddr();
        auto* z = (__ubuf__ float*)zUb.GetPhyAddr();
        for (int r = 0; r < VF_REPEAT; r++) {
            asc_vf_call<ElemwiseAxpyVfUnroll>(x, y, z, A, n_, static_cast<uint16_t>(loopNum_));
        }

        outQueueZ_.EnQue(zUb);
        inQueueX_.FreeTensor(xUb);
        inQueueY_.FreeTensor(yUb);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<float> zUb = outQueueZ_.DeQue<float>();
        AscendC::DataCopyExtParams params{1, static_cast<uint32_t>(n_ * sizeof(float)), 0, 0, 0};
        AscendC::DataCopyPad(zGm_, zUb, params);
        outQueueZ_.FreeTensor(zUb);
    }

    AscendC::TPipe pipe_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX_, inQueueY_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueZ_;
    AscendC::GlobalTensor<float> xGm_, yGm_, zGm_;
    uint32_t n_, loopNum_;
};

__global__ __aicore__ __vector__ void ElemwiseAxpyKernel(GM_ADDR x, GM_ADDR y, GM_ADDR z, uint32_t n)
{
    KernelElemwiseAxpy op;
    op.Init(x, y, z, n);
    op.Process();
}

// ============ Host 侧：随机输入（头文件共用）+ 本地 golden 校验 ============
int main()
{
    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));
    aclrtStream stream;
    CHECK_ACL(aclrtCreateStream(&stream));

    size_t bytes = N * sizeof(float);
    std::vector<float> hX = vf::GenInput(N);                  // x、y 共用同一份随机输入
    std::vector<float> ref(N);
    for (uint32_t i = 0; i < N; i++) ref[i] = A * hX[i] + hX[i];   // 标杆：z = a*x + y（x=y）
    std::vector<float> hZ(N, 0.f);

    uint8_t *dX, *dY, *dZ;
    CHECK_ACL(aclrtMalloc((void**)&dX, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dY, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc((void**)&dZ, bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(dX, bytes, hX.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(dY, bytes, hX.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    ElemwiseAxpyKernel<<<1, nullptr, stream>>>(dX, dY, dZ, N);
    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(hZ.data(), bytes, dZ, bytes, ACL_MEMCPY_DEVICE_TO_HOST));

    bool ok = vf::VerifyAbs(hZ, ref, 1e-4f);
    std::cout << "[elemwise_axpy unroll] N=" << N << " z[0..2]=" << hZ[0] << " " << hZ[1] << " " << hZ[2]
              << " | z[" << (N - 1) << "]=" << hZ[N - 1] << " -> " << (ok ? "PASSED" : "FAILED") << std::endl;

    aclrtFree(dX); aclrtFree(dY); aclrtFree(dZ);
    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return ok ? 0 : 1;
}
